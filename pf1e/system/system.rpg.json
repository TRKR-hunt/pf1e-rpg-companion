{
 "id": "pf1e",
 "name": "Pathfinder 1e",
 "abbreviation": "PF1e",
 "version": "0.0.2",
 "min_app_version": "1.2.0",
 "character_indexed_stats": [
  "name",
  "created_at_display",
  "description"
 ],
 "progression_systems": {
  "experience_levelling_system": {
   "level_up_view_title": {
    "type": "concat",
    "components": {
     "type": "list",
     "components": [
      {
       "type": "constant",
       "value": "Level Up to ",
       "value_type": "string"
      },
      {
       "type": "add",
       "components": {
        "type": "list",
        "components": [
         {
          "type": "stat",
          "stat": "level"
         },
         {
          "type": "constant",
          "value": 1,
          "value_type": "integer"
         }
        ]
       }
      }
     ]
    }
   },
   "level_up_button_text": "Advance Level",
   "level_up_icon": "ic_progression",
   "level_up_icon_color": "#FFB300",
   "level_up_view": {
    "id": "level_up",
    "type": "list",
    "padding": 16,
    "subviews": [
     {
      "id": "level_up_pick_hdr",
      "type": "text",
      "text": {
       "type": "constant",
       "value": "Level Up",
       "value_type": "string"
      },
      "style": "title",
      "bold": true
     },
     {
      "id": "level_up_as_comp",
      "type": "composite",
      "subviews": [
       {
        "id": "level_up_label",
        "type": "text",
        "text": {
         "type": "constant",
         "value": "Level up as a ",
         "value_type": "string"
        },
        "style": "text"
       },
       {
        "id": "level_up_select_class",
        "type": "select",
        "stat": "temp_level_up_class",
        "resource_options": {
         "type": "map",
         "components": {
          "type": "stat",
          "stat": "classes"
         },
         "mapper": {
          "type": "stat",
          "stat": "$mapValue.class"
         }
        },
        "options_display_stat": "name"
       }
      ]
     },
     {
      "id": "level_up_multiclass_check",
      "type": "checkbox",
      "stat": "temp_level_up_multiclass",
      "label": {
       "type": "constant",
       "value": "Multiclass: add a level of a NEW class instead",
       "value_type": "string"
      },
      "label_alignment": "right",
      "style": "checkbox",
      "margin_top": 8
     },
     {
      "id": "level_up_new_class",
      "type": "resource",
      "view_type": "edit",
      "resource_id": "class_progression",
      "stat": "temp_level_up_new_class",
      "create_if_empty": true,
      "is_visible": {
       "type": "defaultIfNull",
       "components": {
        "type": "stat",
        "stat": "$view?.level_up_multiclass_check?"
       },
       "default_components": {
        "type": "constant",
        "value": false,
        "value_type": "bool"
       }
      },
      "validation_message": {
       "type": "when",
       "clauses": [
        {
         "condition": {
          "type": "isNull",
          "components": {
           "type": "defaultIfNull",
           "components": {
            "type": "stat",
            "stat": "$view?.level_up_new_class?"
           },
           "default_components": {
            "type": "constant",
            "value": false,
            "value_type": "bool"
           }
          }
         },
         "components": {
          "type": "constant",
          "value": "Pick the class you want to multiclass into.",
          "value_type": "string"
         }
        },
        {
         "condition": {
          "type": "contains",
          "haystack": {
           "type": "map",
           "components": {
            "type": "stat",
            "stat": "classes"
           },
           "mapper": {
            "type": "stat",
            "stat": "$mapValue.class.name"
           }
          },
          "needle": {
           "type": "stat",
           "stat": "$view?.level_up_new_class?.$view?.class_progression_edit_class_select?.name"
          }
         },
         "components": {
          "type": "constant",
          "value": "You already have levels in that class — uncheck multiclass to level it, or pick a different class.",
          "value_type": "string"
         }
        },
        {
         "condition": {
          "type": "not",
          "components": {
           "type": "isEmpty",
           "components": {
            "type": "defaultIfNull",
            "components": {
             "type": "stat",
             "stat": "level_up_multiclass_alignment_error"
            },
            "default_components": {
             "type": "constant",
             "value": "",
             "value_type": "string"
            }
           }
          }
         },
         "components": {
          "type": "stat",
          "stat": "level_up_multiclass_alignment_error"
         }
        },
        {
         "condition": {
          "type": "constant",
          "value": true,
          "value_type": "bool"
         },
         "components": {
          "type": "constant",
          "value": null,
          "value_type": "string"
         }
        }
       ]
      }
     },
     {
      "id": "level_up_multiclass_align_warn",
      "type": "text",
      "text": {
       "type": "stat",
       "stat": "level_up_multiclass_alignment_error"
      },
      "style": "caption",
      "margin_top": 4,
      "is_visible": {
       "type": "and",
       "components": {
        "type": "list",
        "components": [
         {
          "type": "defaultIfNull",
          "components": {
           "type": "stat",
           "stat": "$view?.level_up_multiclass_check?"
          },
          "default_components": {
           "type": "constant",
           "value": false,
           "value_type": "bool"
          }
         },
         {
          "type": "not",
          "components": {
           "type": "isEmpty",
           "components": {
            "type": "defaultIfNull",
            "components": {
             "type": "stat",
             "stat": "level_up_multiclass_alignment_error"
            },
            "default_components": {
             "type": "constant",
             "value": "",
             "value_type": "string"
            }
           }
          }
         }
        ]
       }
      }
     },
     {
