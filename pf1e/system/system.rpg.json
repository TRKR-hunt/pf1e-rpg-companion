        ]
       }
      },
      "style": "text",
      "margin_top": 6,
      "is_visible": {
       "type": "stat",
       "stat": "level_up_class_selected"
      }
     },
     {
      "id": "level_up_saves_preview",
      "type": "text",
      "text": {
       "type": "concat",
       "components": {
        "type": "list",
        "components": [
         {
          "type": "constant",
          "value": "Saves  Fort +",
          "value_type": "string"
         },
         {
          "type": "stat",
          "stat": "fortitude_base"
         },
         {
          "type": "constant",
          "value": "->+",
          "value_type": "string"
         },
         {
          "type": "stat",
