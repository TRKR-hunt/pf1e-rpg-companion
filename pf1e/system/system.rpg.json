      }
     },
     {
      "id": "level_up_asi_prompt",
      "type": "text",
      "text": {
       "type": "concat",
       "components": {
        "type": "list",
        "components": [
         {
          "type": "constant",
          "value": "Ability Score Increase (levels 4/8/12/16/20): raise one ability +1.  Currently: ",
          "value_type": "string"
         },
         {
          "type": "stat",
          "stat": "level_up_asi_display"
         }
        ]
       }
      },
      "style": "caption",
      "margin_top": 10,
      "is_visible": {
       "type": "stat",
       "stat": "level_up_is_asi_level"
      }
     },
     {
      "id": "level_up_feat_reminder",
      "type": "text",
      "text": {
       "type": "constant",
