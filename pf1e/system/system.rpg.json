      },
      "style": "caption",
      "margin_top": 8,
      "is_visible": {
       "type": "stat",
       "stat": "level_up_is_feat_level"
      }
     },
     {
      "id": "level_up_caster_reminder",
      "type": "text",
      "text": {
       "type": "constant",
       "value": "Spellcaster: your spells per day / spells known advance — manage them in the Spells section.",
       "value_type": "string"
      },
      "style": "caption",
      "margin_top": 8,
      "is_visible": {
       "type": "stat",
       "stat": "level_up_is_caster"
      }
     },
     {
      "id": "level_up_features_note",
      "type": "text",
      "text": {
       "type": "constant",
       "value": "New class features for the new level appear under Features & Feats after you confirm.",
       "value_type": "string"
      },
      "style": "caption",
      "margin_top": 8,
      "is_visible": {
       "type": "stat",
       "stat": "level_up_class_selected"
      }
     },
     {
      "id": "level_up_choices_hdr",
      "type": "text",
      "text": {
       "type": "constant",
       "value": "Your choices",
       "value_type": "string"
      },
      "style": "subhead",
      "bold": true,
      "margin_top": 14,
      "is_visible": {
       "type": "stat",
       "stat": "level_up_class_selected"
      }
     },
     {
      "id": "level_up_favored_comp",
      "type": "composite",
      "margin_top": 14,
      "is_visible": {
       "type": "stat",
       "stat": "level_up_class_selected"
      },
      "subviews": [
       {
        "id": "level_up_favored_label",
        "type": "text",
        "text": {
         "type": "constant",
         "value": "Favored class bonus: ",
         "value_type": "string"
        },
        "style": "text",
        "bold": true,
        "margin_right": 8
       },
       {
        "id": "level_up_favored_select",
        "type": "select",
        "stat": "temp_level_up_favored_choice",
        "options": "level_up_favored_options"
       }
      ]
     },
     {
      "id": "level_up_asi_comp",
      "type": "composite",
      "margin_top": 6,
      "is_visible": {
       "type": "stat",
       "stat": "level_up_is_asi_level"
      },
      "subviews": [
       {
        "id": "level_up_asi_label",
        "type": "text",
        "text": {
         "type": "constant",
         "value": "Raise ability: ",
         "value_type": "string"
        },
        "style": "text",
        "bold": true,
        "margin_right": 8
       },
       {
        "id": "level_up_asi_select",
        "type": "select",
        "stat": "temp_level_up_asi_ability",
        "options": "ability"
       }
      ]
     },
     {
      "id": "level_up_confirm_hint",
      "type": "text",
      "text": {
       "type": "constant",
       "value": "Confirm to apply this level-up. Cancel to back out — nothing changes until you confirm.",
       "value_type": "string"
      },
      "style": "caption",
      "margin_top": 14,
      "is_visible": {
       "type": "stat",
       "stat": "level_up_class_selected"
      }
     }
    ]
   },
   "on_level_up_confirm": {
    "type": "sequence",
    "effects": [
     {
      "type": "setStat",
      "stat": "currently_levelling_up",
      "new_value": {
       "type": "constant",
       "value": true,
       "value_type": "bool"
      },
      "aggregation_type": "set"
     },
     {
      "type": "when",
      "clauses": [
       {
        "condition": {
         "type": "not",
         "components": {
          "type": "stat",
          "stat": "$view.level_up_multiclass_check"
         }
        },
        "effect": {
         "type": "sequence",
         "effects": [
          {
           "type": "setStat",
           "stat": "temp_last_level_up_class_id",
           "new_value": {
            "type": "stat",
            "stat": "level_up_selected_class_progression.class.id"
           },
           "aggregation_type": "set"
          },
          {
           "type": "forEach",
           "components": {
            "type": "list",
            "components": [
             {
              "type": "stat",
              "stat": "level_up_selected_class_progression"
             }
            ]
           },
           "apply": {
            "type": "sequence",
            "effects": [
             {
              "type": "addToStat",
              "stat": "$class_progression.class_level",
              "value": {
               "type": "constant",
               "value": 1,
               "value_type": "integer"
              },
              "aggregation_type": "set"
             }
            ]
           },
           "for_each_value_key": "$class_progression"
          }
         ]
        }
       }
      ]
     },
     {
      "type": "when",
      "clauses": [
       {
        "condition": {
         "type": "stat",
         "stat": "$view.level_up_multiclass_check"
        },
        "effect": {
         "type": "forEach",
         "components": {
          "type": "list",
          "components": [
           {
            "type": "stat",
            "stat": "$view.level_up_new_class"
           }
          ]
         },
         "for_each_value_key": "$new_cp",
         "apply": {
          "type": "sequence",
          "effects": [
           {
            "type": "addToStat",
            "stat": "classes",
            "value": {
             "type": "stat",
             "stat": "$new_cp"
            },
            "aggregation_type": "set"
           },
           {
            "type": "setStat",
            "stat": "temp_last_level_up_class_id",
            "new_value": {
             "type": "stat",
             "stat": "$new_cp.class.id"
            },
            "aggregation_type": "set"
           }
          ]
         }
        }
       }
      ]
     },
     {
      "type": "setStat",
      "stat": "temp_level_up_class",
      "new_value": {
       "type": "constant",
       "value": null,
       "value_type": "string"
      },
      "aggregation_type": "set"
     },
     {
      "type": "when",
      "clauses": [
       {
        "condition": {
         "type": "stat",
         "stat": "should_show_progression_summary_popup"
        },
        "effect": {
         "type": "showPopUp",
         "pop_up_view": {
          "id": "level_up_progression_slots",
          "type": "list",
          "subviews": [
           {
            "id": "level_up_progression_slots_summary_text",
            "type": "text",
            "text": {
             "type": "stat",
             "stat": "level_up_progression_grants_summary_text"
            },
            "style": "text",
            "is_visible": {
             "type": "not",
             "components": {
              "type": "isEmpty",
              "components": {
               "type": "stat",
               "stat": "level_up_progression_grants_summary_text"
              }
             }
            }
           },
           {
            "id": "level_up_progression_slots_resource_array",
            "type": "resourceArray",
            "resource_id": "progression_grant",
            "stat": "level_up_interactive_progression_grants_in_new_level",
            "view_type": "edit",
            "allow_adds_and_removes": false
           }
          ]
         },
         "pop_up_title": {
          "type": "constant",
          "value": "Progression grants",
          "value_type": "string"
         },
         "pop_up_type": "bottomSheet",
         "dismissible": false,
         "display_cancel_button": false,
         "display_save_button": true,
         "should_persist_on_save": true,
         "in_edit_mode": true
        }
       }
      ]
     },
     {
      "type": "forEach",
      "components": {
       "type": "stat",
       "stat": "level_up_interactive_progression_grants_in_new_level"
      },
      "apply": {
       "type": "when",
       "clauses": [
        {
         "condition": {
          "type": "stat",
          "stat": "$grant.is_feat_slot"
         },
         "effect": {
          "type": "sequence",
          "effects": [
           {
            "type": "setStat",
            "stat": "$grant.slot_mode",
            "new_value": {
             "type": "stat",
             "stat": "$grant.slot_mode_effective"
            },
            "aggregation_type": "set"
           },
           {
            "type": "setStat",
            "stat": "$grant.assigned_archetype",
            "new_value": {
             "type": "stat",
             "stat": "$grant.assigned_archetype_effective"
            },
            "aggregation_type": "set"
           },
           {
            "type": "setStat",
            "stat": "$grant.assigned_feat",
            "new_value": {
             "type": "stat",
             "stat": "$grant.assigned_feat_effective"
            },
            "aggregation_type": "set"
           }
          ]
         }
        }
       ]
      },
      "for_each_value_key": "$grant"
     },
     {
      "type": "when",
      "clauses": [
       {
        "condition": {
         "type": "not",
         "components": {
          "type": "and",
          "components": {
           "type": "list",
           "components": [
            {
             "type": "isEmpty",
             "components": {
              "type": "stat",
              "stat": "level_up_language_proficiency_choices_effective"
             }
            },
            {
             "type": "isEmpty",
             "components": {
              "type": "stat",
              "stat": "level_up_skill_proficiency_choices_effective"
             }
            },
            {
             "type": "isEmpty",
             "components": {
              "type": "stat",
              "stat": "level_up_armor_proficiency_choices_effective"
             }
            },
            {
             "type": "isEmpty",
             "components": {
              "type": "stat",
              "stat": "level_up_weapon_proficiency_choices_effective"
             }
            },
            {
             "type": "isEmpty",
             "components": {
              "type": "stat",
              "stat": "level_up_lore_skill_choices"
             }
            }
           ]
          }
         }
        },
        "effect": {
         "type": "showPopUp",
         "pop_up_view": {
          "id": "level_up_select_proficiencies",
          "type": "list",
          "alignment": "start",
          "subviews": [
           {
            "id": "level_up_select_proficiencies_languages",
            "type": "resourceArray",
            "resource_id": "levelled_choice_text",
            "stat": "level_up_language_proficiency_choices_effective",
            "view_type": "display",
            "left_view": {
             "id": "level_up_select_proficiencies_languages_label",
             "type": "text",
             "text": {
              "type": "constant",
              "value": "Languages:",
