import "../macros/system_common.rpgs";

mechanic edit_skill_proficiency(event_names = "editSkillProficiency") =
  popupSelectPersist(
    select_id = "edit_skill_proficiency_select",
    meta_stat = concat([($event?.stat? ?? ""), "_proficiency"]),
    options_id = "skill_proficiency_types",
    title = $event?.statName? ?? "",
  );
