// PF1e status header section: avatar + HP + AC + Perception + Speed.
// Removed pf2e-specific stats:
//   - `base_hp` and `classes_hp_mods` (pf2e split hp model; PF1e uses
//     hp_rolled_total + CON*level + favored class + misc, all in max_hp)
//   - `class_dc` (PF1e has no universal class DC; spell DCs are per class)
// The speed bottom sheet still surfaces burrow/climb/fly/swim because those
// are real PF1e alternate movement modes (now declared in character_stats.rpgs).
character_sheet_section status() =
  section(
    id = "status_section",
    show_divider = true,
    content_item_min_width = 0.5,
    collapsible = false,
    header = [
      avatar(
        id = "avatar_view",
        margin_top = 8,
        margin_right = 8,
        margin_left = 16,
        photo_stat = "photo",
        name_stat = "name",
        size = "small",
      ),
      ticker(
        id = "status_hp",
        margin_left = 16,
        stat = "current_hp",
        style = "title",
        button_location = "right",
        button_look = "plusMinus",
        should_auto_save = true,
        change_amount = 1,
        min_value_allowed = 0,
        label = concat(["/ ", max_hp, " HP"]),
        label_alignment = "right",
        edit_bottom_sheet_title = "Hit points",
      ),
    ],
    content = [
      stat(
        id = "armor_class",
        stat = "armor_class",
        change_amount = 1,
        min_value_allowed = 0,
      ),
      stat(
        id = "perception",
        stat = "perception",
        change_amount = 1,
      ),
      stat(
        id = "speed",
        stat = "speed",
        change_amount = 5,
        min_value_allowed = 0,
        bottom_sheet_in_edit_mode = true,
        bottom_sheet_view = section(
          id = "speed_section",
          header = [],
          show_divider = false,
          content_item_min_width = 125,
          collapsible = false,
          content = [
            stat(
              id = "player_character_speed_bottom_sheet_stat",
              stat = "speed",
              change_amount = 5,
              min_value_allowed = 0,
            ),
            stat(
              id = "player_character_burrow_speed_bottom_sheet_stat",
              stat = "burrow_speed",
              change_amount = 5,
              min_value_allowed = 0,
            ),
            stat(
              id = "player_character_climb_speed_bottom_sheet_stat",
              stat = "climb_speed",
              change_amount = 5,
              min_value_allowed = 0,
            ),
            stat(
              id = "player_character_fly_speed_bottom_sheet_stat",
              stat = "fly_speed",
              change_amount = 5,
              min_value_allowed = 0,
            ),
            stat(
              id = "player_character_swim_speed_bottom_sheet_stat",
              stat = "swim_speed",
              change_amount = 5,
              min_value_allowed = 0,
            ),
          ],
        ),
        sheet_title = "Manage speeds",
      ),
    ],
  );
