// ============================================================================
// PATHFINDER 1E CHARACTER STATS
// ============================================================================
// Key differences from PF2e driving this file:
//   - Raw ability scores (3-18+); modifiers = floor((score-10)/2)
//   - BAB is per-class summed; classes have full / 3/4 / 1/2 progression
//   - 3 saves (Fort/Ref/Will); each class has "good" (2+lvl/2) or "poor" (lvl/3)
//   - AC = 10 + armor + shield + Dex (capped) + size + dodge + natural + deflection + misc
//   - Skill ranks: max per skill = char level; class skill = +3 if any rank
//   - 35 base skills; each keyed to one ability score
//   - CMB = BAB + STR mod + size; CMD = 10 + BAB + STR + DEX + size + deflection + dodge
// ============================================================================

// ---------- BASIC IDENTITY ----------

calc string created_at_display(name = "Created at display") =
  if isNull(created_at)
    then ""
    else concat(["Created ", date(created_at)]);

base photo photo(name = "Photo") = null;
base string name(name = "Name") = "";
base string alignment(name = "Alignment") = "true_neutral";
base string deity(name = "Deity") = "";
base string homeland(name = "Homeland") = "";
base string gender(name = "Gender") = "";
base integer age(name = "Age") = 0;
base string height(name = "Height") = "";
base string weight_text(name = "Weight") = "";
base string hair(name = "Hair") = "";
base string eyes(name = "Eyes") = "";
base string about(name = "About") = "";
base resource<note>[] notes(name = "Notes") = [];

// ---------- RACE & CLASSES ----------

base resource<race> race(name = "Race") = null;
// Phase 2f: live-effective race (creator $view, gotcha #13/#14, with
// committed fallback) — drives racial ability-score modifiers below.
calc resource<race> race_effective(name = "Race (effective)") =
  $view?.edit_character_race_select? ?? race;
base resource<class_progression>[] classes(name = "Classes") = [];

// B.1.5 Phase 1 — LIVE multiclass preview. All cross-class calcs read
// $c.class_level_effective / $c.class_effective (class_progression's
// $view-aware calcs: $view?.<picker>? ?? committed). On the creation
// page these reflect the in-flight class pick live; off it they fall
// back to the committed class/level — so post-commit and sheet values
// are unchanged. Eliminates the "(updates on continue)" placeholder
// (B.1.1.1 spec). Gotchas #13/#14 satisfied by class_progression's
// already-?-guarded effective calcs.
//
// B.1.5 Phase 1 FOLLOWUP (verified by emulator video 2026-05-17):
// Phase 1's per-row $view-fallback ($c.class_effective / $c.class_level_effective)
// is correct but insufficient — the OUTER iteration over `classes`
// still reads the bound stat, which is stale on-page until commit
// (gotcha #13). On the class creation page the resourceArray
// `edit_character_class_classes` doesn't push to bound `classes` live,
// so map(classes, …) iterates an empty array and every cross-class
// calc reads 0 (visible: "Total character level: 0 / BAB +0 / Fort +0").
// Fix: read $view?.edit_character_class_classes (the in-flight row
// array) when non-empty; else fall back to bound `classes`. Each
// per-row $view path resolves on the row's own class_progression view
// (validation_message in 02_class.rpgs already does this with
// $class?.$view?.class_progression_edit_class_select).
calc resource<class_progression>[] effective_classes(name = "Classes (effective)") =
  if !isEmpty(($view?.edit_character_class_classes? ?? []))
    then $view?.edit_character_class_classes? ?? []
    else classes;

calc integer level(name = "Character Level") =
  add(map(effective_classes, mapper = ($c) => $c.class_level_effective));

calc string description(name = "Description") =
  concat([
    (race?.name ?? ""),
    (if isEmpty(classes)
      then ""
      else concat([
        " ",
        joinToString(
          map(classes, mapper = ($c) => concat([
            ($c.class_effective?.name ?? ""),
            (if isEmpty($c.archetype_names_display ?? "") then ""
             else concat([" (", $c.archetype_names_display, ")"])),
            " ", $c.class_level_effective])),
          separator = " / ",
        ),
      ])),
  ]);

// ---------- SIZE ----------

base string size(name = "Size") = "medium";

calc integer size_modifier(name = "Size modifier to attack & AC") =
  when {
    size == "fine" -> 8,
    size == "diminutive" -> 4,
    size == "tiny" -> 2,
    size == "small" -> 1,
    size == "medium" -> 0,
    size == "large" -> -1,
    size == "huge" -> -2,
    size == "gargantuan" -> -4,
    size == "colossal" -> -8,
    else -> 0,
  };

calc integer size_modifier_special(name = "Size modifier to CMB/CMD") =
  when {
    size == "fine" -> -8,
    size == "diminutive" -> -4,
    size == "tiny" -> -2,
    size == "small" -> -1,
    size == "medium" -> 0,
    size == "large" -> 1,
    size == "huge" -> 2,
    size == "gargantuan" -> 4,
    size == "colossal" -> 8,
    else -> 0,
  };

calc integer size_modifier_stealth(name = "Size modifier to Stealth") =
  when {
    size == "fine" -> 16,
    size == "diminutive" -> 12,
    size == "tiny" -> 8,
    size == "small" -> 4,
    size == "medium" -> 0,
    size == "large" -> -4,
    size == "huge" -> -8,
    size == "gargantuan" -> -12,
    size == "colossal" -> -16,
    else -> 0,
  };

// ---------- ABILITY SCORES ----------

base integer strength_score_base(name = "Strength base") = 10;
base integer dexterity_score_base(name = "Dexterity base") = 10;
base integer constitution_score_base(name = "Constitution base") = 10;
base integer intelligence_score_base(name = "Intelligence base") = 10;
base integer wisdom_score_base(name = "Wisdom base") = 10;
base integer charisma_score_base(name = "Charisma base") = 10;

// Phase 2f: racial ability-score modifiers now derive from the
// selected mechanical race (was dead base-0 slots — nothing ever set
// them). Flexible "+2 to any one" races (Human/Half-Elf/Half-Orc)
// carry 0 here; that floating bonus is a separate manual choice.
calc integer strength_race_modifier(name = "STR race mod") =
  race_effective?.str_racial_mod ?? 0;
calc integer dexterity_race_modifier(name = "DEX race mod") =
  race_effective?.dex_racial_mod ?? 0;
calc integer constitution_race_modifier(name = "CON race mod") =
  race_effective?.con_racial_mod ?? 0;
calc integer intelligence_race_modifier(name = "INT race mod") =
  race_effective?.int_racial_mod ?? 0;
calc integer wisdom_race_modifier(name = "WIS race mod") =
  race_effective?.wis_racial_mod ?? 0;
calc integer charisma_race_modifier(name = "CHA race mod") =
  race_effective?.cha_racial_mod ?? 0;

calc integer ability_increase_points(name = "Ability score increases earned (1 per 4 levels)") =
  divide([level, 4], rounding_method = "down");

base integer strength_level_increase(name = "STR level-up increase") = 0;
base integer dexterity_level_increase(name = "DEX level-up increase") = 0;
base integer constitution_level_increase(name = "CON level-up increase") = 0;
base integer intelligence_level_increase(name = "INT level-up increase") = 0;
base integer wisdom_level_increase(name = "WIS level-up increase") = 0;
base integer charisma_level_increase(name = "CHA level-up increase") = 0;

base integer strength_enhancement_bonus(name = "STR enhancement bonus") = 0;
base integer dexterity_enhancement_bonus(name = "DEX enhancement bonus") = 0;
base integer constitution_enhancement_bonus(name = "CON enhancement bonus") = 0;
base integer intelligence_enhancement_bonus(name = "INT enhancement bonus") = 0;
base integer wisdom_enhancement_bonus(name = "WIS enhancement bonus") = 0;
base integer charisma_enhancement_bonus(name = "CHA enhancement bonus") = 0;

base integer strength_inherent_bonus(name = "STR inherent bonus") = 0;
base integer dexterity_inherent_bonus(name = "DEX inherent bonus") = 0;
base integer constitution_inherent_bonus(name = "CON inherent bonus") = 0;
base integer intelligence_inherent_bonus(name = "INT inherent bonus") = 0;
base integer wisdom_inherent_bonus(name = "WIS inherent bonus") = 0;
base integer charisma_inherent_bonus(name = "CHA inherent bonus") = 0;

base integer strength_misc_modifier(name = "STR misc") = 0;
base integer dexterity_misc_modifier(name = "DEX misc") = 0;
base integer constitution_misc_modifier(name = "CON misc") = 0;
base integer intelligence_misc_modifier(name = "INT misc") = 0;
base integer wisdom_misc_modifier(name = "WIS misc") = 0;
base integer charisma_misc_modifier(name = "CHA misc") = 0;

calc integer strength_score(name = "Strength", abbreviation = "STR") =
  strength_score_base + strength_race_modifier + strength_level_increase
    + strength_enhancement_bonus + strength_inherent_bonus + strength_misc_modifier;

calc integer dexterity_score(name = "Dexterity", abbreviation = "DEX") =
  dexterity_score_base + dexterity_race_modifier + dexterity_level_increase
    + dexterity_enhancement_bonus + dexterity_inherent_bonus + dexterity_misc_modifier;

calc integer constitution_score(name = "Constitution", abbreviation = "CON") =
  constitution_score_base + constitution_race_modifier + constitution_level_increase
    + constitution_enhancement_bonus + constitution_inherent_bonus + constitution_misc_modifier;

calc integer intelligence_score(name = "Intelligence", abbreviation = "INT") =
  intelligence_score_base + intelligence_race_modifier + intelligence_level_increase
    + intelligence_enhancement_bonus + intelligence_inherent_bonus + intelligence_misc_modifier;

calc integer wisdom_score(name = "Wisdom", abbreviation = "WIS") =
  wisdom_score_base + wisdom_race_modifier + wisdom_level_increase
    + wisdom_enhancement_bonus + wisdom_inherent_bonus + wisdom_misc_modifier;

calc integer charisma_score(name = "Charisma", abbreviation = "CHA") =
  charisma_score_base + charisma_race_modifier + charisma_level_increase
    + charisma_enhancement_bonus + charisma_inherent_bonus + charisma_misc_modifier;

// ---------- ABILITY SCORE GENERATION METHOD (B.0 Task 4) ----------
// Enum: ability_score_methods. Point-buy variants enforce a budget on the
// six *base* scores (pre-racial). Rolled variants populate the bases via
// the roll_ability_scores button -> mechanic. Custom = free entry.
base string ability_score_method(name = "Ability score method") = "point_buy_15";

// PF1e point-buy cost of one base score (legal range 7..18; <=7 floors at
// -4, >=18 caps at 17).
//
// B.0.5 — CRITICAL reactivity fix. These read the stepper widget's LIVE
// $view value ($view?.edit_character_ability_scores_<abbr>), NOT the bound
// *_score_base char stat. A stat() stepper behaves like select: it updates
// $view.<widgetId> live on-page but the bound stat is stale until the
// page commits. Upstream's live point-buy counter
// (5e str_point_buy_point_worth) reads $view.<stepperId> for exactly this
// reason. Reading the char stat here was why the counter was stale every
// session through B.0.4. Default 10 = the score default (0 cost).
calc integer str_point_buy_cost(name = "STR point-buy cost") = when {
  ($view?.edit_character_ability_scores_str? ?? 10) <= 7 -> -4,
  ($view?.edit_character_ability_scores_str? ?? 10) == 8 -> -2,
  ($view?.edit_character_ability_scores_str? ?? 10) == 9 -> -1,
  ($view?.edit_character_ability_scores_str? ?? 10) == 10 -> 0,
  ($view?.edit_character_ability_scores_str? ?? 10) == 11 -> 1,
  ($view?.edit_character_ability_scores_str? ?? 10) == 12 -> 2,
  ($view?.edit_character_ability_scores_str? ?? 10) == 13 -> 3,
  ($view?.edit_character_ability_scores_str? ?? 10) == 14 -> 5,
  ($view?.edit_character_ability_scores_str? ?? 10) == 15 -> 7,
  ($view?.edit_character_ability_scores_str? ?? 10) == 16 -> 10,
  ($view?.edit_character_ability_scores_str? ?? 10) == 17 -> 13,
  else -> 17,
};
calc integer dex_point_buy_cost(name = "DEX point-buy cost") = when {
  ($view?.edit_character_ability_scores_dex? ?? 10) <= 7 -> -4,
  ($view?.edit_character_ability_scores_dex? ?? 10) == 8 -> -2,
  ($view?.edit_character_ability_scores_dex? ?? 10) == 9 -> -1,
  ($view?.edit_character_ability_scores_dex? ?? 10) == 10 -> 0,
  ($view?.edit_character_ability_scores_dex? ?? 10) == 11 -> 1,
  ($view?.edit_character_ability_scores_dex? ?? 10) == 12 -> 2,
  ($view?.edit_character_ability_scores_dex? ?? 10) == 13 -> 3,
  ($view?.edit_character_ability_scores_dex? ?? 10) == 14 -> 5,
  ($view?.edit_character_ability_scores_dex? ?? 10) == 15 -> 7,
  ($view?.edit_character_ability_scores_dex? ?? 10) == 16 -> 10,
  ($view?.edit_character_ability_scores_dex? ?? 10) == 17 -> 13,
  else -> 17,
};
calc integer con_point_buy_cost(name = "CON point-buy cost") = when {
  ($view?.edit_character_ability_scores_con? ?? 10) <= 7 -> -4,
  ($view?.edit_character_ability_scores_con? ?? 10) == 8 -> -2,
  ($view?.edit_character_ability_scores_con? ?? 10) == 9 -> -1,
  ($view?.edit_character_ability_scores_con? ?? 10) == 10 -> 0,
  ($view?.edit_character_ability_scores_con? ?? 10) == 11 -> 1,
  ($view?.edit_character_ability_scores_con? ?? 10) == 12 -> 2,
  ($view?.edit_character_ability_scores_con? ?? 10) == 13 -> 3,
  ($view?.edit_character_ability_scores_con? ?? 10) == 14 -> 5,
  ($view?.edit_character_ability_scores_con? ?? 10) == 15 -> 7,
  ($view?.edit_character_ability_scores_con? ?? 10) == 16 -> 10,
  ($view?.edit_character_ability_scores_con? ?? 10) == 17 -> 13,
  else -> 17,
};
calc integer int_point_buy_cost(name = "INT point-buy cost") = when {
  ($view?.edit_character_ability_scores_int? ?? 10) <= 7 -> -4,
  ($view?.edit_character_ability_scores_int? ?? 10) == 8 -> -2,
  ($view?.edit_character_ability_scores_int? ?? 10) == 9 -> -1,
  ($view?.edit_character_ability_scores_int? ?? 10) == 10 -> 0,
  ($view?.edit_character_ability_scores_int? ?? 10) == 11 -> 1,
  ($view?.edit_character_ability_scores_int? ?? 10) == 12 -> 2,
  ($view?.edit_character_ability_scores_int? ?? 10) == 13 -> 3,
  ($view?.edit_character_ability_scores_int? ?? 10) == 14 -> 5,
  ($view?.edit_character_ability_scores_int? ?? 10) == 15 -> 7,
  ($view?.edit_character_ability_scores_int? ?? 10) == 16 -> 10,
  ($view?.edit_character_ability_scores_int? ?? 10) == 17 -> 13,
  else -> 17,
};
calc integer wis_point_buy_cost(name = "WIS point-buy cost") = when {
  ($view?.edit_character_ability_scores_wis? ?? 10) <= 7 -> -4,
  ($view?.edit_character_ability_scores_wis? ?? 10) == 8 -> -2,
  ($view?.edit_character_ability_scores_wis? ?? 10) == 9 -> -1,
  ($view?.edit_character_ability_scores_wis? ?? 10) == 10 -> 0,
  ($view?.edit_character_ability_scores_wis? ?? 10) == 11 -> 1,
  ($view?.edit_character_ability_scores_wis? ?? 10) == 12 -> 2,
  ($view?.edit_character_ability_scores_wis? ?? 10) == 13 -> 3,
  ($view?.edit_character_ability_scores_wis? ?? 10) == 14 -> 5,
  ($view?.edit_character_ability_scores_wis? ?? 10) == 15 -> 7,
  ($view?.edit_character_ability_scores_wis? ?? 10) == 16 -> 10,
  ($view?.edit_character_ability_scores_wis? ?? 10) == 17 -> 13,
  else -> 17,
};
calc integer cha_point_buy_cost(name = "CHA point-buy cost") = when {
  ($view?.edit_character_ability_scores_cha? ?? 10) <= 7 -> -4,
  ($view?.edit_character_ability_scores_cha? ?? 10) == 8 -> -2,
  ($view?.edit_character_ability_scores_cha? ?? 10) == 9 -> -1,
  ($view?.edit_character_ability_scores_cha? ?? 10) == 10 -> 0,
  ($view?.edit_character_ability_scores_cha? ?? 10) == 11 -> 1,
  ($view?.edit_character_ability_scores_cha? ?? 10) == 12 -> 2,
  ($view?.edit_character_ability_scores_cha? ?? 10) == 13 -> 3,
  ($view?.edit_character_ability_scores_cha? ?? 10) == 14 -> 5,
  ($view?.edit_character_ability_scores_cha? ?? 10) == 15 -> 7,
  ($view?.edit_character_ability_scores_cha? ?? 10) == 16 -> 10,
  ($view?.edit_character_ability_scores_cha? ?? 10) == 17 -> 13,
  else -> 17,
};

calc integer ability_point_buy_total(name = "Point-buy points spent") =
  str_point_buy_cost + dex_point_buy_cost + con_point_buy_cost
    + int_point_buy_cost + wis_point_buy_cost + cha_point_buy_cost;

calc integer ability_point_buy_budget(name = "Point-buy budget") = when {
  ability_score_method == "point_buy_15" -> 15,
  ability_score_method == "point_buy_20" -> 20,
  ability_score_method == "point_buy_25" -> 25,
  else -> 0,
};

// B.0.5: rolled methods dropped (user decision). Only Point Buy
// 15/20/25 and Custom remain. (B.0.1: calc bool must be a direct
// boolean expression, never a when{->true/else->false}.)
calc bool ability_method_is_custom(name = "Method is custom") =
  ability_score_method == "custom";

// Point buy is the inclusive default (anything that isn't custom).
calc bool ability_method_is_point_buy(name = "Method is point buy") =
  !ability_method_is_custom;

calc integer ability_points_remaining(name = "Point-buy points remaining") =
  ability_point_buy_budget - ability_point_buy_total;

// B.0.5 Task 3 -- total skill-rank budget cap. `skill_ranks_spent` reads
// the LIVE stepper $view values (same reactivity fix as point buy; see
// REACTIVITY_DIAGNOSIS.md). Budget per PF1e: each class level grants
// max(1, class skill ranks/level + INT mod); Human "Skilled" adds +1 per
// level. Favored-class +1 skill is a level-up choice not tracked at
// creation, so it is intentionally NOT added here (being slightly
// generous beats wrongly blocking a legal build).
calc integer skill_ranks_budget(name = "Skill ranks budget (total)") =
  add(map(classes, mapper = ($c) =>
    ($c.class_level_effective * max([1, (($c.class_effective?.skill_ranks_per_level ?? 2) + intelligence_modifier)]))))
  + (if (race?.id ?? "") == "human__crb_" then level else 0);

calc integer skill_ranks_spent(name = "Skill ranks spent") =
  ($view?.edit_skill_row_ranks_acrobatics? ?? 0) + ($view?.edit_skill_row_ranks_appraise? ?? 0) + ($view?.edit_skill_row_ranks_bluff? ?? 0) + ($view?.edit_skill_row_ranks_climb? ?? 0) +
  ($view?.edit_skill_row_ranks_craft? ?? 0) + ($view?.edit_skill_row_ranks_diplomacy? ?? 0) + ($view?.edit_skill_row_ranks_disable_device? ?? 0) + ($view?.edit_skill_row_ranks_disguise? ?? 0) +
  ($view?.edit_skill_row_ranks_escape_artist? ?? 0) + ($view?.edit_skill_row_ranks_fly? ?? 0) + ($view?.edit_skill_row_ranks_handle_animal? ?? 0) + ($view?.edit_skill_row_ranks_heal? ?? 0) +
  ($view?.edit_skill_row_ranks_intimidate? ?? 0) + ($view?.edit_skill_row_ranks_knowledge_arcana? ?? 0) + ($view?.edit_skill_row_ranks_knowledge_dungeoneering? ?? 0) + ($view?.edit_skill_row_ranks_knowledge_engineering? ?? 0) +
  ($view?.edit_skill_row_ranks_knowledge_geography? ?? 0) + ($view?.edit_skill_row_ranks_knowledge_history? ?? 0) + ($view?.edit_skill_row_ranks_knowledge_local? ?? 0) + ($view?.edit_skill_row_ranks_knowledge_nature? ?? 0) +
  ($view?.edit_skill_row_ranks_knowledge_nobility? ?? 0) + ($view?.edit_skill_row_ranks_knowledge_planes? ?? 0) + ($view?.edit_skill_row_ranks_knowledge_religion? ?? 0) + ($view?.edit_skill_row_ranks_linguistics? ?? 0) +
  ($view?.edit_skill_row_ranks_perception? ?? 0) + ($view?.edit_skill_row_ranks_perform? ?? 0) + ($view?.edit_skill_row_ranks_profession? ?? 0) + ($view?.edit_skill_row_ranks_ride? ?? 0) +
  ($view?.edit_skill_row_ranks_sense_motive? ?? 0) + ($view?.edit_skill_row_ranks_sleight_of_hand? ?? 0) + ($view?.edit_skill_row_ranks_spellcraft? ?? 0) + ($view?.edit_skill_row_ranks_stealth? ?? 0) +
  ($view?.edit_skill_row_ranks_survival? ?? 0) + ($view?.edit_skill_row_ranks_swim? ?? 0) + ($view?.edit_skill_row_ranks_use_magic_device? ?? 0);

calc integer skill_ranks_remaining(name = "Skill ranks remaining") =
  skill_ranks_budget - skill_ranks_spent;

// (B.0.3's temp_roll_d1..d4 scratch stats were removed in B.0.4 along
// with the dead post_edit auto-roll — see REACTIVITY_DIAGNOSIS.md
// addendum: post_edit only runs at final save, so on-page auto-roll is
// impossible; rolled methods are now manual stepper entry.)

// Inlined abilityModifier(score): divide([(score + -10), 2], rounding_method = "down")
calc integer strength_modifier(name = "STR mod") =
  divide([(strength_score + -10), 2], rounding_method = "down");
calc integer dexterity_modifier(name = "DEX mod") =
  divide([(dexterity_score + -10), 2], rounding_method = "down");
calc integer constitution_modifier(name = "CON mod") =
  divide([(constitution_score + -10), 2], rounding_method = "down");
calc integer intelligence_modifier(name = "INT mod") =
  divide([(intelligence_score + -10), 2], rounding_method = "down");
calc integer wisdom_modifier(name = "WIS mod") =
  divide([(wisdom_score + -10), 2], rounding_method = "down");
calc integer charisma_modifier(name = "CHA mod") =
  divide([(charisma_score + -10), 2], rounding_method = "down");

// ---------- HIT POINTS ----------

base integer hp_rolled_total(name = "Total HP from class HD rolls") = 0;
base integer hp_favored_class(name = "Favored class HP bonus") = 0;
base integer hp_misc(name = "Misc HP bonuses (Toughness, etc.)") = 0;
base integer current_hp(name = "Current HP") = 1;
base integer temp_hp(name = "Temporary HP") = 0;
base integer nonlethal_damage(name = "Nonlethal damage") = 0;

// B.0 Task 3 — HP method. Enum: hit_point_modes (roll / average / max).
// PF1e: 1st character level = max of that class's hit die; every level
// after = per the chosen method. "roll" has no value until the level-up
// flow stores actual rolls in hp_rolled_total, so it displays the
// average baseline until then (standard VTT behaviour).
base string hp_method(name = "HP method") = "average";

// Per-class-level HP value for the chosen method.
//   max:     full die.  average: PF1e die/2 + 1 (d8 -> 5).
//   roll:    average baseline (real rolls come from level-up).
calc integer hp_method_per_level(name = "HP per level (method)") =
  add(map(classes, mapper = ($c) => ($c.class_level_effective * (when {
    hp_method == "max" -> (when {
      ($c.class_effective?.hit_die ?? "d8") == "d4" -> 4, ($c.class_effective?.hit_die ?? "d8") == "d6" -> 6,
      ($c.class_effective?.hit_die ?? "d8") == "d8" -> 8, ($c.class_effective?.hit_die ?? "d8") == "d10" -> 10,
      ($c.class_effective?.hit_die ?? "d8") == "d12" -> 12, ($c.class_effective?.hit_die ?? "d8") == "d20" -> 20,
      else -> 8,
    }),
    else -> (when {
      ($c.class_effective?.hit_die ?? "d8") == "d4" -> 3, ($c.class_effective?.hit_die ?? "d8") == "d6" -> 4,
      ($c.class_effective?.hit_die ?? "d8") == "d8" -> 5, ($c.class_effective?.hit_die ?? "d8") == "d10" -> 6,
      ($c.class_effective?.hit_die ?? "d8") == "d12" -> 7, ($c.class_effective?.hit_die ?? "d8") == "d20" -> 11,
      else -> 5,
    }),
  }))));

// Hit die of the first class taken (the level-1 class).
calc string hp_first_class_die(name = "First class hit die") =
  findFirst(
    map(classes, mapper = ($c) => ($c.class_effective?.hit_die ?? "d8")),
    filter = ($findFirstValue) => true,
  ) ?? "d8";

// +1st-level-is-max correction: PF1e grants max hit die at character
// level 1. Bonus = (max die) - (per-level method value) for that class;
// zero when the method is already "max".
calc integer hp_first_level_bonus(name = "HP first-level max bonus") =
  if isEmpty(classes) then 0
  else if hp_method == "max" then 0
  else (when {
    hp_first_class_die == "d4" -> 1,
    hp_first_class_die == "d6" -> 2,
    hp_first_class_die == "d8" -> 3,
    hp_first_class_die == "d10" -> 4,
    hp_first_class_die == "d12" -> 5,
    hp_first_class_die == "d20" -> 9,
    else -> 3,
  });

// Deterministic class HP from method; overridden by stored rolls when
// the level-up flow has written them (hp_rolled_total > 0).
calc integer class_hp_total(name = "Class HP total") =
  if hp_rolled_total > 0
    then hp_rolled_total
    else (hp_method_per_level + hp_first_level_bonus);

calc integer max_hp(name = "Max HP") =
  class_hp_total + (constitution_modifier * level) + hp_favored_class + hp_misc;

// ---------- BASE ATTACK BONUS ----------

// Same fix as `level` above: iterate effective_classes (in-flight $view
// rows on the creation page, committed `classes` everywhere else).
calc integer base_attack_bonus(name = "Base Attack Bonus", abbreviation = "BAB") =
  add(map(effective_classes, mapper = ($c) => when {
    ($c.class_effective?.bab_progression ?? "") == "full" -> $c.class_level_effective,
    ($c.class_effective?.bab_progression ?? "") == "three_quarters" ->
      divide([($c.class_level_effective * 3), 4], rounding_method = "down"),
    ($c.class_effective?.bab_progression ?? "") == "half" ->
      divide([$c.class_level_effective, 2], rounding_method = "down"),
    else -> 0,
  }));

// ---------- SAVING THROWS ----------

calc integer fortitude_base(name = "Fort base (class sum)") =
  add(map(effective_classes, mapper = ($c) => when {
    ($c.class_effective?.fortitude_progression ?? "") == "good" ->
      2 + divide([$c.class_level_effective, 2], rounding_method = "down"),
    ($c.class_effective?.fortitude_progression ?? "") == "poor" ->
      divide([$c.class_level_effective, 3], rounding_method = "down"),
    else -> 0,
  }));

calc integer reflex_base(name = "Ref base (class sum)") =
  add(map(effective_classes, mapper = ($c) => when {
    ($c.class_effective?.reflex_progression ?? "") == "good" ->
      2 + divide([$c.class_level_effective, 2], rounding_method = "down"),
    ($c.class_effective?.reflex_progression ?? "") == "poor" ->
      divide([$c.class_level_effective, 3], rounding_method = "down"),
    else -> 0,
  }));

calc integer will_base(name = "Will base (class sum)") =
  add(map(effective_classes, mapper = ($c) => when {
    ($c.class_effective?.will_progression ?? "") == "good" ->
      2 + divide([$c.class_level_effective, 2], rounding_method = "down"),
    ($c.class_effective?.will_progression ?? "") == "poor" ->
      divide([$c.class_level_effective, 3], rounding_method = "down"),
    else -> 0,
  }));

base integer fortitude_resistance_bonus(name = "Fort resistance bonus") = 0;
base integer fortitude_morale_bonus(name = "Fort morale bonus") = 0;
base integer fortitude_misc(name = "Fort misc") = 0;
base integer reflex_resistance_bonus(name = "Ref resistance bonus") = 0;
base integer reflex_morale_bonus(name = "Ref morale bonus") = 0;
base integer reflex_misc(name = "Ref misc") = 0;
base integer will_resistance_bonus(name = "Will resistance bonus") = 0;
base integer will_morale_bonus(name = "Will morale bonus") = 0;
base integer will_misc(name = "Will misc") = 0;

calc integer fortitude(name = "Fortitude") =
  fortitude_base + constitution_modifier + fortitude_resistance_bonus
    + fortitude_morale_bonus + fortitude_misc;

calc integer reflex(name = "Reflex") =
  reflex_base + dexterity_modifier + reflex_resistance_bonus
    + reflex_morale_bonus + reflex_misc;

calc integer will(name = "Will") =
  will_base + wisdom_modifier + will_resistance_bonus
    + will_morale_bonus + will_misc;

// ---------- ARMOR CLASS ----------

base resource<armor> equipped_armor(name = "Equipped armor") = null;
base resource<armor> equipped_shield(name = "Equipped shield") = null;

calc integer armor_bonus(name = "Armor bonus") = (equipped_armor?.armor_bonus ?? 0);
calc integer shield_bonus(name = "Shield bonus") = (equipped_shield?.armor_bonus ?? 0);
calc integer max_dex_to_ac(name = "Max DEX to AC") = (equipped_armor?.max_dex_bonus ?? 99);
calc integer dex_to_ac(name = "Effective DEX to AC") =
  if dexterity_modifier > max_dex_to_ac then max_dex_to_ac else dexterity_modifier;

base integer natural_armor_bonus(name = "Natural armor bonus") = 0;
base integer deflection_bonus(name = "Deflection bonus") = 0;
base integer dodge_bonus(name = "Dodge bonus") = 0;
base integer ac_misc_bonus(name = "Misc AC bonus") = 0;

calc integer armor_class(name = "Armor Class", abbreviation = "AC") =
  10 + armor_bonus + shield_bonus + dex_to_ac + size_modifier
    + natural_armor_bonus + deflection_bonus + dodge_bonus + ac_misc_bonus;

calc integer touch_ac(name = "Touch AC") =
  10 + dex_to_ac + size_modifier + deflection_bonus + dodge_bonus + ac_misc_bonus;

calc integer flat_footed_ac(name = "Flat-Footed AC") =
  10 + armor_bonus + shield_bonus + size_modifier
    + natural_armor_bonus + deflection_bonus + ac_misc_bonus;

// ---------- CMB / CMD ----------

base integer cmb_misc(name = "CMB misc") = 0;
base integer cmd_misc(name = "CMD misc") = 0;

calc integer cmb(name = "Combat Maneuver Bonus", abbreviation = "CMB") =
  base_attack_bonus + strength_modifier + size_modifier_special + cmb_misc;

calc integer cmd(name = "Combat Maneuver Defense", abbreviation = "CMD") =
  10 + base_attack_bonus + strength_modifier + dexterity_modifier
    + size_modifier_special + deflection_bonus + dodge_bonus + cmd_misc;

// ---------- INITIATIVE / SPEED ----------

base integer initiative_misc(name = "Initiative misc") = 0;
calc integer initiative(name = "Initiative") = dexterity_modifier + initiative_misc;

calc integer base_speed(name = "Base speed (race)") = (race?.base_speed ?? 30);
base integer speed_misc(name = "Speed misc") = 0;
calc integer speed(name = "Speed") = base_speed + speed_misc;

// Alternate movement modes. All default to 0 (i.e. not natively possessed);
// the player edits these when granted by a spell, item, race, or class.
base integer burrow_speed(name = "Burrow speed") = 0;
base integer climb_speed(name = "Climb speed") = 0;
base integer fly_speed(name = "Fly speed") = 0;
base integer swim_speed(name = "Swim speed") = 0;

// ---------- CONDITIONS ----------
// PF1e canonical condition set. Booleans for binary conditions; an integer
// for negative levels (the only common stacking counter). The fear and
// fatigue ladders (shaken/frightened/panicked, fatigued/exhausted, and
// sickened/nauseated) are modeled as separate booleans rather than counters
// because PF1e doesn't actually scale them numerically — each tier is its
// own state.
base bool blinded(name = "Blinded") = false;
base bool deafened(name = "Deafened") = false;
base bool dazzled(name = "Dazzled") = false;
base bool dazed(name = "Dazed") = false;
base bool fatigued(name = "Fatigued") = false;
base bool exhausted(name = "Exhausted") = false;
base bool sickened(name = "Sickened") = false;
base bool nauseated(name = "Nauseated") = false;
base bool shaken(name = "Shaken") = false;
base bool frightened(name = "Frightened") = false;
base bool panicked(name = "Panicked") = false;
base bool prone(name = "Prone") = false;
base bool entangled(name = "Entangled") = false;
base bool grappled(name = "Grappled") = false;
base bool pinned(name = "Pinned") = false;
base bool helpless(name = "Helpless") = false;
base bool paralyzed(name = "Paralyzed") = false;
base bool stunned(name = "Stunned") = false;
base bool staggered(name = "Staggered") = false;
base bool confused(name = "Confused") = false;
base bool unconscious(name = "Unconscious") = false;
base bool dying(name = "Dying") = false;
base bool stable(name = "Stable") = false;
base bool dead(name = "Dead") = false;
base integer negative_levels(name = "Negative levels") = 0;

// ---------- DERIVED ATTACK / DAMAGE BONUSES ----------
// PF1e weapon attack rolls are: BAB + (STR or DEX for finesse) + size + a
// running "misc" bucket of typed bonuses + per-weapon enhancement +
// situational. We model the per-character portion as four calc stats; feats
// and effects layer their bonuses into the matching `_misc` bucket, never
// the calc itself.
//
//   melee_attack_bonus  = BAB + STR + size + melee_attack_misc
//   melee_damage_bonus  = STR + melee_damage_misc       (one-handed default;
//                          two-handed *1.5 and off-hand *0.5 are applied at
//                          the weapon-strike DSL layer, not here)
//   ranged_attack_bonus = BAB + DEX + size + ranged_attack_misc
//   ranged_damage_bonus = ranged_damage_misc             (most ranged
//                          weapons don't add an ability mod; composite bows
//                          and thrown weapons that do are handled per-weapon)
//
// Note: STR is the default melee ability. Weapon Finesse and similar feats
// would override to DEX at the weapon level, not here. The base `_misc`
// stats below are the integration points for typed bonus stacking.
base integer melee_attack_misc(name = "Melee attack misc") = 0;
base integer melee_damage_misc(name = "Melee damage misc") = 0;
base integer ranged_attack_misc(name = "Ranged attack misc") = 0;
base integer ranged_damage_misc(name = "Ranged damage misc") = 0;

calc integer melee_attack_bonus(name = "Melee attack bonus") =
  base_attack_bonus + strength_modifier + size_modifier + melee_attack_misc;

calc integer melee_damage_bonus(name = "Melee damage bonus") =
  strength_modifier + melee_damage_misc;

calc integer ranged_attack_bonus(name = "Ranged attack bonus") =
  base_attack_bonus + dexterity_modifier + size_modifier + ranged_attack_misc;

calc integer ranged_damage_bonus(name = "Ranged damage bonus") =
  ranged_damage_misc;

// ---------- SKILLS (35 base skills) ----------

base integer acrobatics_ranks(name = "Acrobatics ranks") = 0;
base integer acrobatics_misc(name = "Acrobatics misc") = 0;
calc integer acrobatics(name = "Acrobatics") =
  acrobatics_ranks + dexterity_modifier
    + (if (contains(haystack = class_skill_list, needle = "acrobatics") && acrobatics_ranks > 0) then 3 else 0)
    + acrobatics_misc;

base integer appraise_ranks(name = "Appraise ranks") = 0;
base integer appraise_misc(name = "Appraise misc") = 0;
calc integer appraise(name = "Appraise") =
