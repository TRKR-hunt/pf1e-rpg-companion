// Class skill list: union across all classes
calc string[] class_skill_list(name = "Class skill list") =
  flatMap(effective_classes, mapper = ($c) => ($c.class_effective?.class_skills ?? []));

// Display-name projection: turn the snake_case ids into the Title Case
// labels used everywhere else (the 04_skills.rpgs row labels are hand-
// coded to these). Without this, the "Your class skills: …" caption on
// the skills page leaks raw ids like "handle_animal,
// knowledge_dungeoneering" — visible in the emulator video 2026-05-17.
calc string[] class_skill_list_display(name = "Class skill list (display)") =
  map(class_skill_list, mapper = ($s) => when {
    $s == "acrobatics" -> "Acrobatics",
    $s == "appraise" -> "Appraise",
    $s == "bluff" -> "Bluff",
    $s == "climb" -> "Climb",
    $s == "craft" -> "Craft",
    $s == "diplomacy" -> "Diplomacy",
    $s == "disable_device" -> "Disable Device",
    $s == "disguise" -> "Disguise",
    $s == "escape_artist" -> "Escape Artist",
    $s == "fly" -> "Fly",
    $s == "handle_animal" -> "Handle Animal",
    $s == "heal" -> "Heal",
    $s == "intimidate" -> "Intimidate",
    $s == "knowledge_arcana" -> "Knowledge (Arcana)",
    $s == "knowledge_dungeoneering" -> "Knowledge (Dungeoneering)",
    $s == "knowledge_engineering" -> "Knowledge (Engineering)",
    $s == "knowledge_geography" -> "Knowledge (Geography)",
    $s == "knowledge_history" -> "Knowledge (History)",
    $s == "knowledge_local" -> "Knowledge (Local)",
    $s == "knowledge_nature" -> "Knowledge (Nature)",
    $s == "knowledge_nobility" -> "Knowledge (Nobility)",
    $s == "knowledge_planes" -> "Knowledge (Planes)",
    $s == "knowledge_religion" -> "Knowledge (Religion)",
    $s == "linguistics" -> "Linguistics",
    $s == "perception" -> "Perception",
    $s == "perform" -> "Perform",
    $s == "profession" -> "Profession",
    $s == "ride" -> "Ride",
    $s == "sense_motive" -> "Sense Motive",
    $s == "sleight_of_hand" -> "Sleight of Hand",
    $s == "spellcraft" -> "Spellcraft",
    $s == "stealth" -> "Stealth",
    $s == "survival" -> "Survival",
    $s == "swim" -> "Swim",
    $s == "use_magic_device" -> "Use Magic Device",
    else -> $s,
  });

// ---------- FEATS / SPELLS / EQUIPMENT ----------

base resource<feat>[] selected_feats(name = "Selected feats") = [];
base resource<spell>[] known_spells(name = "Known spells") = [];
base resource<spell>[] prepared_spells(name = "Prepared spells today") = [];

// B.0 Task 5 — character traits. PF1e: pick 2 at creation, by convention
// from 2 different categories. Two single slots make the distinct-category
// rule enforceable in the creator.
base resource<trait> trait_1(name = "Trait 1") = null;
base resource<trait> trait_2(name = "Trait 2") = null;
calc bool traits_share_category(name = "Traits share a category") =
  notNull(trait_1) && notNull(trait_2)
    && ((trait_1?.trait_category ?? "a") == (trait_2?.trait_category ?? "b"));

base resource<weapon>[] weapons(name = "Weapons") = [];
base resource<armor>[] armors(name = "All armor") = [];
base resource<item>[] inventory(name = "Inventory") = [];
base integer gold_pieces(name = "GP") = 0;
base integer silver_pieces(name = "SP") = 0;
base integer copper_pieces(name = "CP") = 0;
base integer platinum_pieces(name = "PP") = 0;

base integer xp(name = "Experience points") = 0;

// ---------- PF2e-INHERITED STUB STATS ----------
//
// The pf1e/ system folder was originally bootstrapped from pf2e. Across the
// resource-type stats.rpgs files there are still ~366 references to character
// stats that exist in pf2e but were never declared here (e.g. $character.spells,
// $character.spell_slots_<N>, $character.actions_remaining, pf2e proficiency
// trackers). The runtime throws `PathNotFoundException` on first deref of any
// such stat.
//
// Stubbed below with sensible PF1e-safe defaults so the runtime can load.
// The pf2e calcs that consume these will evaluate to zero/empty and silently
// no-op. Removing the pf2e calcs themselves (proper cleanup) is a bigger
// follow-up — these stubs unblock loading without changing semantics for
// features we already use.
//
// Each entry is marked PF2E-STUB; grep for that tag to find them all when
// implementing proper PF1e replacements or removing the underlying pf2e calcs.

// --- aggregates the pf2e infrastructure dereferences ---
base resource<spell>[] spells(name = "Spells (PF2E-STUB; PF1e uses known_spells / prepared_spells)") = [];
base resource<spell>[] sorted_spells(name = "Sorted spells (PF2E-STUB)") = [];
base resource<feat>[] all_feats(name = "All feats (PF2E-STUB)") = [];
base resource<feat>[] all_features(name = "All features (PF2E-STUB)") = [];
base resource<weapon>[] all_weapons(name = "All weapons (PF2E-STUB)") = [];
base resource<class_progression> primary_class_progression(name = "Primary class progression (PF2E-STUB)") = null;
base resource<feat>[] spellcasting_archetypes(name = "Spellcasting archetypes (PF2E-STUB)") = [];
base resource<feat> class_archetype(name = "Class archetype (PF2E-STUB)") = null;
base resource<item>[] equipment(name = "Equipment (PF2E-STUB; PF1e uses inventory)") = [];
base string equipped_armor_id(name = "Equipped armor id (PF2E-STUB)") = "";
base string equipped_shield_id(name = "Equipped shield id (PF2E-STUB)") = "";
base string[] selected_selectable_feature_ids(name = "Selected selectable feature ids (PF2E-STUB)") = [];

// --- pf2e ancestry/heritage/background as character refs (we use race) ---
base resource<heritage> heritage(name = "Heritage (PF2E-STUB; not used in PF1e)") = null;
base resource<feat> background(name = "Background (PF2E-STUB; not used in PF1e)") = null;
calc resource<race> ancestry(name = "Ancestry alias for race (PF2E-STUB)") = race;

// --- pf2e action economy (PF1e uses standard/move/swift not the 3-action model) ---
base integer actions_remaining(name = "Actions remaining (PF2E-STUB)") = 0;
base integer max_actions_per_turn(name = "Max actions per turn (PF2E-STUB)") = 3;
base bool reaction_available(name = "Reaction available (PF2E-STUB)") = true;
base integer max_reactions_per_round(name = "Max reactions/round (PF2E-STUB)") = 1;
base bool in_combat(name = "In combat (PF2E-STUB)") = false;

// --- pf2e level / spellcasting bonus tracking ---
base integer level_bonus(name = "Level bonus (PF2E-STUB)") = 0;
base integer focus_points(name = "Focus points (PF2E-STUB; PF1e doesn't use focus)") = 0;
base integer max_focus_points(name = "Max focus points (PF2E-STUB)") = 0;
base integer hero_points(name = "Hero points (PF2E-STUB; PF1e doesn't use hero points)") = 0;

// --- pf2e proficiency strings (PF1e uses ranks, not proficiency ranks) ---
base string acrobatics_proficiency(name = "Acrobatics proficiency (PF2E-STUB)") = "untrained";
base string spellcasting_proficiency(name = "Spellcasting proficiency (PF2E-STUB)") = "untrained";
base string arcane_spellcasting_proficiency(name = "Arcane spellcasting proficiency (PF2E-STUB)") = "untrained";
base string divine_spellcasting_proficiency(name = "Divine spellcasting proficiency (PF2E-STUB)") = "untrained";
base string occult_spellcasting_proficiency(name = "Occult spellcasting proficiency (PF2E-STUB)") = "untrained";
base string primal_spellcasting_proficiency(name = "Primal spellcasting proficiency (PF2E-STUB)") = "untrained";
base string[] weapon_proficiencies(name = "Weapon proficiencies (PF2E-STUB; PF1e tracks via class)") = [];
base string[] armor_proficiencies(name = "Armor proficiencies (PF2E-STUB; PF1e tracks via class)") = [];
base bool is_not_wearing_inproficient_armor(name = "Is not wearing inproficient armor (PF2E-STUB)") = true;

// --- pf2e condition value trackers ---
base integer clumsy_value(name = "Clumsy value (PF2E-STUB)") = 0;
base integer drained_value(name = "Drained value (PF2E-STUB)") = 0;
base integer enfeebled_value(name = "Enfeebled value (PF2E-STUB)") = 0;
base integer frightened_value(name = "Frightened value (PF2E-STUB)") = 0;
base integer sickened_value(name = "Sickened value (PF2E-STUB)") = 0;
base integer slowed_value(name = "Slowed value (PF2E-STUB)") = 0;
base integer stunned_value(name = "Stunned value (PF2E-STUB)") = 0;
base integer stupefied_value(name = "Stupefied value (PF2E-STUB)") = 0;

// --- pf2e strike/spell attack-damage bonus aggregates ---
base integer spell_attack_extra_bonus(name = "Spell attack extra bonus (PF2E-STUB)") = 0;
base integer spell_attack_typed_modifier_total(name = "Spell attack typed-mod total (PF2E-STUB)") = 0;
base integer spell_dc_extra_bonus(name = "Spell DC extra bonus (PF2E-STUB)") = 0;
base integer spell_dc_typed_modifier_total(name = "Spell DC typed-mod total (PF2E-STUB)") = 0;
base integer strike_attack_typed_modifier_total(name = "Strike attack typed-mod total (PF2E-STUB)") = 0;
base integer strike_damage_typed_modifier_total(name = "Strike damage typed-mod total (PF2E-STUB)") = 0;

// --- pf2e spell slot model (10 ranks; PF1e uses 0-9 but the calcs ref both) ---
base integer spell_slots_0(name = "Spell slots 0 (PF2E-STUB)") = 0;
base integer spell_slots_1(name = "Spell slots 1 (PF2E-STUB)") = 0;
base integer spell_slots_2(name = "Spell slots 2 (PF2E-STUB)") = 0;
base integer spell_slots_3(name = "Spell slots 3 (PF2E-STUB)") = 0;
base integer spell_slots_4(name = "Spell slots 4 (PF2E-STUB)") = 0;
base integer spell_slots_5(name = "Spell slots 5 (PF2E-STUB)") = 0;
base integer spell_slots_6(name = "Spell slots 6 (PF2E-STUB)") = 0;
base integer spell_slots_7(name = "Spell slots 7 (PF2E-STUB)") = 0;
base integer spell_slots_8(name = "Spell slots 8 (PF2E-STUB)") = 0;
base integer spell_slots_9(name = "Spell slots 9 (PF2E-STUB)") = 0;
base integer spell_slots_10(name = "Spell slots 10 (PF2E-STUB)") = 0;
base integer max_spell_slots_1_bonus(name = "Max spell slots 1 bonus (PF2E-STUB)") = 0;
base integer max_spell_slots_2_bonus(name = "Max spell slots 2 bonus (PF2E-STUB)") = 0;
base integer max_spell_slots_3_bonus(name = "Max spell slots 3 bonus (PF2E-STUB)") = 0;
base integer max_spell_slots_4_bonus(name = "Max spell slots 4 bonus (PF2E-STUB)") = 0;
base integer max_spell_slots_5_bonus(name = "Max spell slots 5 bonus (PF2E-STUB)") = 0;
base integer max_spell_slots_6_bonus(name = "Max spell slots 6 bonus (PF2E-STUB)") = 0;
base integer max_spell_slots_7_bonus(name = "Max spell slots 7 bonus (PF2E-STUB)") = 0;
base integer max_spell_slots_8_bonus(name = "Max spell slots 8 bonus (PF2E-STUB)") = 0;
base integer max_spell_slots_9_bonus(name = "Max spell slots 9 bonus (PF2E-STUB)") = 0;
base integer max_spell_slots_10_bonus(name = "Max spell slots 10 bonus (PF2E-STUB)") = 0;

// --- pf2e UI/mode state ---
base bool currently_levelling_up(name = "Currently levelling up (PF2E-STUB)") = false;
base bool daily_preparations_reselection_in_progress(name = "Daily preparations reselection in progress (PF2E-STUB)") = false;
base bool creation_feats_page_open(name = "Creation feats page open (PF2E-STUB)") = false;
base bool should_show_controls_for_choices(name = "Should show controls for choices (PF2E-STUB)") = true;
base bool spells_show_prepared_only(name = "Spells show prepared only (PF2E-STUB)") = false;
base bool spells_hide_fully_expended_prepared(name = "Spells hide fully expended prepared (PF2E-STUB)") = false;
base bool enable_optional_class_archetypes(name = "Enable optional class archetypes (PF2E-STUB)") = false;

// --- pf2e temp casting state ---
base string temp_spell_cast_rank(name = "Temp spell cast rank (PF2E-STUB)") = "";
base string temp_spell_cast_spell_id(name = "Temp spell cast spell id (PF2E-STUB)") = "";
base string temp_last_level_up_class_id(name = "Temp last level-up class id (PF2E-STUB)") = "";

// --- level-up flow (system.rpg.json's level_up_view references these) ---
// `temp_level_up_class` is the stat written by the level_up_select_class view.
// The select shows class names (display="name") drawn from $character.classes,
// and writes the selected class's display name into this base string.
base string temp_level_up_class(name = "Temp variable for level-up class select") = null;

// B.1.6 — multiclass at level-up (upstream pre-stdlib 5e pattern).
// When `temp_level_up_multiclass` is checked, the user picks a brand
// new class via the `level_up_new_class` resource<class_progression>
// widget; on_level_up_confirm appends it to `classes` (addToStat
// array append) instead of incrementing an existing class. Phase 1's
// _effective calcs then sum BAB/saves/HP/level across all classes
// automatically.
base bool temp_level_up_multiclass(name = "Level-up: multiclass instead") = false;
base resource<class_progression> temp_level_up_new_class(name = "Level-up: new multiclass class") = null;

// Picked new class (live $view of the nested class_progression edit).
calc resource<class> level_up_new_class_picked(name = "Level-up new class (picked)") =
  $view?.level_up_new_class?.$view?.class_progression_edit_class_select?;

// Alignment gate. selectResources filters are equality-on-indexed-stat
// only and cannot express PF1e's prose alignment predicates against the
// character's chosen alignment, so the picker cannot be option-filtered
// (gotcha #17). Enforced here as a blocking validation keyed off the
// picked class id + character `alignment` per the SRD-restricted list.
calc string level_up_multiclass_alignment_error(name = "Multiclass alignment error") = when {
  (level_up_new_class_picked?.id ?? "") == "paladin__crb_" && alignment != "lawful_good"
    -> "Paladin requires Lawful Good alignment.",
  (level_up_new_class_picked?.id ?? "") == "antipaladin__crb_" && alignment != "chaotic_evil"
    -> "Antipaladin requires Chaotic Evil alignment.",
  (level_up_new_class_picked?.id ?? "") == "monk__crb_"
    && alignment != "lawful_good" && alignment != "lawful_neutral" && alignment != "lawful_evil"
    -> "Monk requires a Lawful alignment.",
  (level_up_new_class_picked?.id ?? "") == "monk_unchained__crb_"
    && alignment != "lawful_good" && alignment != "lawful_neutral" && alignment != "lawful_evil"
    -> "Unchained Monk requires a Lawful alignment.",
  ((level_up_new_class_picked?.id ?? "") == "barbarian__crb_"
    || (level_up_new_class_picked?.id ?? "") == "barbarian_unchained__crb_")
    && (alignment == "lawful_good" || alignment == "lawful_neutral" || alignment == "lawful_evil")
    -> "Barbarian cannot be Lawful.",
  (level_up_new_class_picked?.id ?? "") == "druid__crb_"
    && (alignment == "lawful_good" || alignment == "lawful_neutral" || alignment == "lawful_evil"
      || alignment == "chaotic_good" || alignment == "chaotic_neutral" || alignment == "chaotic_evil")
    -> "Druid must be within one step of true neutral (no Lawful/Chaotic extremes).",
  else -> "",
};

// B.1.7 — prestige prerequisite evaluator. For the picked level-up
// new class, collect every machine-checkable prerequisite the
// character does NOT meet (bab/ability/class_level/alignment), as a
// "; "-joined list of their display strings. text-kind prereqs
// (feature/spell/narrative) are shown in the class's Lore/prereq
// list and player/GM-attested — never auto-blocked (documented).
calc bool level_up_new_class_is_prestige(name = "Picked new class is prestige") =
  level_up_new_class_picked?.is_prestige ?? false;

calc string level_up_prestige_unmet_prereqs(name = "Unmet prestige prerequisites") =
  joinToString(
    map(
      filter(
        (level_up_new_class_picked?.prerequisites ?? []),
        filter = ($p) => ($p.is_machine_checkable && (when {
          $p.kind == "bab" -> base_attack_bonus < $p.threshold,
          $p.kind == "class_level" -> level < $p.threshold,
          $p.kind == "alignment" -> alignment != $p.text_value,
          $p.kind == "ability" -> (when {
            $p.param == "strength" -> strength_score < $p.threshold,
            $p.param == "dexterity" -> dexterity_score < $p.threshold,
            $p.param == "constitution" -> constitution_score < $p.threshold,
            $p.param == "intelligence" -> intelligence_score < $p.threshold,
            $p.param == "wisdom" -> wisdom_score < $p.threshold,
            $p.param == "charisma" -> charisma_score < $p.threshold,
            else -> false,
          }),
          else -> false,
        })),
      ),
      mapper = ($p) => $p.display,
    ),
    separator = "; ",
  );

// Resolves the selected class back to its class_progression by matching
// $view?.level_up_select_class? against $character.classes[*].class.id.
calc resource<class_progression> level_up_selected_class_progression(name = "Selected existing class when levelling up") =
  findFirst(
    classes,
    filter = ($findFirstValue) => ($findFirstValue.class?.id == $view?.level_up_select_class?),
  );

// --- B.0 Task 7 — PF1e level-up walkthrough ---
// The core loop already works: on_level_up_confirm increments the chosen
// class_progression.class_level, and level / BAB / saves / max_hp (Task 3
// method) / skill-point budget all auto-recompute from class_level. These
// stats drive the richer level_up_view walkthrough and the appended
// ASI / favored-class effects in on_level_up_confirm.
base string temp_level_up_asi_ability(name = "Level-up: ability to raise (+1)") = "";
base string temp_level_up_favored_choice(name = "Level-up: favored class bonus") = "hp";

calc integer level_up_new_level(name = "Level after this level-up") = level + 1;

// PF1e: an ability score increase at character levels 4, 8, 12, 16, 20.
calc bool level_up_is_asi_level(name = "This level grants an ASI") =
  (level_up_new_level - (divide([level_up_new_level, 4], rounding_method = "down") * 4)) == 0;

// PF1e: a feat at every odd character level (1, 3, 5, ...).
calc bool level_up_is_feat_level(name = "This level grants a feat") =
  (level_up_new_level - (divide([level_up_new_level, 2], rounding_method = "down") * 2)) == 1;

calc bool level_up_class_selected(name = "A class is selected for level-up") =
  notNull(level_up_selected_class_progression);

calc string level_up_selected_class_die(name = "Selected level-up class hit die") =
  level_up_selected_class_progression?.class?.hit_die ?? "d8";

// HP for one level of the selected class under the chosen HP method
// (mirrors hp_method_per_level; roll baseline = average).
calc integer level_up_class_per_level_hp(name = "HP for this class level (method)") = when {
  hp_method == "max" -> (when {
    level_up_selected_class_die == "d4" -> 4, level_up_selected_class_die == "d6" -> 6,
    level_up_selected_class_die == "d8" -> 8, level_up_selected_class_die == "d10" -> 10,
    level_up_selected_class_die == "d12" -> 12, level_up_selected_class_die == "d20" -> 20,
    else -> 8,
  }),
  else -> (when {
    level_up_selected_class_die == "d4" -> 3, level_up_selected_class_die == "d6" -> 4,
    level_up_selected_class_die == "d8" -> 5, level_up_selected_class_die == "d10" -> 6,
    level_up_selected_class_die == "d12" -> 7, level_up_selected_class_die == "d20" -> 11,
    else -> 5,
  }),
};

// B.0.6 — PREVIEW calcs read the LIVE select $view value, per gotcha
// #13: the bound stat temp_level_up_favored_choice is stale until
// on_level_up_confirm. B.0.7 (gotcha #14): the widget-id path component
// MUST carry the trailing `?` conditional-path operator
// ($view?.level_up_favored_select?) — without it, when the favored
// widget hasn't rendered yet (1->2 level-up: no favored class chosen
// during creation) the bare path throws PathNotFoundException before
// `?? "hp"` can apply. The `?` makes the missing path resolve to null,
// then `?? "hp"` supplies the default. APPLY-side calcs
// (level_up_favored_is_hp, level_up_asi_is_*) keep reading the bound
// stat — by confirm time it is committed (device-verified working).
calc integer level_up_favored_hp_bonus(name = "Favored class +1 HP") =
  if ($view?.level_up_favored_select? ?? "hp") == "hp" then 1 else 0;
calc integer level_up_favored_skill_bonus(name = "Favored class +1 skill rank") =
  if ($view?.level_up_favored_select? ?? "hp") == "skill" then 1 else 0;

calc integer level_up_hp_gain_preview(name = "HP gained this level") =
  level_up_class_per_level_hp + constitution_modifier + level_up_favored_hp_bonus;

calc integer level_up_skill_points_preview(name = "Skill ranks gained this level") =
  max([1, ((level_up_selected_class_progression?.class?.skill_ranks_per_level ?? 2)
    + intelligence_modifier)]) + level_up_favored_skill_bonus;

calc bool level_up_is_caster(name = "Selected level-up class is a caster") =
  !isEmpty(level_up_selected_class_progression?.class?.spellcasting_ability ?? "");

// Live ASI target for the preview text (bound stat is stale in the popup).
calc string level_up_asi_display(name = "Level-up ASI target (preview)") =
  if isEmpty($view?.level_up_asi_select? ?? "") then "(none chosen)"
  else ($view?.level_up_asi_select? ?? "");

// --- B.0.6 BAB / save deltas for the preview ---
// Predicted change from the selected class's NEXT level. L = that class's
// current class_level; PF1e per-level deltas via floor arithmetic.
calc integer level_up_sel_class_level(name = "Selected class current level") =
  level_up_selected_class_progression?.class_level ?? 0;

calc integer level_up_bab_delta(name = "BAB gained this level") = when {
  (level_up_selected_class_progression?.class?.bab_progression ?? "half") == "full" -> 1,
  (level_up_selected_class_progression?.class?.bab_progression ?? "half") == "three_quarters" ->
    (divide([(3 * (level_up_sel_class_level + 1)), 4], rounding_method = "down")
      - divide([(3 * level_up_sel_class_level), 4], rounding_method = "down")),
  else ->
    (divide([(level_up_sel_class_level + 1), 2], rounding_method = "down")
      - divide([level_up_sel_class_level, 2], rounding_method = "down")),
};

calc integer level_up_fort_delta(name = "Fort base gained this level") =
  if (level_up_selected_class_progression?.class?.fortitude_progression ?? "poor") == "good"
    then (divide([(level_up_sel_class_level + 1), 2], rounding_method = "down")
      - divide([level_up_sel_class_level, 2], rounding_method = "down"))
    else (divide([(level_up_sel_class_level + 1), 3], rounding_method = "down")
      - divide([level_up_sel_class_level, 3], rounding_method = "down"));
calc integer level_up_ref_delta(name = "Ref base gained this level") =
  if (level_up_selected_class_progression?.class?.reflex_progression ?? "poor") == "good"
    then (divide([(level_up_sel_class_level + 1), 2], rounding_method = "down")
      - divide([level_up_sel_class_level, 2], rounding_method = "down"))
    else (divide([(level_up_sel_class_level + 1), 3], rounding_method = "down")
      - divide([level_up_sel_class_level, 3], rounding_method = "down"));
calc integer level_up_will_delta(name = "Will base gained this level") =
  if (level_up_selected_class_progression?.class?.will_progression ?? "poor") == "good"
    then (divide([(level_up_sel_class_level + 1), 2], rounding_method = "down")
      - divide([level_up_sel_class_level, 2], rounding_method = "down"))
    else (divide([(level_up_sel_class_level + 1), 3], rounding_method = "down")
      - divide([level_up_sel_class_level, 3], rounding_method = "down"));

calc string level_up_selected_class_name(name = "Selected level-up class name") =
  level_up_selected_class_progression?.class?.name ?? "(choose a class)";

calc integer level_up_new_bab(name = "BAB after level-up") = base_attack_bonus + level_up_bab_delta;
calc integer level_up_new_fort(name = "Fort base after level-up") = fortitude_base + level_up_fort_delta;
calc integer level_up_new_ref(name = "Ref base after level-up") = reflex_base + level_up_ref_delta;
calc integer level_up_new_will(name = "Will base after level-up") = will_base + level_up_will_delta;

// Single-stat condition flags so on_level_up_confirm (JSON) only needs the
// proven {"type":"stat"} when-condition shape (no inline equality nodes).
calc bool level_up_asi_is_str(name = "ASI -> STR") = temp_level_up_asi_ability == "strength";
calc bool level_up_asi_is_dex(name = "ASI -> DEX") = temp_level_up_asi_ability == "dexterity";
calc bool level_up_asi_is_con(name = "ASI -> CON") = temp_level_up_asi_ability == "constitution";
calc bool level_up_asi_is_int(name = "ASI -> INT") = temp_level_up_asi_ability == "intelligence";
calc bool level_up_asi_is_wis(name = "ASI -> WIS") = temp_level_up_asi_ability == "wisdom";
calc bool level_up_asi_is_cha(name = "ASI -> CHA") = temp_level_up_asi_ability == "charisma";
calc bool level_up_favored_is_hp(name = "Favored -> HP") = temp_level_up_favored_choice == "hp";

// --- level-up flow PF2E-STUBS: stats system.rpg.json references but PF1e
// doesn't yet implement (ASI = pf2e Ability Score Increase mechanic; skill
// increases = pf2e mechanic; interactive progression grants = pf2e). All
// stubbed to safe defaults so the level-up view materialises without
// PathNotFoundException. Re-implement as the PF1e level-up flow comes online.
base string temp_asi_selection_1(name = "Temp ASI selection 1 (PF2E-STUB)") = null;
