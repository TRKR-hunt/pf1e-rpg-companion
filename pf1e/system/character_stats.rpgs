// Class skill list: union across all classes
calc string[] class_skill_list(name = "Class skill list") =
  flatMap(classes, mapper = ($c) => ($c.class.class_skills ?? []));

// ---------- FEATS / SPELLS / EQUIPMENT ----------

base resource<feat>[] selected_feats(name = "Selected feats") = [];
base resource<spell>[] known_spells(name = "Known spells") = [];
base resource<spell>[] prepared_spells(name = "Prepared spells today") = [];

// B.0 Task 5 — character traits. PF1e: pick 2 at creation, by convention
// from 2 different categories. Two single slots make the distinct-category
// rule enforceable in the creator.
base resource<trait> trait_1(name = "Trait 1") = null;
base resource<trait> trait_2(name = "Trait 2") = null;
calc bool traits_share_category(name = "Traits share a category") =
  notNull(trait_1) && notNull(trait_2)
    && ((trait_1?.trait_category ?? "a") == (trait_2?.trait_category ?? "b"));

base resource<weapon>[] weapons(name = "Weapons") = [];
base resource<armor>[] armors(name = "All armor") = [];
base resource<item>[] inventory(name = "Inventory") = [];
base integer gold_pieces(name = "GP") = 0;
base integer silver_pieces(name = "SP") = 0;
base integer copper_pieces(name = "CP") = 0;
base integer platinum_pieces(name = "PP") = 0;

base integer xp(name = "Experience points") = 0;

// ---------- PF2e-INHERITED STUB STATS ----------
//
// The pf1e/ system folder was originally bootstrapped from pf2e. Across the
// resource-type stats.rpgs files there are still ~366 references to character
// stats that exist in pf2e but were never declared here (e.g. $character.spells,
// $character.spell_slots_<N>, $character.actions_remaining, pf2e proficiency
// trackers). The runtime throws `PathNotFoundException` on first deref of any
// such stat.
//
// Stubbed below with sensible PF1e-safe defaults so the runtime can load.
// The pf2e calcs that consume these will evaluate to zero/empty and silently
// no-op. Removing the pf2e calcs themselves (proper cleanup) is a bigger
// follow-up — these stubs unblock loading without changing semantics for
// features we already use.
//
// Each entry is marked PF2E-STUB; grep for that tag to find them all when
// implementing proper PF1e replacements or removing the underlying pf2e calcs.

// --- aggregates the pf2e infrastructure dereferences ---
base resource<spell>[] spells(name = "Spells (PF2E-STUB; PF1e uses known_spells / prepared_spells)") = [];
base resource<spell>[] sorted_spells(name = "Sorted spells (PF2E-STUB)") = [];
base resource<feat>[] all_feats(name = "All feats (PF2E-STUB)") = [];
base resource<feat>[] all_features(name = "All features (PF2E-STUB)") = [];
base resource<weapon>[] all_weapons(name = "All weapons (PF2E-STUB)") = [];
base resource<class_progression> primary_class_progression(name = "Primary class progression (PF2E-STUB)") = null;
base resource<feat>[] spellcasting_archetypes(name = "Spellcasting archetypes (PF2E-STUB)") = [];
base resource<feat> class_archetype(name = "Class archetype (PF2E-STUB)") = null;
base resource<item>[] equipment(name = "Equipment (PF2E-STUB; PF1e uses inventory)") = [];
base string equipped_armor_id(name = "Equipped armor id (PF2E-STUB)") = "";
base string equipped_shield_id(name = "Equipped shield id (PF2E-STUB)") = "";
base string[] selected_selectable_feature_ids(name = "Selected selectable feature ids (PF2E-STUB)") = [];

// --- pf2e ancestry/heritage/background as character refs (we use race) ---
base resource<heritage> heritage(name = "Heritage (PF2E-STUB; not used in PF1e)") = null;
base resource<feat> background(name = "Background (PF2E-STUB; not used in PF1e)") = null;
calc resource<race> ancestry(name = "Ancestry alias for race (PF2E-STUB)") = race;

// --- pf2e action economy (PF1e uses standard/move/swift not the 3-action model) ---
base integer actions_remaining(name = "Actions remaining (PF2E-STUB)") = 0;
base integer max_actions_per_turn(name = "Max actions per turn (PF2E-STUB)") = 3;
base bool reaction_available(name = "Reaction available (PF2E-STUB)") = true;
base integer max_reactions_per_round(name = "Max reactions/round (PF2E-STUB)") = 1;
base bool in_combat(name = "In combat (PF2E-STUB)") = false;

// --- pf2e level / spellcasting bonus tracking ---
base integer level_bonus(name = "Level bonus (PF2E-STUB)") = 0;
base integer focus_points(name = "Focus points (PF2E-STUB; PF1e doesn't use focus)") = 0;
base integer max_focus_points(name = "Max focus points (PF2E-STUB)") = 0;
base integer hero_points(name = "Hero points (PF2E-STUB; PF1e doesn't use hero points)") = 0;

// --- pf2e proficiency strings (PF1e uses ranks, not proficiency ranks) ---
base string acrobatics_proficiency(name = "Acrobatics proficiency (PF2E-STUB)") = "untrained";
base string spellcasting_proficiency(name = "Spellcasting proficiency (PF2E-STUB)") = "untrained";
