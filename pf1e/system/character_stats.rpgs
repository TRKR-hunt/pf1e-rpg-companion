calc integer creator_preview_dexterity_modifier(name = "Creator preview DEX mod (PF2E-STUB)") = dexterity_modifier;
calc integer creator_preview_constitution_modifier(name = "Creator preview CON mod (PF2E-STUB)") = constitution_modifier;
calc integer creator_preview_intelligence_modifier(name = "Creator preview INT mod (PF2E-STUB)") = intelligence_modifier;
calc integer creator_preview_wisdom_modifier(name = "Creator preview WIS mod (PF2E-STUB)") = wisdom_modifier;
calc integer creator_preview_charisma_modifier(name = "Creator preview CHA mod (PF2E-STUB)") = charisma_modifier;
