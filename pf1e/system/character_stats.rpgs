// --- level-up flow (system.rpg.json's level_up_view references these) ---
// `temp_level_up_class` is the stat written by the level_up_select_class view.
// The select shows class names (display="name") drawn from $character.classes,
// and writes the selected class's display name into this base string.
base string temp_level_up_class(name = "Temp variable for level-up class select") = null;

// Resolves the selected class back to its class_progression by matching
// $view.level_up_select_class? against $character.classes[*].class.id.
calc resource<class_progression> level_up_selected_class_progression(name = "Selected existing class when levelling up") =
  findFirst(
    classes,
    filter = ($findFirstValue) => ($findFirstValue.class?.id == $view.level_up_select_class?),
  );

// --- B.0 Task 7 — PF1e level-up walkthrough ---
// The core loop already works: on_level_up_confirm increments the chosen
// class_progression.class_level, and level / BAB / saves / max_hp (Task 3
// method) / skill-point budget all auto-recompute from class_level. These
// stats drive the richer level_up_view walkthrough and the appended
// ASI / favored-class effects in on_level_up_confirm.
base string temp_level_up_asi_ability(name = "Level-up: ability to raise (+1)") = "";
base string temp_level_up_favored_choice(name = "Level-up: favored class bonus") = "hp";

calc integer level_up_new_level(name = "Level after this level-up") = level + 1;

// PF1e: an ability score increase at character levels 4, 8, 12, 16, 20.
calc bool level_up_is_asi_level(name = "This level grants an ASI") =
  (level_up_new_level - (divide([level_up_new_level, 4], rounding_method = "down") * 4)) == 0;

// PF1e: a feat at every odd character level (1, 3, 5, ...).
calc bool level_up_is_feat_level(name = "This level grants a feat") =
  (level_up_new_level - (divide([level_up_new_level, 2], rounding_method = "down") * 2)) == 1;

calc bool level_up_class_selected(name = "A class is selected for level-up") =
  notNull(level_up_selected_class_progression);

calc string level_up_selected_class_die(name = "Selected level-up class hit die") =
  level_up_selected_class_progression?.class?.hit_die ?? "d8";

// HP for one level of the selected class under the chosen HP method
// (mirrors hp_method_per_level; roll baseline = average).
calc integer level_up_class_per_level_hp(name = "HP for this class level (method)") = when {
  hp_method == "max" -> (when {
    level_up_selected_class_die == "d4" -> 4, level_up_selected_class_die == "d6" -> 6,
    level_up_selected_class_die == "d8" -> 8, level_up_selected_class_die == "d10" -> 10,
    level_up_selected_class_die == "d12" -> 12, level_up_selected_class_die == "d20" -> 20,
    else -> 8,
  }),
  else -> (when {
    level_up_selected_class_die == "d4" -> 3, level_up_selected_class_die == "d6" -> 4,
    level_up_selected_class_die == "d8" -> 5, level_up_selected_class_die == "d10" -> 6,
    level_up_selected_class_die == "d12" -> 7, level_up_selected_class_die == "d20" -> 11,
    else -> 5,
  }),
};

calc integer level_up_favored_hp_bonus(name = "Favored class +1 HP") =
  if temp_level_up_favored_choice == "hp" then 1 else 0;
calc integer level_up_favored_skill_bonus(name = "Favored class +1 skill rank") =
  if temp_level_up_favored_choice == "skill" then 1 else 0;

calc integer level_up_hp_gain_preview(name = "HP gained this level") =
  level_up_class_per_level_hp + constitution_modifier + level_up_favored_hp_bonus;

calc integer level_up_skill_points_preview(name = "Skill ranks gained this level") =
  max([1, ((level_up_selected_class_progression?.class?.skill_ranks_per_level ?? 2)
    + intelligence_modifier)]) + level_up_favored_skill_bonus;

calc bool level_up_is_caster(name = "Selected level-up class is a caster") =
  !isEmpty(level_up_selected_class_progression?.class?.spellcasting_ability ?? "");

// Single-stat condition flags so on_level_up_confirm (JSON) only needs the
// proven {"type":"stat"} when-condition shape (no inline equality nodes).
calc bool level_up_asi_is_str(name = "ASI -> STR") = temp_level_up_asi_ability == "strength";
calc bool level_up_asi_is_dex(name = "ASI -> DEX") = temp_level_up_asi_ability == "dexterity";
calc bool level_up_asi_is_con(name = "ASI -> CON") = temp_level_up_asi_ability == "constitution";
calc bool level_up_asi_is_int(name = "ASI -> INT") = temp_level_up_asi_ability == "intelligence";
calc bool level_up_asi_is_wis(name = "ASI -> WIS") = temp_level_up_asi_ability == "wisdom";
calc bool level_up_asi_is_cha(name = "ASI -> CHA") = temp_level_up_asi_ability == "charisma";
calc bool level_up_favored_is_hp(name = "Favored -> HP") = temp_level_up_favored_choice == "hp";

// --- level-up flow PF2E-STUBS: stats system.rpg.json references but PF1e
// doesn't yet implement (ASI = pf2e Ability Score Increase mechanic; skill
// increases = pf2e mechanic; interactive progression grants = pf2e). All
// stubbed to safe defaults so the level-up view materialises without
// PathNotFoundException. Re-implement as the PF1e level-up flow comes online.
base string temp_asi_selection_1(name = "Temp ASI selection 1 (PF2E-STUB)") = null;
base string temp_asi_selection_2(name = "Temp ASI selection 2 (PF2E-STUB)") = null;
base string temp_asi_selection_3(name = "Temp ASI selection 3 (PF2E-STUB)") = null;
base string temp_asi_selection_4(name = "Temp ASI selection 4 (PF2E-STUB)") = null;
base string temp_skill_increase_skill(name = "Temp skill increase skill (PF2E-STUB)") = "";
calc string[] temp_skill_increase_skill_options(name = "Temp skill increase skill options (PF2E-STUB)") = [];
calc string temp_skill_increase_summary_text(name = "Temp skill increase summary text (PF2E-STUB)") = "";
calc string temp_skill_increase_validation_message(name = "Temp skill increase validation message (PF2E-STUB)") = "";
calc string asi_selection_help_text(name = "ASI selection help text (PF2E-STUB)") = "";
calc string level_up_progression_grants_summary_text(name = "Level-up progression grants summary (PF2E-STUB)") = "";
calc bool should_show_asi(name = "Should show ASI (PF2E-STUB)") = false;
calc bool should_show_asi_selection_2(name = "Should show ASI selection 2 (PF2E-STUB)") = false;
calc bool should_show_asi_selection_3(name = "Should show ASI selection 3 (PF2E-STUB)") = false;
calc bool should_show_asi_selection_4(name = "Should show ASI selection 4 (PF2E-STUB)") = false;
calc bool should_show_skill_increase(name = "Should show skill increase popup (PF2E-STUB)") = false;
calc bool should_show_progression_summary_popup(name = "Should show progression summary popup (PF2E-STUB)") = false;
calc resource<feat>[] features_with_new_descriptions_in_new_level(name = "Features with new descriptions in new level (PF2E-STUB)") = [];
calc resource<feat>[] selectable_features_with_pending_choices(name = "Selectable features with pending choices (PF2E-STUB)") = [];
calc resource<levelled_armor_proficiency>[] level_up_armor_proficiency_choices_effective(name = "Level-up armor prof choices effective (PF2E-STUB)") = [];
calc resource<levelled_weapon_proficiency>[] level_up_weapon_proficiency_choices_effective(name = "Level-up weapon prof choices effective (PF2E-STUB)") = [];
calc resource<levelled_skill_proficiency>[] level_up_skill_proficiency_choices_effective(name = "Level-up skill prof choices effective (PF2E-STUB)") = [];
calc resource<progression_grant>[] level_up_interactive_progression_grants_in_new_level(name = "Level-up interactive progression grants (PF2E-STUB)") = [];
// `level_up_language_proficiency_choices_effective` and `level_up_lore_skill_choices`
// reference resource types (levelled_choice_text, lore_skill) we do not declare;
// stubbing as string[] keeps the runtime materialiser happy without having to
// invent those resource types. The level-up popup just won't show them.
calc string[] level_up_language_proficiency_choices_effective(name = "Level-up language prof choices effective (PF2E-STUB)") = [];
calc string[] level_up_lore_skill_choices(name = "Level-up lore skill choices (PF2E-STUB)") = [];

// --- character-creator framework stubs ---
//
// The app framework's Save handler iterates creation pages in REVERSE during
// save, reading `creator_ability_score_increases` (and siblings) on each
// page to track "abilities before/after post_edit". When these stats are
// undeclared, the read fails silently and the iteration HALTS at the page
// that triggered post_edit — never completing, never firing dismiss.
//
// Diagnosed via side-by-side 5e (works) vs PF1e (doesn't) logcat capture.
// 5e logs `[EditCharacter] post_edit start page=3 → 2 → 1 → 0` (full
// reverse iteration). Ours logs only `[EditCharacter] post_edit start
// page=6` and stops. Adding these stubs lets the framework's iteration
// proceed to completion → dismiss fires.
//
// All empty / null — PF1e doesn't use pf2e's creator-flow ability-boost
// model. These stats exist solely so the framework can read them during
// save iteration without erroring.
calc resource<ability_score_increase>[] creator_ability_score_increases(name = "Creator ability score increases (PF2E-STUB)") = [];
base resource<ability_score_increase>[] old_creator_ability_score_increases(name = "Old creator ability score increases (PF2E-STUB)") = [];
calc resource<race> creator_selected_ancestry(name = "Selected creator ancestry (PF2E-STUB)") = race;
calc resource<heritage> creator_selected_heritage(name = "Selected creator heritage (PF2E-STUB)") = null;
calc resource<feat> creator_selected_background(name = "Selected creator background (PF2E-STUB)") = null;
calc resource<class_progression>[] creator_selected_classes(name = "Selected creator classes (PF2E-STUB)") = classes;
// Choice arrays — framework may read these for the save's per-page validation.
calc string[] creator_language_proficiency_choices(name = "Creator language prof choices (PF2E-STUB)") = [];
calc resource<levelled_skill_proficiency>[] creator_skill_proficiency_choices(name = "Creator skill prof choices (PF2E-STUB)") = [];
base string[] creator_additional_class_skill_choices(name = "Creator additional class skill choices (PF2E-STUB)") = [];
calc string[] creator_selected_skill_choices(name = "Creator selected skill choices (PF2E-STUB)") = [];
calc integer creator_additional_class_skill_choices_required(name = "Creator additional class skill choices required (PF2E-STUB)") = 0;
calc string[] creator_additional_class_skill_choices_allowed_options(name = "Creator additional class skill choices allowed options (PF2E-STUB)") = [];
calc string creator_additional_class_skill_choices_help_text(name = "Creator additional class skill choices help text (PF2E-STUB)") = "";
calc resource<levelled_armor_proficiency>[] creator_armor_proficiency_choices(name = "Creator armor prof choices (PF2E-STUB)") = [];
calc resource<levelled_weapon_proficiency>[] creator_weapon_proficiency_choices(name = "Creator weapon prof choices (PF2E-STUB)") = [];
calc string[] creator_lore_skill_choices(name = "Creator lore skill choices (PF2E-STUB)") = [];
// `creator_starting_*_choices` reference resource types we don't declare
// (selectable_items / selectable_armors / selectable_weapons). String[] is
// a safe fallback — these stubs never produce non-empty content.
calc string[] creator_starting_equipment_choices(name = "Creator starting equipment choices (PF2E-STUB)") = [];
calc string[] creator_starting_armor_choices(name = "Creator starting armor choices (PF2E-STUB)") = [];
calc string[] creator_starting_weapon_choices(name = "Creator starting weapon choices (PF2E-STUB)") = [];
// `creator_preview_*` integer stats. Framework may inspect these to show
// "your ability scores after creation" hints. All return same value as the
// current ability scores (no creator-flow boosts in PF1e).
calc integer creator_preview_strength_score(name = "Creator preview STR (PF2E-STUB)") = strength_score;
calc integer creator_preview_dexterity_score(name = "Creator preview DEX (PF2E-STUB)") = dexterity_score;
calc integer creator_preview_constitution_score(name = "Creator preview CON (PF2E-STUB)") = constitution_score;
calc integer creator_preview_intelligence_score(name = "Creator preview INT (PF2E-STUB)") = intelligence_score;
calc integer creator_preview_wisdom_score(name = "Creator preview WIS (PF2E-STUB)") = wisdom_score;
calc integer creator_preview_charisma_score(name = "Creator preview CHA (PF2E-STUB)") = charisma_score;
calc integer creator_preview_strength_modifier(name = "Creator preview STR mod (PF2E-STUB)") = strength_modifier;
calc integer creator_preview_dexterity_modifier(name = "Creator preview DEX mod (PF2E-STUB)") = dexterity_modifier;
calc integer creator_preview_constitution_modifier(name = "Creator preview CON mod (PF2E-STUB)") = constitution_modifier;
calc integer creator_preview_intelligence_modifier(name = "Creator preview INT mod (PF2E-STUB)") = intelligence_modifier;
calc integer creator_preview_wisdom_modifier(name = "Creator preview WIS mod (PF2E-STUB)") = wisdom_modifier;
calc integer creator_preview_charisma_modifier(name = "Creator preview CHA mod (PF2E-STUB)") = charisma_modifier;
calc integer creator_preview_strength_total_boosts(name = "Creator preview STR boosts (PF2E-STUB)") = 0;
calc integer creator_preview_dexterity_total_boosts(name = "Creator preview DEX boosts (PF2E-STUB)") = 0;
calc integer creator_preview_constitution_total_boosts(name = "Creator preview CON boosts (PF2E-STUB)") = 0;
calc integer creator_preview_intelligence_total_boosts(name = "Creator preview INT boosts (PF2E-STUB)") = 0;
calc integer creator_preview_wisdom_total_boosts(name = "Creator preview WIS boosts (PF2E-STUB)") = 0;
calc integer creator_preview_charisma_total_boosts(name = "Creator preview CHA boosts (PF2E-STUB)") = 0;
