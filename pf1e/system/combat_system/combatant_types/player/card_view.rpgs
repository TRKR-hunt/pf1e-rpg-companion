view player_card() =
  list(
    padding = 4,
    subviews = [
      composite(
        id = "player_combat_card_status",
        subviews = [
          avatar(
            id = "avatar_view",
            margin_top = 8,
            margin_right = 8,
            margin_left = 8,
            name_stat = "name",
            size = "small",
          ),
          text(
            id = "player_status_name",
            text = name,
            style = "subhead",
          ),
        ]
      ),
      composite(
        id = "player_display_ac_pp_speed",
        subviews = [
          text(
            id = "player_display_ac_label",
            text = "AC: ",
            style = "subhead",
            bold = true,
            margin_left = 8,
          ),
          text(
            id = "player_display_ac",
            text = armor_class,
            style = "text",
            margin_right = 12,
          ),
          text(
            id = "player_display_pp_label",
            text = "PER: ",
            style = "subhead",
            bold = true,
          ),
          text(
            id = "player_display_pp",
            text = perception,
            style = "text",
            margin_right = 12,
          ),
          text(
            id = "player_display_level_label",
            text = "Lvl: ",
            style = "subhead",
            bold = true,
            is_visible = !defined(stat = "$combatants"),
          ),
          text(
            id = "player_display_level",
            text = level,
            style = "text",
            margin_right = 12,
            is_visible = !defined(stat = "$combatants"),
          ),
          text(
            id = "player_display_ini_label",
            text = "Ini.: ",
            style = "subhead",
            bold = true,
          ),
          text(
            id = "player_display_ini",
            text = initiative,
            style = "text",
          ),
        ],
      ),
    ]
  );
