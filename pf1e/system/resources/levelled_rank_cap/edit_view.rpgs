view levelled_rank_cap_edit() =
  composite(
    id = "levelled_rank_cap_edit",
    subviews = [
      text(
        id = "levelled_rank_cap_edit_level",
        edit_stat = "level",
        hint = "Lvl",
        style = "text",
        max_length = 3,
      ),
      select(
        id = "levelled_rank_cap_edit_proficiency",
        stat = "proficiency",
        options = "skill_proficiency_types",
      ),
    ],
  );
