view heritage_display() =
  list(
    id = "heritage_display",
    padding = 16,
    alignment = "start",
    subviews = [
      composite(
        id = "heritage_display_source_and_type",
        margin_left = 16,
        subviews = [
          text(
            id = "heritage_display_source",
            style = "caption",
            resource_id = "source",
            resource_instance_ids_stat = "source",
            resource_display_stat = "abbreviation",
            is_visible = !isEmpty(source),
          ),
          text(
            id = "heritage_display_separator",
            text = " | ",
            style = "caption",
            is_visible = !isEmpty(source),
          ),
          text(
            id = "heritage_display_kind",
            text = if is_versatile then "Versatile" else "Ancestry Heritage",
            style = "caption",
          ),
        ],
      ),
      text(
        id = "heritage_display_description",
        text = description,
        style = "text",
        markdown = true,
        is_visible = !isEmpty(description),
      ),
      composite(
        id = "heritage_display_allowed_ancestries",
        margin_top = 6,
        subviews = [
          text(
            id = "heritage_display_allowed_ancestries_label",
            text = "Allowed races: ",
            style = "caption",
            bold = true,
          ),
          text(
            id = "heritage_display_allowed_ancestries_value",
            resource_id = "race",
            resource_instance_ids_stat = "allowed_ancestries",
            resource_display_stat = "name",
            style = "caption",
          ),
        ],
        is_visible = !is_versatile,
      ),
      resourceArray(
        id = "heritage_display_ability_score_increases",
        resource_id = "ability_score_increase",
        stat = "ability_score_increases",
        view_type = "display",
        left_view = text(
          id = "heritage_display_ability_boosts_label",
          text = "Ability boosts: ",
          style = "text",
          bold = true,
        ),
        is_visible = !isEmpty(ability_score_increases),
      ),
      composite(
        id = "heritage_display_hit_points_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "heritage_display_hit_points_label",
            text = "Hit points: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "heritage_display_hit_points",
            text = hit_points,
            style = "text",
          ),
        ],
        is_visible = !same_hit_points_as_parent,
      ),
      composite(
        id = "heritage_display_armor_class_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "heritage_display_armor_class_label",
            text = "Armor class: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "heritage_display_armor_class_value",
            text = display_armor_class,
            style = "text",
          ),
        ],
        is_visible = !same_ac_as_parent,
      ),
      composite(
        id = "heritage_display_speeds",
        subviews = [
          text(
            id = "heritage_display_speeds_label",
            text = "Speeds: ",
            style = "text",
            bold = true,
          ),
          text(id = "heritage_display_speeds_text", text = display_speeds, style = "text"),
        ],
      ),
      collapsible(
        id = "heritage_display_traits_collapsible",
        title = "Traits",
        start_expanded = false,
        is_visible = !isEmpty(traits),
        subviews = [
          resourceSection(
            id = "heritage_display_traits",
            resource_stat = "traits",
            resource_id = "feat",
            content_item_min_width = 1,
            read_only = true,
          ),
        ],
      ),
      composite(
        id = "heritage_display_weapon",
        margin_top = 8,
        subviews = [
          text(
            id = "heritage_display_weapon_label",
            text = "Weapon: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "heritage_display_weapon_text",
            text = display_unarmed_strike,
            style = "text",
          ),
        ],
      ),
      collapsible(
        id = "heritage_display_spells_collapsible",
        title = "Spells (per lvl)",
        start_expanded = false,
        subviews = [
          resourceSection(
            id = "heritage_display_spells",
            resource_stat = "spells",
            resource_id = "levelled_spell",
            content_item_min_width = 1,
            read_only = true,
          ),
        ],
        is_visible = !isEmpty(spells),
      ),
      collapsible(
        id = "heritage_display_languages_collapsible",
        title = "Languages (per lvl)",
        start_expanded = false,
        subviews = [
          resourceArray(
            id = "heritage_display_languages",
            resource_id = "levelled_choice_text",
            stat = "language_proficiencies",
            view_type = "display",
          ),
        ],
        is_visible = !isEmpty(language_proficiencies),
      ),
      collapsible(
        id = "heritage_display_skills_collapsible",
        title = "Skill proficiencies (per lvl)",
        start_expanded = false,
        subviews = [
          resourceArray(
            id = "heritage_display_skills",
            resource_id = "levelled_skill_proficiency",
            stat = "skill_proficiencies",
            view_type = "display",
          ),
        ],
        is_visible = !isEmpty(skill_proficiencies),
      ),
      collapsible(
        id = "heritage_display_armor_proficiencies_collapsible",
        title = "Armor proficiencies (per lvl)",
        start_expanded = false,
        subviews = [
          resourceArray(
            id = "heritage_display_armor_proficiencies",
            resource_id = "levelled_armor_proficiency",
            stat = "armor_proficiencies",
            view_type = "display",
          ),
        ],
        is_visible = !isEmpty(armor_proficiencies),
      ),
      collapsible(
        id = "heritage_display_weapon_proficiencies_collapsible",
        title = "Weapon proficiencies (per lvl)",
        start_expanded = false,
        subviews = [
          resourceArray(
            id = "heritage_display_weapon_proficiencies",
            resource_id = "levelled_weapon_proficiency",
            stat = "weapon_proficiencies",
            view_type = "display",
          ),
        ],
        is_visible = !isEmpty(weapon_proficiencies),
      ),
      collapsible(
        id = "heritage_display_lore_skills_collapsible",
        title = "Lore skills (per lvl)",
        start_expanded = false,
        subviews = [
          resourceArray(
            id = "heritage_display_lore_skills",
            resource_id = "lore_skill",
            stat = "lore_skills",
            view_type = "display",
          ),
        ],
        is_visible = !isEmpty(lore_skills),
      ),
    ],
  );
