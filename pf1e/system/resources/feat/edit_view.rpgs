view feat_edit() =
  list(
    id = "feat_edit",
    padding = 16,
    subviews = [
      text(
        id = "feat_edit_name",
        edit_stat = "name",
        style = "text",
        label = "Name",
        max_length = 140,
        validation_message = if isEmpty($view.feat_edit_name) then "Please add a name to your feat" else null,
      ),
      composite(
        id = "feat_edit_source",
        margin_top = 4,
        subviews = [
          text(id = "feat_edit_source_label", text = "Source: ", style = "text"),
          select(
            id = "feat_edit_source_select",
            options = "source",
            options_display_stat = "abbreviation",
            stat = "source",
          ),
        ],
        is_visible = !defined(stat = "$parent"),
      ),
      composite(
        id = "feat_edit_type",
        margin_top = 4,
        subviews = [
          text(id = "feat_edit_type_label", text = "Type: ", style = "text"),
          select(id = "feat_edit_type_select", options = "feat_types", stat = "type"),
        ],
        is_visible = !defined(stat = "$parent"),
      ),
      text(
        id = "feat_edit_prerequisites",
        edit_stat = "prerequisites",
        style = "text",
        label = "Prerequisites",
        max_length = 140,
      ),
      composite(
        id = "feat_edit_action_cost",
        margin_top = 4,
        subviews = [
          text(id = "feat_edit_action_cost_label", text = "Action cost: ", style = "text"),
          select(id = "feat_edit_action_cost_select", options = "feat_action_costs", stat = "action_cost"),
        ],
      ),
      text(
        id = "feat_edit_traits",
        edit_stat = "traits",
        style = "text",
        label = "Traits (comma-separated)",
      ),
      composite(
        id = "feat_edit_classes",
        margin_top = 4,
        subviews = [
          text(id = "feat_edit_classes_label", text = "Classes: ", style = "text"),
          select(
            id = "feat_edit_classes_select",
            options = "class",
            options_display_stat = "name",
            stat = "classes",
            multi_select = true,
          ),
        ],
      ),
      composite(
        id = "feat_edit_ancestries",
        margin_top = 4,
        subviews = [
          text(id = "feat_edit_ancestries_label", text = "Races: ", style = "text"),
          select(
            id = "feat_edit_ancestries_select",
            options = "race",
            options_display_stat = "name",
            stat = "ancestries",
            multi_select = true,
          ),
        ],
      ),
      composite(
        id = "feat_edit_heritages",
        margin_top = 4,
        subviews = [
          text(id = "feat_edit_heritages_label", text = "Heritages: ", style = "text"),
          select(
            id = "feat_edit_heritages_select",
            options = "heritage",
            options_display_stat = "name",
            stat = "heritages",
            multi_select = true,
          ),
        ],
      ),
      composite(
        id = "feat_edit_archetypes",
        margin_top = 4,
        subviews = [
          text(id = "feat_edit_archetypes_label", text = "Archetypes: ", style = "text"),
          select(
            id = "feat_edit_archetypes_select",
            options = "archetype",
            options_display_stat = "name",
            stat = "archetypes",
            multi_select = true,
          ),
        ],
        is_visible = $view.feat_edit_type_select == "archetype",
      ),
      text(
        id = "feat_edit_trigger",
        edit_stat = "trigger",
        style = "text",
        label = "Trigger",
      ),
      text(
        id = "feat_edit_requirements",
        edit_stat = "requirements",
        style = "text",
        label = "Requirements",
      ),
      text(
        id = "feat_edit_frequency",
        edit_stat = "frequency",
        style = "text",
        label = "Frequency",
      ),
      text(
        id = "feat_edit_access",
        edit_stat = "access",
        style = "text",
        label = "Access",
      ),
      text(
        id = "feat_edit_special",
        edit_stat = "special",
        style = "text",
        label = "Special",
      ),
      resourceArray(
        id = "feat_edit_levelled_descriptions",
        resource_id = "levelled_description",
        stat = "descriptions",
        view_type = "edit",
        left_view = text(
          id = "feat_edit_descriptions_label",
          text = "Descriptions (per lvl): ",
          style = "text",
        ),
      ),
      resourceArray(
        id = "feat_edit_effects",
        resource_id = "effect",
        view_type = "edit",
        stat = "effects",
        left_view = text(
          id = "feat_edit_effects_label",
          text = "Effects: ",
          style = "text",
        ),
      ),
      resourceArray(
        id = "feat_edit_conditional_linked_feats",
        resource_id = "conditional_linked_feat",
        view_type = "edit",
        stat = "conditional_linked_feats",
        left_view = text(
          id = "feat_edit_conditional_linked_feats_label",
          text = "Conditional linked feats: ",
          style = "text",
        ),
      ),
      resourceArray(
        id = "feat_edit_armor_proficiencies",
        resource_id = "levelled_armor_proficiency",
        stat = "armor_proficiencies",
        view_type = "edit",
        left_view = text(
          id = "feat_edit_armor_proficiencies_label",
          text = "Armor proficiencies (per lvl): ",
          style = "text",
        ),
      ),
      resourceArray(
        id = "feat_edit_skill_proficiencies",
        resource_id = "levelled_skill_proficiency",
        stat = "skill_proficiencies",
        view_type = "edit",
        left_view = text(
          id = "feat_edit_skill_proficiencies_label",
          text = "Skill proficiencies (per lvl): ",
          style = "text",
        ),
      ),
      resourceArray(
        id = "feat_edit_weapon_proficiencies",
        resource_id = "levelled_weapon_proficiency",
        stat = "weapon_proficiencies",
        view_type = "edit",
        left_view = text(
          id = "feat_edit_weapon_proficiencies_label",
          text = "Weapon proficiencies (per lvl): ",
          style = "text",
        ),
      ),
      resourceArray(
        id = "feat_edit_lore_skills",
        resource_id = "lore_skill",
        stat = "lore_skills",
        view_type = "edit",
        left_view = text(
          id = "feat_edit_lore_skills_label",
          text = "Lore skills (per lvl): ",
          style = "text",
        ),
      ),
      checkbox(
        id = "feat_edit_is_basic_spellcasting_feat",
        stat = "is_basic_spellcasting_feat",
        label = "Basic archetype spellcasting feat",
        label_alignment = "right",
        style = "checkbox",
      ),
      checkbox(
        id = "feat_edit_is_expert_spellcasting_feat",
        stat = "is_expert_spellcasting_feat",
        label = "Expert archetype spellcasting feat",
        label_alignment = "right",
        style = "checkbox",
      ),
      checkbox(
        id = "feat_edit_is_master_spellcasting_feat",
        stat = "is_master_spellcasting_feat",
        label = "Master archetype spellcasting feat",
        label_alignment = "right",
        style = "checkbox",
      ),
      checkbox(
        id = "feat_edit_has_selectable_features",
        stat = "has_selectable_features",
        label = "Has selectable features",
        label_alignment = "right",
        style = "checkbox",
        is_visible = can_have_selectable_features,
      ),
      checkbox(
        id = "feat_edit_refresh_selectable_features_on_daily_preparations",
        stat = "refresh_selectable_features_on_daily_preparations",
        label = "Re-select selectable features on daily prep",
        label_alignment = "right",
        style = "checkbox",
        is_visible = $view.feat_edit_has_selectable_features,
      ),
      checkbox(
        id = "feat_edit_grants_weapon_specialization",
        stat = "grants_weapon_specialization",
        label = "Weapon spec. dmg scaling",
        label_alignment = "right",
        style = "checkbox",
      ),
      checkbox(
        id = "feat_edit_grants_greater_weapon_specialization",
        stat = "grants_greater_weapon_specialization",
        label = "Greater weapon spec. dmg scaling",
        label_alignment = "right",
        style = "checkbox",
      ),
      resourceArray(
        id = "feat_edit_selectable_features",
        resource_id = "feat",
        stat = "selectable_features",
        view_type = "edit",
        left_view = text(
          id = "feat_edit_selectable_features_label",
          text = "Selectable features: ",
          style = "text",
        ),
        pop_up_type = "bottomSheet",
        pop_up_button_text = levelled_description,
        is_visible = $view.feat_edit_has_selectable_features,
      ),
      resourceArray(
        id = "feat_edit_selectable_feature_amount_per_level",
        resource_id = "levelled_amount",
        stat = "selectable_feature_amount_per_level",
        view_type = "edit",
        left_view = text(
          id = "feat_edit_selectable_features_amount_per_level_label",
          text = "Amount of selectable features per lvl: ",
          style = "text",
        ),
        is_visible = $view.feat_edit_has_selectable_features,
      ),
    ],
  );
