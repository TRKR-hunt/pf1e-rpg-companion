import "../../macros/system_common.rpgs";

base integer level(name = "Level", abbreviation = "Lvl") = 1;

base integer amount(name = "Description") = 0;

calc string display_description(name = "Display description") =
  levelledDisplayDescription(level = level, value = amount);

base bool is_levelled(name = "Is levelled") = true;

calc bool can_be_used(name = "Can execute") =
  levelGate(required_level = level);
