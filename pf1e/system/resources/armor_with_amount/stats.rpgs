import "../../macros/system_common.rpgs";

base integer amount(name = "Amount") = 1;

base resource<armor> armor(name = "Armor") = null;

calc string display_description(name = "Display description") =
  armorWithAmountDisplayDescription();

base bool selected(name = "Is selected") = false;

calc bool can_toggle_selection(name = "Can toggle selection") =
  armorWithAmountCanToggleSelection();

base bool should_load_effects(name = "Should load effects") = false;
