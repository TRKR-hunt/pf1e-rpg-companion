view archetype_list() =
  composite(
    id = "archetype_list",
    margin_left = 8,
    subviews = [
      text(
        id = "archetype_list_class_archetype_badge",
        text = "CLASS",
        style = "caption",
        color = "accent",
        is_visible = is_class_archetype,
      ),
    ],
  );
