base string name(name = "Name") = "";

base string source(name = "Source") = "";

base string description(name = "Description") = "";

base bool is_class_archetype(name = "Is class archetype") = false;

base string required_class_id(name = "Required class ID") = "";

base resource<feat> dedication_feat(name = "Dedication feat") = null;

base resource<feat>[] feats(name = "Feats") = [];

base resource<progression_grant>[] progression_grants(name = "Progression grants") =
  [];

base resource<levelled_amount>[] cantrip_quantity_per_level(name = "Cantrip quantity per level") =
  [];

base resource<spell_capacity_grant>[] spell_capacity_grants(name = "Spell capacity grants") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_0(name = "Prepared cantrips") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_1(name = "Prepared rank 1 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_2(name = "Prepared rank 2 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_3(name = "Prepared rank 3 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_4(name = "Prepared rank 4 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_5(name = "Prepared rank 5 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_6(name = "Prepared rank 6 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_7(name = "Prepared rank 7 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_8(name = "Prepared rank 8 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_9(name = "Prepared rank 9 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_10(name = "Prepared rank 10 spells") =
  [];

calc resource<feat>[] dedication_feat_array(name = "Dedication feat array") =
  if notNull(dedication_feat) then [dedication_feat] else [];

calc resource<feat>[] sorted_feats(name = "Sorted feats") =
  sortBy(
    feats,
    order = "asc",
    sort_by_selector = ($sortByValue) => $sortByValue.min_level,
  );

calc resource<progression_grant>[] progression_grants_for_current_level(name = "Progression grants for current level") =
  filter(
    progression_grants,
    filter = ($filterValue) => ($filterValue.level <= ($character?.level ?? 1)),
  );

calc resource<feat>[] auto_feats_for_current_level(name = "Auto-granted feats for current level") =
  if !is_class_archetype
    then []
    else filter(feats, filter = ($f) => $f.min_level <= ($character?.level ?? 1));

calc string list_view_description(name = "List view description") = description;

base bool grants_spellcasting(name = "Grants spellcasting") = false;

base string spellcasting_tradition(name = "Spellcasting tradition") = "arcane";

base string spellcasting_ability(name = "Spellcasting ability") = "intelligence";

base string spellcasting_mode(name = "Spellcasting mode") = "prepared";

base string spellcasting_proficiency(name = "Spellcasting proficiency (none, trained, expert, master, legendary)") = "trained";

base integer spell_slots_1(name = "Rank 1 spell slots remaining") = 0;

base integer spell_slots_2(name = "Rank 2 spell slots remaining") = 0;

base integer spell_slots_3(name = "Rank 3 spell slots remaining") = 0;

base integer spell_slots_4(name = "Rank 4 spell slots remaining") = 0;

base integer spell_slots_5(name = "Rank 5 spell slots remaining") = 0;

base integer spell_slots_6(name = "Rank 6 spell slots remaining") = 0;

base integer spell_slots_7(name = "Rank 7 spell slots remaining") = 0;

base integer spell_slots_8(name = "Rank 8 spell slots remaining") = 0;

base integer spell_slots_9(name = "Rank 9 spell slots remaining") = 0;

base integer spell_slots_10(name = "Rank 10 spell slots remaining") = 0;

calc bool has_basic_spellcasting(name = "Has basic spellcasting feat") =
  !isEmpty(
    filter(
      $character?.all_feats ?? [],
      filter = ($f) => contains(
        haystack = map(feats, mapper = ($fv) => $fv.id),
        needle = $f.id,
      ) && ($f.is_basic_spellcasting_feat ?? false),
    ),
  );

calc bool has_expert_spellcasting(name = "Has expert spellcasting feat") =
  !isEmpty(
    filter(
      $character?.all_feats ?? [],
      filter = ($f) => contains(
        haystack = map(feats, mapper = ($fv) => $fv.id),
        needle = $f.id,
      ) && ($f.is_expert_spellcasting_feat ?? false),
    ),
  );

calc bool has_master_spellcasting(name = "Has master spellcasting feat") =
  !isEmpty(
    filter(
      $character?.all_feats ?? [],
      filter = ($f) => contains(
        haystack = map(feats, mapper = ($fv) => $fv.id),
        needle = $f.id,
      ) && ($f.is_master_spellcasting_feat ?? false),
    ),
  );

calc bool has_dedication_feat_selected(name = "Has dedication feat selected") =
  notNull(dedication_feat)
    && !isEmpty(
      filter(
        $character?.all_feats ?? [],
        filter = ($f) => $f.id == dedication_feat.id,
      ),
    );

calc integer max_spell_slots_1(name = "Max rank 1 spell slots") =
  if has_basic_spellcasting && ($character?.level ?? 0) >= 4 then 1 else 0;

calc integer max_spell_slots_2(name = "Max rank 2 spell slots") =
  if has_basic_spellcasting && ($character?.level ?? 0) >= 6 then 1 else 0;

calc integer max_spell_slots_3(name = "Max rank 3 spell slots") =
  if has_basic_spellcasting && ($character?.level ?? 0) >= 8 then 1 else 0;

calc integer max_spell_slots_4(name = "Max rank 4 spell slots") =
  if has_expert_spellcasting && ($character?.level ?? 0) >= 12 then 1 else 0;

calc integer max_spell_slots_5(name = "Max rank 5 spell slots") =
  if has_expert_spellcasting && ($character?.level ?? 0) >= 14 then 1 else 0;

calc integer max_spell_slots_6(name = "Max rank 6 spell slots") =
  if has_expert_spellcasting && ($character?.level ?? 0) >= 16 then 1 else 0;

calc integer max_spell_slots_7(name = "Max rank 7 spell slots") =
  if has_master_spellcasting && ($character?.level ?? 0) >= 18 then 1 else 0;

calc integer max_spell_slots_8(name = "Max rank 8 spell slots") =
  if has_master_spellcasting && ($character?.level ?? 0) >= 20 then 1 else 0;

calc integer max_spell_slots_9(name = "Max rank 9 spell slots") = 0;

calc integer max_spell_slots_10(name = "Max rank 10 spell slots") = 0;

calc resource<spell_capacity_grant>[] active_spell_capacity_grants(name = "Active spell capacity grants") =
  filter(
    spell_capacity_grants,
    filter = ($filterValue) => ($filterValue.level <= ($character?.level ?? 1)),
  );

calc resource<levelled_amount> cantrip_quantity_lookup(name = "Cantrip quantity lookup row") =
  findFirst(
    sortBy(
      cantrip_quantity_per_level,
      order = "desc",
      sort_by_selector = ($sortByValue) => $sortByValue.level,
    ),
    filter = ($findFirstValue) => ($findFirstValue.level <= ($character?.level ?? 1)),
  );

calc integer max_archetype_cantrip_quantity_base(name = "Max archetype cantrip quantity (base)") =
  cantrip_quantity_lookup?.amount ?? 0;

calc integer max_archetype_cantrip_quantity_grants(name = "Max archetype cantrip quantity (grants)") =
  add(
    map(
      filter(
        active_spell_capacity_grants,
        filter = ($filterValue) => ($filterValue.capacity_type == "cantrip"),
      ),
      mapper = ($mapValue) => $mapValue.current_quantity,
    ),
  );

calc integer max_archetype_cantrip_quantity(name = "Max archetype cantrip quantity") =
  max_archetype_cantrip_quantity_base + max_archetype_cantrip_quantity_grants;

calc integer highest_base_spell_slot_rank(name = "Highest base spell slot rank") =
  when {
    max_spell_slots_9 > 0 -> 9,
    max_spell_slots_8 > 0 -> 8,
    max_spell_slots_7 > 0 -> 7,
    max_spell_slots_6 > 0 -> 6,
    max_spell_slots_5 > 0 -> 5,
    max_spell_slots_4 > 0 -> 4,
    max_spell_slots_3 > 0 -> 3,
    max_spell_slots_2 > 0 -> 2,
    max_spell_slots_1 > 0 -> 1,
    else -> 0,
  };

calc integer max_spell_slots_1_grants(name = "Max rank 1 spell slots (grants)") =
  add(
    map(
      filter(
        active_spell_capacity_grants,
        filter = ($g) => $g.capacity_type == "slot"
          && (
              ($g.target_rank_mode == "specific" && $g.target_rank == 1)
                || ($g.target_rank_mode == "highest_available" && highest_base_spell_slot_rank == 1)
            ),
      ),
      mapper = ($g) => $g.current_quantity,
    ),
  );

calc integer max_spell_slots_2_grants(name = "Max rank 2 spell slots (grants)") =
  add(
    map(
      filter(
        active_spell_capacity_grants,
        filter = ($g) => $g.capacity_type == "slot"
          && (
              ($g.target_rank_mode == "specific" && $g.target_rank == 2)
                || ($g.target_rank_mode == "highest_available" && highest_base_spell_slot_rank == 2)
            ),
      ),
      mapper = ($g) => $g.current_quantity,
    ),
  );

calc integer max_spell_slots_3_grants(name = "Max rank 3 spell slots (grants)") =
  add(
    map(
      filter(
        active_spell_capacity_grants,
        filter = ($g) => $g.capacity_type == "slot"
          && (
              ($g.target_rank_mode == "specific" && $g.target_rank == 3)
                || ($g.target_rank_mode == "highest_available" && highest_base_spell_slot_rank == 3)
            ),
      ),
      mapper = ($g) => $g.current_quantity,
    ),
  );

calc integer max_spell_slots_4_grants(name = "Max rank 4 spell slots (grants)") =
