// Stage-3 inline: stripped import; preparedCantripChoiceArray and
// preparedSpellChoiceArrayByRank expanded inline (1 cantrip + 10 ranks).
view archetype_edit() =
  list(
    id = "archetype_edit",
    padding = 16,
    subviews = [
      text(
        id = "archetype_edit_name",
        edit_stat = "name",
        style = "text",
        label = "Name",
        max_length = 140,
        validation_message = if isEmpty($view.archetype_edit_name)
        then "Please add a name to your archetype"
        else null,
      ),
      composite(
        id = "archetype_edit_source",
        margin_top = 4,
        subviews = [
          text(id = "archetype_edit_source_label", text = "Source: ", style = "text"),
          select(
            id = "archetype_edit_source_select",
            options = "source",
            options_display_stat = "abbreviation",
            stat = "source",
          ),
        ],
      ),
      text(
        id = "archetype_edit_description",
        edit_stat = "description",
        style = "text",
        label = "Description",
        margin_top = 4,
      ),
      checkbox(
        id = "archetype_edit_is_class_archetype",
        stat = "is_class_archetype",
        label = "Is class archetype",
        label_alignment = "right",
        margin_top = 4,
        style = "checkbox",
      ),
      composite(
        id = "archetype_edit_required_class_id",
        margin_top = 4,
        subviews = [
          text(
            id = "archetype_edit_required_class_id_label",
            text = "Required class: ",
            style = "text",
          ),
          select(
            id = "archetype_edit_required_class_id_select",
            options = "class",
            options_display_stat = "name",
            stat = "required_class_id",
          ),
        ],
        is_visible = $view.archetype_edit_is_class_archetype,
      ),
      composite(
        id = "archetype_edit_dedication_feat_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "archetype_edit_dedication_feat_label",
            text = "Dedication feat: ",
            style = "text",
          ),
          selectResources(
            id = "archetype_edit_dedication_feat_select",
            stat = "dedication_feat",
            resource_id = "feat",
          ),
        ],
      ),
      resourceArray(
        id = "archetype_edit_feats",
        resource_id = "feat",
        stat = "feats",
        view_type = "edit",
        left_view = text(
          id = "archetype_edit_feats_label",
          text = "Archetype feats: ",
          style = "text",
        ),
        margin_top = 8,
        pop_up_type = "bottomSheet",
        pop_up_button_text = name,
      ),
      checkbox(
        id = "archetype_edit_grants_spellcasting",
        stat = "grants_spellcasting",
        label = "Grants spellcasting",
        label_alignment = "right",
        margin_top = 8,
        style = "checkbox",
      ),
      list(
        id = "archetype_edit_spellcasting_details",
        margin_top = 4,
        is_visible = $view.archetype_edit_grants_spellcasting,
        subviews = [
          composite(
            id = "archetype_edit_spellcasting_details_composite",
            subviews = [
              select(
                id = "archetype_edit_spellcasting_tradition",
                stat = "spellcasting_tradition",
                options = "spell_traditions",
                margin_right = 4,
              ),
              select(
                id = "archetype_edit_spellcasting_mode",
                stat = "spellcasting_mode",
                options = "spellcasting_modes",
                margin_right = 4,
              ),
              select(
                id = "archetype_edit_spellcasting_proficiency",
                stat = "spellcasting_proficiency",
                options = "skill_proficiency_types",
              ),
            ],
          ),
          composite(
            id = "archetype_edit_spellcasting_details_ability_composite",
            margin_top = 4,
            subviews = [
              text(
                id = "archetype_edit_spellcasting_ability_label",
                text = "Ability: ",
                style = "text"
              ),
              select(
                id = "archetype_edit_spellcasting_ability",
                stat = "spellcasting_ability",
                options = "ability",
              ),
            ]
          ),
          resourceArray(
            id = "archetype_edit_cantrip_quantity_per_level",
            resource_id = "levelled_amount",
            stat = "cantrip_quantity_per_level",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_cantrip_quantity_per_level_label",
              text = "Cantrip quantity by level:",
              style = "text",
              bold = true,
            ),
          ),
          resourceArray(
            id = "archetype_edit_spell_capacity_grants",
            resource_id = "spell_capacity_grant",
            stat = "spell_capacity_grants",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_spell_capacity_grants_label",
              text = "Capacity grants:",
              style = "text",
              bold = true,
            ),
          ),
          text(
            id = "archetype_edit_prepared_warning",
            text = prepared_capacity_warning_text,
            style = "caption",
            color = "accent",
            is_visible = !isEmpty(prepared_capacity_warning_text)
            && $view.archetype_edit_spellcasting_mode == "prepared",
          ),
          resourceArray(
            id = "archetype_edit_prepared_spells_rank_0_array",
            resource_id = "prepared_spell_choice",
            stat = "prepared_spell_choices_rank_0",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_prepared_spells_rank_0_label",
              text = "Cantrips",
              style = "text",
              bold = true,
            ),
            is_visible = $view.archetype_edit_spellcasting_mode == "prepared"
            && (max_archetype_cantrip_quantity > 0 || !isEmpty(prepared_spell_choices_rank_0)),
          ),
          resourceArray(
            id = "archetype_edit_prepared_spells_rank_1_array",
            resource_id = "prepared_spell_choice",
            stat = "prepared_spell_choices_rank_1",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_prepared_spells_rank_1_label",
              text = "Rank 1",
              style = "text",
              bold = true,
            ),
            is_visible = $view.archetype_edit_spellcasting_mode == "prepared"
            && (max_spell_slots_1_total > 0 || !isEmpty(prepared_spell_choices_rank_1)),
          ),
          resourceArray(
            id = "archetype_edit_prepared_spells_rank_2_array",
            resource_id = "prepared_spell_choice",
            stat = "prepared_spell_choices_rank_2",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_prepared_spells_rank_2_label",
              text = "Rank 2",
              style = "text",
              bold = true,
            ),
            is_visible = $view.archetype_edit_spellcasting_mode == "prepared"
            && (max_spell_slots_2_total > 0 || !isEmpty(prepared_spell_choices_rank_2)),
          ),
          resourceArray(
            id = "archetype_edit_prepared_spells_rank_3_array",
            resource_id = "prepared_spell_choice",
            stat = "prepared_spell_choices_rank_3",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_prepared_spells_rank_3_label",
              text = "Rank 3",
              style = "text",
              bold = true,
            ),
            is_visible = $view.archetype_edit_spellcasting_mode == "prepared"
            && (max_spell_slots_3_total > 0 || !isEmpty(prepared_spell_choices_rank_3)),
          ),
          resourceArray(
            id = "archetype_edit_prepared_spells_rank_4_array",
            resource_id = "prepared_spell_choice",
            stat = "prepared_spell_choices_rank_4",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_prepared_spells_rank_4_label",
              text = "Rank 4",
              style = "text",
              bold = true,
            ),
            is_visible = $view.archetype_edit_spellcasting_mode == "prepared"
            && (max_spell_slots_4_total > 0 || !isEmpty(prepared_spell_choices_rank_4)),
          ),
          resourceArray(
            id = "archetype_edit_prepared_spells_rank_5_array",
            resource_id = "prepared_spell_choice",
            stat = "prepared_spell_choices_rank_5",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_prepared_spells_rank_5_label",
              text = "Rank 5",
              style = "text",
              bold = true,
            ),
            is_visible = $view.archetype_edit_spellcasting_mode == "prepared"
            && (max_spell_slots_5_total > 0 || !isEmpty(prepared_spell_choices_rank_5)),
          ),
          resourceArray(
            id = "archetype_edit_prepared_spells_rank_6_array",
            resource_id = "prepared_spell_choice",
            stat = "prepared_spell_choices_rank_6",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_prepared_spells_rank_6_label",
              text = "Rank 6",
              style = "text",
              bold = true,
            ),
            is_visible = $view.archetype_edit_spellcasting_mode == "prepared"
            && (max_spell_slots_6_total > 0 || !isEmpty(prepared_spell_choices_rank_6)),
          ),
          resourceArray(
            id = "archetype_edit_prepared_spells_rank_7_array",
            resource_id = "prepared_spell_choice",
            stat = "prepared_spell_choices_rank_7",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_prepared_spells_rank_7_label",
              text = "Rank 7",
              style = "text",
              bold = true,
            ),
            is_visible = $view.archetype_edit_spellcasting_mode == "prepared"
            && (max_spell_slots_7_total > 0 || !isEmpty(prepared_spell_choices_rank_7)),
          ),
          resourceArray(
            id = "archetype_edit_prepared_spells_rank_8_array",
            resource_id = "prepared_spell_choice",
            stat = "prepared_spell_choices_rank_8",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_prepared_spells_rank_8_label",
              text = "Rank 8",
              style = "text",
              bold = true,
            ),
            is_visible = $view.archetype_edit_spellcasting_mode == "prepared"
            && (max_spell_slots_8_total > 0 || !isEmpty(prepared_spell_choices_rank_8)),
          ),
          resourceArray(
            id = "archetype_edit_prepared_spells_rank_9_array",
            resource_id = "prepared_spell_choice",
            stat = "prepared_spell_choices_rank_9",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_prepared_spells_rank_9_label",
              text = "Rank 9",
              style = "text",
              bold = true,
            ),
            is_visible = $view.archetype_edit_spellcasting_mode == "prepared"
            && (max_spell_slots_9_total > 0 || !isEmpty(prepared_spell_choices_rank_9)),
          ),
          resourceArray(
            id = "archetype_edit_prepared_spells_rank_10_array",
            resource_id = "prepared_spell_choice",
            stat = "prepared_spell_choices_rank_10",
            view_type = "edit",
            left_view = text(
              id = "archetype_edit_prepared_spells_rank_10_label",
              text = "Rank 10",
              style = "text",
              bold = true,
            ),
            is_visible = $view.archetype_edit_spellcasting_mode == "prepared"
            && (max_spell_slots_10_total > 0 || !isEmpty(prepared_spell_choices_rank_10)),
          ),
        ],
      ),
    ],
  );
