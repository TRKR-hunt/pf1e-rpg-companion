          ),
        ],
        is_visible = !isEmpty(armor_proficiencies),
      ),
      composite(
        id = "class_display_shield_proficiencies_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_shield_proficiencies_label",
            text = "Shield proficiencies: ",
            style = "text",
            bold = true,
