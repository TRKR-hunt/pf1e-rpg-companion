          ),
        ],
        is_visible = !isEmpty(shield_proficiencies),
      ),
      collapsible(
        id = "class_display_lore_skills_collapsible",
        title = "Lore skills (per lvl)",
        start_expanded = false,
        subviews = [
          resourceArray(
            id = "class_display_lore_skills",
