view class_display() =
  list(
    id = "class_display",
    padding = 16,
    alignment = "start",
    subviews = [
      text(
        id = "class_display_source",
        style = "caption",
        margin_left = 16,
        resource_id = "source",
        resource_instance_ids_stat = "source",
        resource_display_stat = "abbreviation",
      ),
      text(
        id = "class_display_lore_only_banner",
        text = "(Lore Only — not mechanically implemented)",
        style = "caption",
        bold = true,
        is_visible = is_lore_only,
      ),
      text(
        id = "class_display_description",
        text = description,
        style = "text",
        markdown = true,
        is_visible = !isEmpty(description),
      ),
      text(
        id = "class_display_lore",
        text = lore,
        style = "text",
        markdown = true,
        margin_top = 8,
        is_visible = !isEmpty(lore),
      ),
      resourceArray(
        id = "class_display_ability_score_increases",
        resource_id = "ability_score_increase",
        stat = "ability_score_increases",
        view_type = "display",
        left_view = text(
          id = "class_display_ability_boosts_label",
          text = "Ability boosts: ",
          style = "text",
          bold = true,
        ),
        is_visible = !isEmpty(ability_score_increases),
      ),
      composite(
        id = "class_display_additional_trained_skills_rule",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_additional_trained_skills_rule_label",
            text = "Additional trained skills: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "class_display_additional_trained_skills_rule_text",
            text = display_additional_trained_skills_rule,
            style = "text",
          ),
        ],
        is_visible = additional_trained_skills_base_count > 0,
      ),
      composite(
        id = "class_display_hp_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_hp_label",
            text = "HP: ",
            style = "text",
            bold = true,
          ),
          text(id = "class_display_hp_text", text = display_hp, style = "text"),
        ],
      ),
      composite(
        id = "class_display_armor_class_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_armor_class_label",
            text = "Armor class: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "class_display_armor_class_label",
            text = display_armor_class,
            style = "text",
          ),
        ],
      ),
      composite(
        id = "class_display_saving_throws",
        subviews = [
          text(
            id = "class_display_saving_throws_label",
            text = "Save proficiencies: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "class_display_saving_throws_text",
            text = display_saving_throws,
            style = "text",
          ),
        ],
      ),
      composite(
        id = "class_display_perception_proficiency",
        margin_top = 4,
        subviews = [
          text(
            id = "class_display_perception_proficiency_label",
            text = "Perception proficiency: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "class_display_perception_proficiency_text",
            text = display_perception_proficiency,
            style = "text",
          ),
        ],
      ),
      collapsible(
        id = "class_display_features_collapsible",
        title = "Features",
        start_expanded = false,
        subviews = [
          resourceSection(
            id = "class_display_features",
            resource_stat = "features",
            resource_id = "feat",
            content_item_min_width = 1,
            read_only = true,
          ),
        ],
      ),
      collapsible(
        id = "class_display_progression_grants_collapsible",
        title = "Progression grants",
        start_expanded = false,
        subviews = [
          resourceSection(
            id = "class_display_progression_grants",
            resource_stat = "progression_grants",
            resource_id = "progression_grant",
            content_item_min_width = 1,
            read_only = true,
          ),
        ],
        is_visible = !isEmpty(progression_grants),
      ),
      collapsible(
        id = "class_display_skill_increase_rank_caps_collapsible",
        title = "Skill increase rank caps",
        start_expanded = false,
        subviews = [
          resourceSection(
            id = "class_display_skill_increase_rank_caps",
            resource_stat = "skill_increase_rank_caps",
            resource_id = "levelled_rank_cap",
            content_item_min_width = 1,
            read_only = true,
          ),
        ],
        is_visible = !isEmpty(skill_increase_rank_caps),
      ),
      composite(
        id = "class_display_spellcasting_ability_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_spellcasting_ability_label",
            text = "Spellcasting ability: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "class_display_spellcasting_ability_label",
            text = display_spellcasting_ability,
            style = "text",
          ),
        ],
      ),
      composite(
        id = "class_display_spellcasting_mode_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_spellcasting_mode_label",
            text = "Spellcasting mode: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "class_display_spellcasting_mode_text",
            text = display_spellcasting_mode,
            style = "text",
          ),
        ],
      ),
      composite(
        id = "class_display_caster_level_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_caster_level_label",
            text = "Spellcasting progression: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "class_display_caster_level_label",
            text = display_caster_level,
            style = "text",
          ),
        ],
      ),
      composite(
        id = "class_display_spellcasting_proficiency_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_spellcasting_proficiency_label",
            text = "Spellcasting proficiency: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "class_display_spellcasting_proficiency",
            text = display_spellcasting_proficiency,
            style = "text",
          ),
        ],
      ),
      composite(
        id = "class_display_class_key_ability_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_class_key_ability_label",
            text = "Class key ability: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "class_display_class_key_ability_text",
            text = display_class_key_ability,
            style = "text",
          ),
        ],
      ),
      composite(
        id = "class_display_class_dc_proficiency_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_class_dc_proficiency_label",
            text = "Class DC proficiency: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "class_display_class_dc_proficiency_text",
            text = display_class_dc_proficiency,
            style = "text",
          ),
        ],
      ),
      collapsible(
        id = "class_display_spells_collapsible",
        title = "Spells (per lvl)",
        start_expanded = false,
        subviews = [
          resourceSection(
            id = "class_display_spells",
            resource_stat = "spells",
            resource_id = "levelled_spell",
            content_item_min_width = 1,
            read_only = true,
          ),
        ],
        is_visible = !isEmpty(spells),
      ),
      composite(
        id = "class_display_weapon",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_weapon_label",
            text = "Weapon: ",
            style = "text",
            bold = true,
          ),
          text(id = "class_display_weapon_text", text = display_weapon, style = "text"),
        ],
      ),
      collapsible(
        id = "class_display_equipment_choices_collapsible",
        title = "Starting equipment choices",
        start_expanded = false,
        subviews = [
          resourceArray(
            id = "class_display_selectable_armors",
            resource_id = "selectable_armors",
            stat = "selectable_armors",
            view_type = "display",
          ),
          resourceArray(
            id = "class_display_selectable_weapons",
            resource_id = "selectable_weapons",
            stat = "selectable_weapons",
            view_type = "display",
          ),
          resourceArray(
            id = "class_display_selectable_items",
            resource_id = "selectable_items",
            stat = "selectable_equipments",
            view_type = "display",
          ),
        ],
        is_visible = !isEmpty(selectable_armors)
          && !isEmpty(selectable_weapons)
          && !isEmpty(selectable_equipments),
      ),
      collapsible(
        id = "class_display_languages_collapsible",
        title = "Languages (per lvl)",
        start_expanded = false,
        subviews = [
          resourceArray(
            id = "class_display_languages",
            resource_id = "levelled_choice_text",
            stat = "language_proficiencies",
            view_type = "display",
          ),
        ],
        is_visible = !isEmpty(language_proficiencies),
      ),
      collapsible(
        id = "class_display_skills_collapsible",
        title = "Skill proficiencies (per lvl)",
        start_expanded = false,
        subviews = [
          resourceArray(
            id = "class_display_skills",
            resource_id = "levelled_skill_proficiency",
            stat = "skill_proficiencies",
            view_type = "display",
          ),
        ],
        is_visible = !isEmpty(skill_proficiencies),
      ),
      composite(
        id = "class_display_weapon_proficiencies_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_weapon_proficiencies_label",
            text = "Weapon proficiencies: ",
            style = "text",
            bold = true,
          ),
          text(
            id = "class_display_weapon_proficiencies_text",
            text = joinToString(weapon_proficiencies, separator = ", "),
