          ),
        ],
        is_visible = !isEmpty(weapon_proficiencies),
      ),
      composite(
        id = "class_display_armor_proficiencies_composite",
        margin_top = 8,
        subviews = [
          text(
            id = "class_display_armor_proficiencies_label",
