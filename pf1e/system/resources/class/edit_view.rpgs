          ),
          composite(
            id = "class_edit_spellcasting_proficiency_composite",
            margin_bottom = 4,
            subviews = [
              text(
                id = "class_edit_spellcasting_proficiency_label",
                text = "Fallback spellcasting proficiency: ",
                style = "text",
              ),
              select(
                id = "class_edit_spellcasting_proficiency_select",
                stat = "spellcasting_proficiency",
                options = "skill_proficiency_types",
              ),
            ],
          ),
          resourceArray(
            id = "class_edit_spellcasting_proficiency_by_level",
            margin_top = 4,
            resource_id = "levelled_save_proficiency",
            stat = "spellcasting_proficiency_per_level",
            view_type = "edit",
            left_view = text(
              id = "class_edit_spellcasting_proficiency_by_level_label",
              text = "Spellcasting proficiency progression: ",
