          resourceArray(
            id = "class_edit_class_dc_proficiency_by_level",
            margin_top = 4,
            resource_id = "levelled_save_proficiency",
            stat = "class_dc_proficiency_per_level",
            view_type = "edit",
            left_view = text(
              id = "class_edit_class_dc_proficiency_by_level_label",
              text = "Class DC progression: ",
              style = "text",
              bold = true,
            ),
          ),
          text(
            id = "class_edit_class_dc_proficiency_note",
            text = "Use progression rows for PF2e scaling. Fallback applies only if no row matches.",
            style = "caption",
            margin_top = 4,
            margin_bottom = 4,
          ),
          composite(
            id = "class_edit_spellcasting_progression_kind_composite",
            subviews = [
              text(
                id = "class_edit_spellcasting_progression_kind_label",
                text = "Spellcasting progression: ",
                style = "text",
                bold = true,
              ),
              select(
                id = "class_edit_spellcasting_progression_kind",
                stat = "spellcasting_progression_kind",
                options = "spellcasting_progression_kinds",
              ),
            ],
          ),
          levelledAmountPopUpButton(
            id_prefix = "class_edit_cantrip_quantity_per_level",
            stat_id = "cantrip_quantity_per_level",
            button_text = "Cantrip cap by level",
            pop_up_title = "Edit Cantrip Quantity by Level",
            left_view_text = "Cantrip quantity by level: ",
          ),
          resourceArray(
            id = "class_edit_spell_capacity_grants",
            margin_top = 8,
            resource_id = "spell_capacity_grant",
            stat = "spell_capacity_grants",
            view_type = "edit",
            left_view = text(
              id = "class_edit_spell_capacity_grants_label",
              text = "Spell capacity grants: ",
              style = "text",
              bold = true,
            ),
            pop_up_type = "bottomSheet",
            pop_up_button_text = display_description,
          ),
          list(
            id = "class_edit_spell_slots_per_level",
            padding = 0,
            is_visible = ($view?.class_edit_spellcasting_progression_kind? ?? spellcasting_progression_kind) == "custom",
            subviews = [
              checkbox(
                id = "class_edit_spell_recharge_slots_on_refocus",
                stat = "recharge_slots_on_refocus",
                label = "Recharge spell ranks on refocus",
                label_alignment = "right",
              ),
              text(
                id = "class_edit_spell_slots_per_level_label",
                text = "Spell ranks:",
                style = "text",
                bold = true,
              ),
              systemClassSpellSlotsPerLevelPopUpButton(slot_level = "1"),
              systemClassSpellSlotsPerLevelPopUpButton(slot_level = "2"),
              systemClassSpellSlotsPerLevelPopUpButton(slot_level = "3"),
              systemClassSpellSlotsPerLevelPopUpButton(slot_level = "4"),
              systemClassSpellSlotsPerLevelPopUpButton(slot_level = "5"),
              systemClassSpellSlotsPerLevelPopUpButton(slot_level = "6"),
              systemClassSpellSlotsPerLevelPopUpButton(slot_level = "7"),
              systemClassSpellSlotsPerLevelPopUpButton(slot_level = "8"),
              systemClassSpellSlotsPerLevelPopUpButton(slot_level = "9"),
