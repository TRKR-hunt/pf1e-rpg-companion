          resourceArray(
            id = "class_edit_armor_proficiencies",
            resource_id = "levelled_armor_proficiency",
            stat = "armor_proficiencies",
            view_type = "edit",
            left_view = text(
              id = "class_edit_armor_proficiencies_label",
              text = "Armor proficiency choices (per lvl): ",
