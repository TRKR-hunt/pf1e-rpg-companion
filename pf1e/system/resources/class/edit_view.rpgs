          resourceArray(
            id = "class_edit_spells",
            resource_id = "levelled_spell",
            stat = "spells",
            view_type = "edit",
            left_view = text(
              id = "class_edit_spells_label",
              text = "Spells (per lvl): ",
              style = "text",
              bold = true,
            ),
          ),
