              select(
                id = "class_edit_class_key_ability_select",
                stat = "class_key_ability",
                options = "ability",
              ),
              text(
                id = "class_edit_class_key_ability_options_label",
                margin_left = 8,
                text = "Options: ",
                style = "text",
                bold = true,
              ),
              select(
                id = "class_edit_class_key_ability_options_select",
                stat = "class_key_ability_options",
                options = "ability",
                multi_select = true,
              ),
              text(
                id = "class_edit_class_dc_proficiency_label",
                margin_left = 8,
                text = "Fallback class DC proficiency: ",
