          ),
          composite(
            id = "class_edit_spellcasting_mode_composite",
            margin_bottom = 4,
            subviews = [
              text(
                id = "class_edit_spellcasting_mode_label",
                text = "Spellcasting mode: ",
                style = "text",
                bold = true,
              ),
              select(
                id = "class_edit_spellcasting_mode_select",
                stat = "spellcasting_mode",
                options = "spellcasting_modes",
              ),
