          ),
          composite(
            id = "class_edit_spellcasting_tradition_composite",
            margin_bottom = 4,
            subviews = [
              text(
                id = "class_edit_spellcasting_tradition_label",
                text = "Spellcasting tradition: ",
                style = "text",
                bold = true,
              ),
              select(
                id = "class_edit_spellcasting_tradition_select",
                stat = "spellcasting_tradition",
                options = "spell_traditions",
              ),
