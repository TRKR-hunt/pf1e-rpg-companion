          resourceArray(
            id = "class_edit_selectable_equipments",
            resource_id = "selectable_items",
            stat = "selectable_equipments",
            view_type = "edit",
            left_view = text(
              id = "class_edit_selectable_equipments_label",
              text = "Starting equipment choices: ",
              style = "text",
              bold = true,
