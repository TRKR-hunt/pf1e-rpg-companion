import "../../macros/system_common.rpgs";

view class_edit() =
  viewPager(
    id = "class_edit",
    names = [
      "Basic information",
      "Features",
      "Spellcasting",
      "Weapons & Equipment",
      "Proficiencies",
    ],
    color = "#016157",
    subviews = [
      list(
        id = "class_edit_basics",
        padding = 16,
        subviews = [
          text(
            id = "class_edit_name",
            edit_stat = "name",
            style = "text",
            label = "Name",
            max_length = 140,
            validation_message = if isEmpty($view.class_edit_name)
              then "Please add a name to your class"
              else null,
          ),
          composite(
            id = "class_edit_source",
            margin_top = 4,
            subviews = [
              text(id = "class_edit_source_label", text = "Source: ", style = "text"),
              select(
                id = "class_edit_source_select",
                options = "source",
                options_display_stat = "abbreviation",
                stat = "source",
              ),
            ],
          ),
          text(
            id = "class_edit_description",
            edit_stat = "description",
            label = "Description",
            style = "text",
          ),
          checkbox(
            id = "class_edit_requires_deity",
            stat = "requires_deity",
            label = "Requires deity selection",
            label_alignment = "right",
          ),
          resourceArray(
            id = "class_edit_ability_score_increases",
            resource_id = "ability_score_increase",
            stat = "ability_score_increases",
            view_type = "edit",
            left_view = text(
              id = "class_edit_ability_boosts_label",
              text = "Ability boosts: ",
              style = "text",
              bold = true,
            ),
            pop_up_type = "bottomSheet",
            pop_up_button_text = description,
          ),
          composite(
            id = "class_edit_additional_trained_skills_composite",
            margin_top = 4,
            subviews = [
              text(
                id = "class_edit_additional_trained_skills_base_label",
                text = "Additional trained skills (base): ",
                style = "text",
                bold = true,
              ),
              text(
                id = "class_edit_additional_trained_skills_base",
                edit_stat = "additional_trained_skills_base_count",
                style = "text",
                max_length = 3,
                signed = false,
                hint = "0",
              ),
              text(
                id = "class_edit_additional_trained_skills_plus_label",
                text = " + ",
                style = "text",
              ),
              select(
                id = "class_edit_additional_trained_skills_ability_select",
                stat = "additional_trained_skills_ability",
                options = "ability",
              ),
              text(
                id = "class_edit_additional_trained_skills_modifier_label",
                text = " modifier",
                style = "text",
              ),
            ],
          ),
          composite(
            id = "class_edit_hp_composite",
            margin_top = 4,
            subviews = [
              text(
                id = "class_edit_hp_per_level_label",
                text = "HP per level: ",
                style = "text",
                bold = true,
              ),
              text(
                id = "class_edit_hp_per_level",
                edit_stat = "class_hp_per_level",
                style = "text",
                max_length = 3,
                signed = false,
                hint = "8",
              ),
              text(id = "class_edit_hp_plus_label", text = " + ", style = "text"),
              select(
                id = "class_edit_hp_modifiers",
                stat = "hp_modifiers",
                options = "ability",
                multi_select = true,
              ),
            ],
          ),
          composite(
            id = "class_edit_armor_composite",
            margin_top = 4,
            subviews = [
              text(id = "class_edit_base_ac", text = "Base AC: ", style = "text", bold = true),
              text(
                id = "class_edit_base_ac",
                edit_stat = "base_ac",
                style = "text",
                max_length = 2,
                signed = false,
                hint = "0",
              ),
              text(id = "class_edit_ac_plus_label", text = " + ", style = "text"),
              select(
                id = "class_edit_ac_modifiers",
                stat = "ac_modifiers",
                options = "ability",
                multi_select = true,
              ),
            ],
          ),
          text(
            id = "class_edit_saving_throw_proficiencies_label",
            margin_top = 4,
            text = "Saving proficiencies by level:",
            style = "text",
            bold = true,
          ),
          resourceArray(
            id = "class_edit_fortitude_saving_throw_by_level",
            margin_top = 4,
            resource_id = "levelled_save_proficiency",
            stat = "fortitude_proficiency_per_level",
            view_type = "edit",
            left_view = text(
              id = "class_edit_fortitude_saving_throw_by_level_label",
              text = "Fortitude by level: ",
              style = "text",
              bold = true,
            ),
          ),
          resourceArray(
            id = "class_edit_reflex_saving_throw_by_level",
            margin_top = 4,
            resource_id = "levelled_save_proficiency",
            stat = "reflex_proficiency_per_level",
            view_type = "edit",
            left_view = text(
              id = "class_edit_reflex_saving_throw_by_level_label",
              text = "Reflex by level: ",
              style = "text",
              bold = true,
            ),
          ),
          resourceArray(
            id = "class_edit_will_saving_throw_by_level",
            margin_top = 4,
            resource_id = "levelled_save_proficiency",
            stat = "will_proficiency_per_level",
            view_type = "edit",
            left_view = text(
              id = "class_edit_will_saving_throw_by_level_label",
              text = "Will by level: ",
              style = "text",
              bold = true,
            ),
          ),
          resourceArray(
            id = "class_edit_perception_proficiency_by_level",
            margin_top = 4,
            resource_id = "levelled_save_proficiency",
            stat = "perception_proficiency_per_level",
            view_type = "edit",
            left_view = text(
              id = "class_edit_perception_proficiency_by_level_label",
              text = "Perception by level: ",
              style = "text",
              bold = true,
            ),
          ),
        ],
      ),
      list(
        id = "class_edit_features",
        padding = 16,
        subviews = [
          resourceArray(
            id = "class_edit_features",
            resource_id = "feat",
            stat = "features",
            view_type = "edit",
            left_view = text(
              id = "class_edit_features_label",
              text = "Features: ",
              style = "text",
              bold = true,
            ),
            pop_up_type = "bottomSheet",
            pop_up_button_text = levelled_description,
            validation_message = if !isEmpty(
              filter(
                $view.class_edit_features,
                filter = ($filterValue) => isEmpty($filterValue.name),
              ),
            )
              then "You have empty features. Please add some content to them or remove them."
              else null,
          ),
          resourceArray(
            id = "class_edit_progression_grants",
            margin_top = 8,
            resource_id = "progression_grant",
            stat = "progression_grants",
            view_type = "edit",
            left_view = text(
              id = "class_edit_progression_grants_label",
              text = "Progression grants: ",
              style = "text",
              bold = true,
            ),
            pop_up_type = "bottomSheet",
            pop_up_button_text = display_description,
          ),
          resourceArray(
            id = "class_edit_skill_increase_rank_caps",
            margin_top = 8,
            resource_id = "levelled_rank_cap",
            stat = "skill_increase_rank_caps",
            view_type = "edit",
            left_view = text(
              id = "class_edit_skill_increase_rank_caps_label",
              text = "Skill increase caps: ",
              style = "text",
              bold = true,
            ),
          ),
        ],
      ),
      list(
        id = "class_edit_spells",
        padding = 16,
        subviews = [
          composite(
            id = "class_edit_spellcasting_ability_composite",
            margin_bottom = 4,
            subviews = [
              text(
                id = "class_edit_spellcasting_ability_label",
                text = "Spellcasting Ability: ",
                style = "text",
                bold = true,
              ),
              select(
                id = "class_edit_spellcasting_ability_select",
                stat = "spellcasting_ability",
                options = "ability",
