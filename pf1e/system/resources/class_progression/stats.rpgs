base resource<class> class(name = "Class") = null;

base resource<deity> selected_deity(name = "Deity") = null;

base string selected_deity_font(name = "Selected deity font") = "";

base integer class_level(name = "Class level") = 1;

calc resource<class> class_effective(name = "Class (effective)") =
  $view?.class_progression_edit_class_select? ?? class;

calc integer class_level_effective(name = "Class level (effective)") =
  $view?.class_progression_edit_class_level? ?? class_level;

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_0(name = "Prepared cantrips") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_1(name = "Prepared rank 1 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_2(name = "Prepared rank 2 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_3(name = "Prepared rank 3 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_4(name = "Prepared rank 4 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_5(name = "Prepared rank 5 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_6(name = "Prepared rank 6 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_7(name = "Prepared rank 7 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_8(name = "Prepared rank 8 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_9(name = "Prepared rank 9 spells") =
  [];

base resource<prepared_spell_choice>[] prepared_spell_choices_rank_10(name = "Prepared rank 10 spells") =
  [];

base string[] selected_choice_bound_slot_spell_ids_rank_10(name = "Choice-bound slot spell IDs (rank 10)") =
  [];

base string[] selected_selectable_feature_ids(name = "Selected selectable feature ids") =
  [];

base string selected_class_key_ability(name = "Selected class key ability") = "";

base integer last_selection_level(name = "Last level in which the player selected proficiencies") =
  0;

calc bool should_select_on_level_up(name = "Should select new stuff on this level up") =
  $character.temp_last_level_up_class_id == (class?.id ?? "");

calc resource<archetype> selected_character_class_archetype(name = "Selected character class archetype") =
  if defined(stat = "$character") && notNull($character.class_archetype)
    then $character.class_archetype
    else null;

calc resource<archetype>[] selected_class_archetypes(name = "Selected class archetypes") =
  if !defined(stat = "$character")
    then []
    else if !($character.enable_optional_class_archetypes ?? false)
      then []
      else if isNull(selected_character_class_archetype)
        then []
        else if !(selected_character_class_archetype?.is_class_archetype ?? false)
          then []
          else if !isEmpty(selected_character_class_archetype?.required_class_id ?? "")
            && (selected_character_class_archetype?.required_class_id ?? "") != (class?.id ?? "")
            then []
            else [selected_character_class_archetype];

calc string selected_class_archetype_names(name = "Selected class archetype names") =
  joinToString(
    map(
      selected_class_archetypes,
      mapper = ($mapValue) => $mapValue.name,
    ),
    separator = ", ",
  );

calc string class_name_with_archetype(name = "Class name with archetype") =
  if isEmpty(selected_class_archetype_names)
    then (class?.name ?? "")
    else concat([(class?.name ?? ""), " (", selected_class_archetype_names, ")"]);

calc bool class_requires_deity(name = "Class requires deity") =
  class?.requires_deity ?? false;

calc resource<deity> active_selected_deity(name = "Active selected deity") =
  if class_requires_deity then selected_deity else null;

calc string selected_deity_name(name = "Selected deity name") =
  active_selected_deity?.name ?? "";

calc string active_selected_deity_font(name = "Active selected deity font") =
  if contains(
      haystack = (active_selected_deity?.font_options ?? []),
      needle = selected_deity_font,
    )
    then selected_deity_font
    else (findFirst(active_selected_deity?.font_options ?? [], filter = ($findFirstValue) => true) ?? "");

calc string selected_deity_font_text(name = "Selected deity font text") =
  if !isEmpty(active_selected_deity_font)
    then active_selected_deity_font
    else joinToString(active_selected_deity?.font_options ?? [], separator = ", ");

calc string selected_deity_associated_skill_text(name = "Selected deity associated skill text") =
  joinToString(active_selected_deity?.divine_skill_options ?? [], separator = ", ");

calc string selected_deity_favored_weapon_text(name = "Selected deity favored weapon text") =
  active_selected_deity?.display_favored_weapon ?? "";

calc string class_name_with_archetype_and_deity(name = "Class name with archetype and deity") =
  if class_requires_deity && !isEmpty(selected_deity_name)
    then concat([class_name_with_archetype, " (", selected_deity_name, ")"])
    else class_name_with_archetype;

calc bool show_spellcasting_details(name = "Should show spellcasting details") =
  (class?.actual_spellcasting_progression_kind ?? "none") != "none";

calc string class_name_with_spellcasting_ability(name = "Class name with spellcasting ability") =
  if isEmpty(class?.actual_spellcasting_ability ?? "")
    then (class?.name ?? "")
    else concat(
        [
          (class?.name ?? ""),
          " (",
          enumeratedAbbreviation(
            enumerated_type = "ability",
            id = class?.actual_spellcasting_ability ?? "",
          ),
          ")",
        ],
      );

calc string spellcasting_entry_name(name = "Spellcasting entry name") =
  class_name_with_spellcasting_ability;

calc integer this_class_effective_caster_level_for_slots(name = "This class effective caster level for slot calculation") =
  when {
    (class?.actual_spellcasting_progression_kind ?? "none") == "full" -> class_level,
    (class?.actual_spellcasting_progression_kind ?? "none") == "bounded" -> divide([class_level, 2], rounding_method = "up"),
    else -> 0,
  };

calc resource<levelled_amount> custom_slot_lookup_1(name = "Custom slot lookup rank 1") =
  findFirst(
    sortBy(class?.actual_spell_slots_level_1_per_level ?? [], order = "desc", sort_by_selector = ($v) => $v.level),
    filter = ($v) => ($v.level <= class_level),
  );

calc resource<levelled_amount> custom_slot_lookup_2(name = "Custom slot lookup rank 2") =
  findFirst(
    sortBy(class?.actual_spell_slots_level_2_per_level ?? [], order = "desc", sort_by_selector = ($v) => $v.level),
    filter = ($v) => ($v.level <= class_level),
  );

calc resource<levelled_amount> custom_slot_lookup_3(name = "Custom slot lookup rank 3") =
  findFirst(
    sortBy(class?.actual_spell_slots_level_3_per_level ?? [], order = "desc", sort_by_selector = ($v) => $v.level),
    filter = ($v) => ($v.level <= class_level),
  );

calc resource<levelled_amount> custom_slot_lookup_4(name = "Custom slot lookup rank 4") =
  findFirst(
    sortBy(class?.actual_spell_slots_level_4_per_level ?? [], order = "desc", sort_by_selector = ($v) => $v.level),
    filter = ($v) => ($v.level <= class_level),
  );

calc resource<levelled_amount> custom_slot_lookup_5(name = "Custom slot lookup rank 5") =
  findFirst(
    sortBy(class?.actual_spell_slots_level_5_per_level ?? [], order = "desc", sort_by_selector = ($v) => $v.level),
    filter = ($v) => ($v.level <= class_level),
  );

calc resource<levelled_amount> custom_slot_lookup_6(name = "Custom slot lookup rank 6") =
  findFirst(
    sortBy(class?.actual_spell_slots_level_6_per_level ?? [], order = "desc", sort_by_selector = ($v) => $v.level),
    filter = ($v) => ($v.level <= class_level),
  );

calc resource<levelled_amount> custom_slot_lookup_7(name = "Custom slot lookup rank 7") =
  findFirst(
    sortBy(class?.actual_spell_slots_level_7_per_level ?? [], order = "desc", sort_by_selector = ($v) => $v.level),
    filter = ($v) => ($v.level <= class_level),
  );

calc resource<levelled_amount> custom_slot_lookup_8(name = "Custom slot lookup rank 8") =
  findFirst(
    sortBy(class?.actual_spell_slots_level_8_per_level ?? [], order = "desc", sort_by_selector = ($v) => $v.level),
    filter = ($v) => ($v.level <= class_level),
  );

calc resource<levelled_amount> custom_slot_lookup_9(name = "Custom slot lookup rank 9") =
  findFirst(
    sortBy(class?.actual_spell_slots_level_9_per_level ?? [], order = "desc", sort_by_selector = ($v) => $v.level),
    filter = ($v) => ($v.level <= class_level),
  );

calc resource<spell_capacity_grant>[] active_spell_capacity_grants(name = "Active spell capacity grants") =
  filter(
    class?.actual_spell_capacity_grants ?? [],
    filter = ($filterValue) => ($filterValue.level <= class_level),
  );

calc resource<spell_capacity_grant>[] active_choice_bound_rank_10_slot_grants(name = "Active choice-bound rank 10 slot grants") =
  filter(
    active_spell_capacity_grants,
    filter = ($filterValue) => ($filterValue.capacity_type == "slot"
      && $filterValue.requires_spell_choice
      && $filterValue.choice_rank == 10
      && $filterValue.current_quantity > 0),
  );

calc string[] choice_bound_rank_10_spell_id_options(name = "Choice-bound rank 10 spell ID options") =
  flatAppend(
    map(
      filter(
        $character?.spells ?? [],
        filter = ($filterValue) => ($filterValue.level == "spell_level_10"
          && (
              isEmpty(class?.actual_spellcasting_tradition ?? "")
                || contains(
                  haystack = $filterValue.traditions,
                  needle = class?.actual_spellcasting_tradition ?? "",
                )
            )),
      ),
      mapper = ($mapValue) => [$mapValue.id],
    ),
    treat_as_set = true,
  );

calc integer required_choice_bound_rank_10_slot_spell_count(name = "Required choice-bound rank 10 spell count") =
  add(
    map(
      active_choice_bound_rank_10_slot_grants,
      mapper = ($mapValue) => max(
        [
          0,
          $mapValue.required_choice_count * $mapValue.current_quantity,
        ],
      ),
    ),
  );

calc integer selected_choice_bound_rank_10_slot_spell_count(name = "Selected choice-bound rank 10 spell count") =
  length(selected_choice_bound_slot_spell_ids_rank_10);

calc integer selected_choice_bound_rank_10_slot_unique_spell_count(name = "Selected unique choice-bound rank 10 spell count") =
  length(
    flatAppend(
      map(
        selected_choice_bound_slot_spell_ids_rank_10,
        mapper = ($mapValue) => [$mapValue],
      ),
      treat_as_set = true,
    ),
  );

calc resource<spell>[] selected_choice_bound_slot_spell_resources(name = "Selected choice-bound slot spell resources") =
  filter(
    map(
      selected_choice_bound_slot_spell_ids_rank_10,
      mapper = ($mapValue) => findFirst(
        $character?.spells ?? [],
        filter = ($findFirstValue) => $findFirstValue.id == $mapValue,
      ),
    ),
    filter = ($filterValue) => notNull($filterValue),
  );

calc string[] selected_choice_bound_slot_spell_names(name = "Selected choice-bound slot spell names") =
  filter(
    map(
      selected_choice_bound_slot_spell_resources,
      mapper = ($mapValue) => $mapValue.name,
    ),
    filter = ($filterValue) => !isEmpty($filterValue),
  );

calc bool has_choice_bound_rank_10_slot_selection_warning(name = "Has choice-bound rank 10 slot selection warning") =
  required_choice_bound_rank_10_slot_spell_count > 0
    && (
      selected_choice_bound_rank_10_slot_spell_count < required_choice_bound_rank_10_slot_spell_count
        || selected_choice_bound_rank_10_slot_unique_spell_count < selected_choice_bound_rank_10_slot_spell_count
    );

calc string choice_bound_rank_10_slot_selection_warning_text(name = "Choice-bound rank 10 slot selection warning text") =
  joinToString(
    flatAppend(
      [
        (if required_choice_bound_rank_10_slot_spell_count > 0
            && selected_choice_bound_rank_10_slot_spell_count < required_choice_bound_rank_10_slot_spell_count
          then [
              concat(
                [
                  "Choose ",
                  required_choice_bound_rank_10_slot_spell_count,
                  " rank-10 spell(s) for choice-bound bonus slots (currently ",
                  selected_choice_bound_rank_10_slot_spell_count,
                  ").",
                ],
              ),
            ]
          else []),
        (if selected_choice_bound_rank_10_slot_unique_spell_count < selected_choice_bound_rank_10_slot_spell_count
          then ["Choice-bound bonus slot spell selections contain duplicates."]
          else []),
      ],
    ),
    separator = "\n",
  );

calc resource<levelled_amount> class_cantrip_quantity_lookup(name = "Class cantrip quantity lookup row") =
  findFirst(
    sortBy(
      class?.actual_cantrip_quantity_per_level ?? [],
      order = "desc",
      sort_by_selector = ($sortByValue) => $sortByValue.level,
    ),
    filter = ($findFirstValue) => ($findFirstValue.level <= class_level),
  );

calc integer max_class_cantrip_quantity_base(name = "Max class cantrip quantity (base)") =
  class_cantrip_quantity_lookup?.amount ?? 0;

calc integer max_class_cantrip_quantity_grants(name = "Max class cantrip quantity (grants)") =
  add(
    map(
      filter(
        active_spell_capacity_grants,
        filter = ($filterValue) => ($filterValue.capacity_type == "cantrip"),
      ),
      mapper = ($mapValue) => $mapValue.current_quantity,
    ),
  );

calc integer max_class_cantrip_quantity(name = "Max class cantrip quantity") =
  max_class_cantrip_quantity_base + max_class_cantrip_quantity_grants;

calc integer max_class_spell_slots_1_base(name = "Max class rank 1 spell slots (base)") =
  when {
    (class?.actual_spellcasting_progression_kind ?? "none") == "custom" -> custom_slot_lookup_1?.amount ?? 0,
    (class?.actual_spellcasting_progression_kind ?? "none") != "full" && (class?.actual_spellcasting_progression_kind ?? "none") != "bounded" -> 0,
    this_class_effective_caster_level_for_slots == 0 -> 0,
    this_class_effective_caster_level_for_slots == 1 -> 2,
    this_class_effective_caster_level_for_slots == 2 -> 3,
    else -> 4,
  };

calc integer max_class_spell_slots_2_base(name = "Max class rank 2 spell slots (base)") =
  when {
    (class?.actual_spellcasting_progression_kind ?? "none") == "custom" -> custom_slot_lookup_2?.amount ?? 0,
    (class?.actual_spellcasting_progression_kind ?? "none") != "full" && (class?.actual_spellcasting_progression_kind ?? "none") != "bounded" -> 0,
    this_class_effective_caster_level_for_slots < 3 -> 0,
    this_class_effective_caster_level_for_slots == 3 -> 2,
    else -> 3,
  };

calc integer max_class_spell_slots_3_base(name = "Max class rank 3 spell slots (base)") =
  when {
    (class?.actual_spellcasting_progression_kind ?? "none") == "custom" -> custom_slot_lookup_3?.amount ?? 0,
    (class?.actual_spellcasting_progression_kind ?? "none") != "full" && (class?.actual_spellcasting_progression_kind ?? "none") != "bounded" -> 0,
    this_class_effective_caster_level_for_slots < 5 -> 0,
    this_class_effective_caster_level_for_slots == 5 -> 2,
    else -> 3,
  };

calc integer max_class_spell_slots_4_base(name = "Max class rank 4 spell slots (base)") =
  when {
    (class?.actual_spellcasting_progression_kind ?? "none") == "custom" -> custom_slot_lookup_4?.amount ?? 0,
    (class?.actual_spellcasting_progression_kind ?? "none") != "full" && (class?.actual_spellcasting_progression_kind ?? "none") != "bounded" -> 0,
    this_class_effective_caster_level_for_slots < 7 -> 0,
    this_class_effective_caster_level_for_slots == 7 -> 1,
    this_class_effective_caster_level_for_slots == 8 -> 2,
    else -> 3,
  };

calc integer max_class_spell_slots_5_base(name = "Max class rank 5 spell slots (base)") =
  when {
    (class?.actual_spellcasting_progression_kind ?? "none") == "custom" -> custom_slot_lookup_5?.amount ?? 0,
    (class?.actual_spellcasting_progression_kind ?? "none") != "full" && (class?.actual_spellcasting_progression_kind ?? "none") != "bounded" -> 0,
    this_class_effective_caster_level_for_slots < 9 -> 0,
    this_class_effective_caster_level_for_slots == 9 -> 1,
    this_class_effective_caster_level_for_slots < 18 -> 2,
    else -> 3,
  };

calc integer max_class_spell_slots_6_base(name = "Max class rank 6 spell slots (base)") =
  when {
    (class?.actual_spellcasting_progression_kind ?? "none") == "custom" -> custom_slot_lookup_6?.amount ?? 0,
    (class?.actual_spellcasting_progression_kind ?? "none") != "full" && (class?.actual_spellcasting_progression_kind ?? "none") != "bounded" -> 0,
    this_class_effective_caster_level_for_slots < 11 -> 0,
    this_class_effective_caster_level_for_slots < 19 -> 1,
    else -> 2,
  };

calc integer max_class_spell_slots_7_base(name = "Max class rank 7 spell slots (base)") =
  when {
    (class?.actual_spellcasting_progression_kind ?? "none") == "custom" -> custom_slot_lookup_7?.amount ?? 0,
    (class?.actual_spellcasting_progression_kind ?? "none") != "full" && (class?.actual_spellcasting_progression_kind ?? "none") != "bounded" -> 0,
    this_class_effective_caster_level_for_slots < 13 -> 0,
    this_class_effective_caster_level_for_slots < 20 -> 1,
    else -> 2,
  };

calc integer max_class_spell_slots_8_base(name = "Max class rank 8 spell slots (base)") =
  when {
    (class?.actual_spellcasting_progression_kind ?? "none") == "custom" -> custom_slot_lookup_8?.amount ?? 0,
    (class?.actual_spellcasting_progression_kind ?? "none") != "full" && (class?.actual_spellcasting_progression_kind ?? "none") != "bounded" -> 0,
    else -> (if this_class_effective_caster_level_for_slots < 15 then 0 else 1),
  };

calc integer max_class_spell_slots_9_base(name = "Max class rank 9 spell slots (base)") =
  when {
    (class?.actual_spellcasting_progression_kind ?? "none") == "custom" -> custom_slot_lookup_9?.amount ?? 0,
    (class?.actual_spellcasting_progression_kind ?? "none") != "full" && (class?.actual_spellcasting_progression_kind ?? "none") != "bounded" -> 0,
    else -> (if this_class_effective_caster_level_for_slots < 17 then 0 else 1),
  };

calc integer highest_base_spell_slot_rank(name = "Highest base spell slot rank") =
  when {
    max_class_spell_slots_9_base > 0 -> 9,
    max_class_spell_slots_8_base > 0 -> 8,
    max_class_spell_slots_7_base > 0 -> 7,
    max_class_spell_slots_6_base > 0 -> 6,
    max_class_spell_slots_5_base > 0 -> 5,
    max_class_spell_slots_4_base > 0 -> 4,
    max_class_spell_slots_3_base > 0 -> 3,
    max_class_spell_slots_2_base > 0 -> 2,
    max_class_spell_slots_1_base > 0 -> 1,
    else -> 0,
  };

calc integer max_class_spell_slots_1_grants(name = "Max class rank 1 spell slots (grants)") =
  add(
    map(
      filter(
        active_spell_capacity_grants,
        filter = ($g) => $g.capacity_type == "slot"
          && (
              ($g.target_rank_mode == "specific" && $g.target_rank == 1)
                || ($g.target_rank_mode == "highest_available" && highest_base_spell_slot_rank == 1)
            ),
      ),
      mapper = ($g) => $g.current_quantity,
    ),
  );

calc integer max_class_spell_slots_2_grants(name = "Max class rank 2 spell slots (grants)") =
  add(
    map(
      filter(
        active_spell_capacity_grants,
        filter = ($g) => $g.capacity_type == "slot"
          && (
              ($g.target_rank_mode == "specific" && $g.target_rank == 2)
                || ($g.target_rank_mode == "highest_available" && highest_base_spell_slot_rank == 2)
            ),
      ),
      mapper = ($g) => $g.current_quantity,
    ),
  );

