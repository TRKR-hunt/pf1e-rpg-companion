calc integer max_class_spell_slots_10_grants(name = "Max class rank 10 spell slots (grants)") =
  add(
    map(
      filter(
        active_spell_capacity_grants,
        filter = ($g) => $g.capacity_type == "slot"
          && ($g.target_rank_mode == "specific" && $g.target_rank == 10),
      ),
      mapper = ($g) => $g.current_quantity,
    ),
  );

calc integer max_class_spell_slots_1(name = "Max class rank 1 spell slots") =
  max_class_spell_slots_1_base + max_class_spell_slots_1_grants;

calc integer max_class_spell_slots_2(name = "Max class rank 2 spell slots") =
  max_class_spell_slots_2_base + max_class_spell_slots_2_grants;

calc integer max_class_spell_slots_3(name = "Max class rank 3 spell slots") =
  max_class_spell_slots_3_base + max_class_spell_slots_3_grants;

calc integer max_class_spell_slots_4(name = "Max class rank 4 spell slots") =
  max_class_spell_slots_4_base + max_class_spell_slots_4_grants;

calc integer max_class_spell_slots_5(name = "Max class rank 5 spell slots") =
  max_class_spell_slots_5_base + max_class_spell_slots_5_grants;

calc integer max_class_spell_slots_6(name = "Max class rank 6 spell slots") =
  max_class_spell_slots_6_base + max_class_spell_slots_6_grants;

calc integer max_class_spell_slots_7(name = "Max class rank 7 spell slots") =
  max_class_spell_slots_7_base + max_class_spell_slots_7_grants;

calc integer max_class_spell_slots_8(name = "Max class rank 8 spell slots") =
  max_class_spell_slots_8_base + max_class_spell_slots_8_grants;

calc integer max_class_spell_slots_9(name = "Max class rank 9 spell slots") =
  max_class_spell_slots_9_base + max_class_spell_slots_9_grants;

calc integer max_class_spell_slots_10(name = "Max class rank 10 spell slots") =
  max_class_spell_slots_10_grants;

calc integer spellcasting_proficiency_bonus(name = "Spellcasting proficiency bonus") =
  when {
    (class?.current_level_spellcasting_proficiency ?? "none") == "trained" -> $character.level_bonus + 2,
    (class?.current_level_spellcasting_proficiency ?? "none") == "expert" -> $character.level_bonus + 4,
    (class?.current_level_spellcasting_proficiency ?? "none") == "master" -> $character.level_bonus + 6,
    (class?.current_level_spellcasting_proficiency ?? "none") == "legendary" -> $character.level_bonus + 8,
    else -> 0,
  };

calc integer spell_attack_bonus(name = "Spell attack bonus") =
  if isEmpty(class?.actual_spellcasting_ability ?? "")
    then 0
    else metaStat(
        meta_stat = concat(
          [
            "$character.",
            class?.actual_spellcasting_ability ?? "",
            "_modifier",
          ],
        ),
      ) + spellcasting_proficiency_bonus + $character.spell_attack_typed_modifier_total;

calc string spell_attack_bonus_text(name = "Spell attack bonus formatted") =
  if spell_attack_bonus >= 0
    then concat(["+", spell_attack_bonus])
    else "" + spell_attack_bonus;

calc integer spell_save_dc(name = "Spell save DC") =
  if isEmpty(class?.actual_spellcasting_ability ?? "")
    then 0
    else 10 + metaStat(
        meta_stat = concat(
          [
            "$character.",
            class?.actual_spellcasting_ability ?? "",
            "_modifier",
          ],
        ),
      ) + spellcasting_proficiency_bonus + $character.spell_dc_typed_modifier_total;

calc integer class_level_hp_gain(name = "Class level HP gain") =
  (class?.actual_class_hp_per_level ?? 0) + add(
    map(
      class?.actual_hp_modifiers ?? [],
      mapper = ($mapValue) => metaStat(
        meta_stat = concat(["$character.", $mapValue, "_modifier"]),
      ),
    ),
  );

calc bool should_show_level_up_disclaimer(name = "Should show level up disclaimer") =
  !($character?.$is_new? ?? true)
    && ($view?.class_progression_edit_class_level? ?? 1) > class_level;

calc resource<feat>[] features(name = "Features") =
  sortBy(
    class?.current_level_features ?? [],
    sort_by_selector = ($sortByValue) => $sortByValue.min_level,
  );

calc resource<progression_grant>[] active_progression_grants(name = "Active progression grants") =
  filter(
    (class?.progression_grants ?? []),
    filter = ($filterValue) => ($filterValue.level <= class_level),
  );

calc resource<progression_grant>[] progression_grants_gained_in_level(name = "Progression grants gained in level") =
  filter(
    (class?.progression_grants ?? []),
    filter = ($filterValue) => ($filterValue.level == class_level),
  );

calc resource<levelled_rank_cap>[] active_skill_increase_rank_caps(name = "Active skill increase rank caps") =
  filter(
    (class?.skill_increase_rank_caps ?? []),
    filter = ($filterValue) => ($filterValue.level <= class_level),
  );

calc resource<prepared_spell_choice>[] all_prepared_spell_choices(name = "All prepared spell choices") =
  flatAppend(
    [
      prepared_spell_choices_rank_0,
      prepared_spell_choices_rank_1,
      prepared_spell_choices_rank_2,
      prepared_spell_choices_rank_3,
      prepared_spell_choices_rank_4,
      prepared_spell_choices_rank_5,
      prepared_spell_choices_rank_6,
      prepared_spell_choices_rank_7,
      prepared_spell_choices_rank_8,
      prepared_spell_choices_rank_9,
      prepared_spell_choices_rank_10,
    ],
  );

calc integer prepared_cantrip_quantity(name = "Prepared cantrip quantity") =
  add(
    map(
      prepared_spell_choices_rank_0,
      mapper = ($mapValue) => $mapValue.effective_slot_quantity,
    ),
  );

calc integer prepared_rank_1_quantity(name = "Prepared rank 1 quantity") =
  add(map(prepared_spell_choices_rank_1, mapper = ($mapValue) => $mapValue.effective_slot_quantity));

calc integer prepared_rank_2_quantity(name = "Prepared rank 2 quantity") =
  add(map(prepared_spell_choices_rank_2, mapper = ($mapValue) => $mapValue.effective_slot_quantity));

calc integer prepared_rank_3_quantity(name = "Prepared rank 3 quantity") =
  add(map(prepared_spell_choices_rank_3, mapper = ($mapValue) => $mapValue.effective_slot_quantity));

calc integer prepared_rank_4_quantity(name = "Prepared rank 4 quantity") =
  add(map(prepared_spell_choices_rank_4, mapper = ($mapValue) => $mapValue.effective_slot_quantity));

calc integer prepared_rank_5_quantity(name = "Prepared rank 5 quantity") =
  add(map(prepared_spell_choices_rank_5, mapper = ($mapValue) => $mapValue.effective_slot_quantity));

calc integer prepared_rank_6_quantity(name = "Prepared rank 6 quantity") =
  add(map(prepared_spell_choices_rank_6, mapper = ($mapValue) => $mapValue.effective_slot_quantity));

calc integer prepared_rank_7_quantity(name = "Prepared rank 7 quantity") =
  add(map(prepared_spell_choices_rank_7, mapper = ($mapValue) => $mapValue.effective_slot_quantity));

calc integer prepared_rank_8_quantity(name = "Prepared rank 8 quantity") =
  add(map(prepared_spell_choices_rank_8, mapper = ($mapValue) => $mapValue.effective_slot_quantity));

calc integer prepared_rank_9_quantity(name = "Prepared rank 9 quantity") =
  add(map(prepared_spell_choices_rank_9, mapper = ($mapValue) => $mapValue.effective_slot_quantity));

calc integer prepared_rank_10_quantity(name = "Prepared rank 10 quantity") =
  add(map(prepared_spell_choices_rank_10, mapper = ($mapValue) => $mapValue.effective_slot_quantity));

calc integer prepared_cantrip_overspent(name = "Prepared cantrip overspent amount") =
  max([0, prepared_cantrip_quantity - max_class_cantrip_quantity]);

calc integer prepared_rank_1_overspent(name = "Prepared rank 1 overspent amount") =
  max([0, prepared_rank_1_quantity - max_class_spell_slots_1]);

calc integer prepared_rank_2_overspent(name = "Prepared rank 2 overspent amount") =
  max([0, prepared_rank_2_quantity - max_class_spell_slots_2]);

calc integer prepared_rank_3_overspent(name = "Prepared rank 3 overspent amount") =
  max([0, prepared_rank_3_quantity - max_class_spell_slots_3]);

calc integer prepared_rank_4_overspent(name = "Prepared rank 4 overspent amount") =
  max([0, prepared_rank_4_quantity - max_class_spell_slots_4]);

calc integer prepared_rank_5_overspent(name = "Prepared rank 5 overspent amount") =
  max([0, prepared_rank_5_quantity - max_class_spell_slots_5]);

calc integer prepared_rank_6_overspent(name = "Prepared rank 6 overspent amount") =
  max([0, prepared_rank_6_quantity - max_class_spell_slots_6]);

calc integer prepared_rank_7_overspent(name = "Prepared rank 7 overspent amount") =
  max([0, prepared_rank_7_quantity - max_class_spell_slots_7]);

calc integer prepared_rank_8_overspent(name = "Prepared rank 8 overspent amount") =
  max([0, prepared_rank_8_quantity - max_class_spell_slots_8]);

calc integer prepared_rank_9_overspent(name = "Prepared rank 9 overspent amount") =
  max([0, prepared_rank_9_quantity - max_class_spell_slots_9]);

calc integer prepared_rank_10_overspent(name = "Prepared rank 10 overspent amount") =
  max([0, prepared_rank_10_quantity - max_class_spell_slots_10]);

calc string prepared_capacity_warning_text(name = "Prepared capacity warning text") =
  joinToString(
    flatAppend(
      [
        (if has_choice_bound_rank_10_slot_selection_warning
          then [choice_bound_rank_10_slot_selection_warning_text]
          else []),
        (if class?.actual_spellcasting_mode == "prepared" && prepared_cantrip_overspent > 0
          then [
              concat(
                [
                  "Prepared cantrips exceed class cap by ",
                  prepared_cantrip_overspent,
                  ".",
                ],
              ),
            ]
          else []),
        (if class?.actual_spellcasting_mode == "prepared" && prepared_rank_1_overspent > 0
          then [concat(["Prepared rank 1 spells exceed slots by ", prepared_rank_1_overspent, "."])]
          else []),
        (if class?.actual_spellcasting_mode == "prepared" && prepared_rank_2_overspent > 0
          then [concat(["Prepared rank 2 spells exceed slots by ", prepared_rank_2_overspent, "."])]
          else []),
        (if class?.actual_spellcasting_mode == "prepared" && prepared_rank_3_overspent > 0
          then [concat(["Prepared rank 3 spells exceed slots by ", prepared_rank_3_overspent, "."])]
          else []),
        (if class?.actual_spellcasting_mode == "prepared" && prepared_rank_4_overspent > 0
          then [concat(["Prepared rank 4 spells exceed slots by ", prepared_rank_4_overspent, "."])]
          else []),
        (if class?.actual_spellcasting_mode == "prepared" && prepared_rank_5_overspent > 0
          then [concat(["Prepared rank 5 spells exceed slots by ", prepared_rank_5_overspent, "."])]
          else []),
        (if class?.actual_spellcasting_mode == "prepared" && prepared_rank_6_overspent > 0
          then [concat(["Prepared rank 6 spells exceed slots by ", prepared_rank_6_overspent, "."])]
          else []),
        (if class?.actual_spellcasting_mode == "prepared" && prepared_rank_7_overspent > 0
          then [concat(["Prepared rank 7 spells exceed slots by ", prepared_rank_7_overspent, "."])]
          else []),
        (if class?.actual_spellcasting_mode == "prepared" && prepared_rank_8_overspent > 0
          then [concat(["Prepared rank 8 spells exceed slots by ", prepared_rank_8_overspent, "."])]
          else []),
        (if class?.actual_spellcasting_mode == "prepared" && prepared_rank_9_overspent > 0
          then [concat(["Prepared rank 9 spells exceed slots by ", prepared_rank_9_overspent, "."])]
          else []),
        (if class?.actual_spellcasting_mode == "prepared" && prepared_rank_10_overspent > 0
          then [concat(["Prepared rank 10 spells exceed slots by ", prepared_rank_10_overspent, "."])]
          else []),
      ],
    ),
    separator = "\n",
  );
