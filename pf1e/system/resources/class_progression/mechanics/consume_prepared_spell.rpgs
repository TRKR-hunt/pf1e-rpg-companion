            filter = ($choice) => ($choice.spell_id == ($character.temp_spell_cast_spell_id ?? "")
              && $choice.used_quantity < $choice.effective_slot_quantity),
          ),
        ],
        for_each_value_key = "$choice",
        apply = addToStat(stat = "$choice.used_quantity", value = 1, aggregation_type = "set"),
      ),
    $character.temp_spell_cast_rank == 5 && notNull(
      findFirst(
        prepared_spell_choices_rank_5,
        filter = ($choice) => ($choice.spell_id == ($character.temp_spell_cast_spell_id ?? "")
