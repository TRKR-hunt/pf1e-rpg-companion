base string name(name = "Name") = "";

base string source(name = "Source") = "";

base string level(name = "Rank") = "spell_level_0";

base string school(name = "School") = "spell_school_abjuration";

base string[] traditions(name = "Traditions") = [];

base bool ritual(name = "Ritual") = false;

base string casting_time(name = "Casting time") = "";

base string action_cost(name = "Action cost") = "activity";

calc string display_casting_time(name = "Display casting time") =
  if ritual then concat([casting_time, " or ritual"]) else casting_time;

calc string action_cost_name(name = "Action cost name") =
  enumeratedName(enumerated_type = "feat_action_costs", id = action_cost);

calc string action_cost_icon_name(name = "Action cost icon name") =
  when {
    action_cost == "one_action" -> "ic_action",
    action_cost == "two_actions" -> "ic_two_actions",
    action_cost == "three_actions" -> "ic_three_actions",
    action_cost == "reaction" -> "ic_reaction",
    action_cost == "free_action" -> "ic_free_action",
    else -> "",
  };

base string range(name = "Range") = "";

base string duration(name = "Duration") = "";

base string saving_throw(name = "Saving throw") = "";

base string area(name = "Area") = "";

base string targets(name = "Targets") = "";

base bool verbal(name = "Verbal") = false;

base bool somatic(name = "Somatic") = false;

base bool material(name = "Material") = false;

base string components(name = "Components") = "";

base string description(name = "Description") = "";

base string higher_level_description(name = "Higher level description") = "";

base string[] classes(name = "Classes") = [];

base string[] spell_traits(name = "Spell traits") = [];

base resource<levelled_damage_dice>[] dice(name = "Dice") = [];

base resource<effect>[] effects(name = "Effects") = [];

base bool prepared(name = "Prepared") = false;

base bool is_focus_spell(name = "Is focus spell") = false;

base integer focus_point_cost(name = "Focus point cost") = 1;

base integer cast_level(name = "Cast rank") = 1;

base string selected_spellcasting_class_id(name = "Selected spellcasting class id") =
  "";

base string selected_spellcasting_source_id(name = "Selected spellcasting source id") =
  "";

base string selected_spellcasting_source_kind(name = "Selected spellcasting source kind") =
  "";

base string spellcasting_mode(name = "Spellcasting mode override") = "prepared";

base string spellcasting_ability(name = "Spellcasting ability override") = "intelligence";

base integer spell_attack_bonus(name = "Spell attack bonus override") = 0;

base integer spell_save_dc(name = "Spell save DC override") = 0;

calc bool is_cantrip(name = "Is cantrip") = level == "spell_level_0";

calc integer num_level(name = "Numerical rank") =
  toNum(replace(string = level, occurrence = "spell_level_", replace = ""));

calc bool has_higher_level_description(name = "Has higher level description") =
  length(higher_level_description) > 0;

calc bool has_saving_throw(name = "Has saving throw") = length(saving_throw) > 0;

calc bool has_area(name = "Has area") = length(area) > 0;

calc bool has_targets(name = "Has targets") = length(targets) > 0;

calc bool has_damage_dice(name = "Has damage dice") = !isEmpty(dice);

calc bool has_active_effects(name = "Has active effects") =
  !isEmpty(
    filter(
      effects,
      filter = ($filterValue) => $filterValue.is_active
        && $filterValue.type != "roll"
        && $filterValue.type != "roll_dice",
    ),
  );

calc bool should_show_damage_or_effects_button(name = "Should show damage/effects button") =
  has_damage_dice || has_active_effects;

calc string damage_or_effects_button_text(name = "Damage/effects button text") =
  if has_damage_dice then "DAMAGE" else "TRIGGER EFFECTS";

calc string display_traditions(name = "Display traditions") =
  joinToString(
    map(traditions, mapper = ($mapValue) => enumeratedName(enumerated_type = "spell_traditions", id = $mapValue)),
    separator = ", ",
  );

calc string display_type(name = "Type") =
  concat(
    [
      enumeratedName(enumerated_type = "spell_level", id = level),
      (if school != "none" then concat([" ", enumeratedName(enumerated_type = "spell_school", id = school)]) else ""),
      (if !isEmpty(traditions) then concat([" (", display_traditions, ")"]) else ""),
    ],
  );

calc string string_components(name = "Stringified components VSM") =
  joinToString(
    flatAppend(
      [
        (if true == verbal then ["V"] else []),
        (if true == somatic then ["S"] else []),
        (if true == material then ["M"] else []),
      ],
    ),
    separator = ", ",
  );

calc bool has_components(name = "Has components VSM") =
  verbal || somatic || material;

calc string display_requirements(name = "Requirements") =
  concat(
    [
      casting_time,
      (if has_components then concat([" (", string_components, ")"]) else ""),
    ],
  );

calc string full_components(name = "Full components") =
  if material
    then concat([string_components, " (", components, ")"])
    else string_components;

calc bool is_monster_spell_context(name = "Is monster spell context") =
  defined(stat = "$parent.$parent.spell_dc")
    || defined(stat = "$parent.$parent.$parent.spell_dc");

calc bool is_character_spell_context(name = "Is character spell context") =
  defined(stat = "$character") && !is_monster_spell_context;

calc bool is_effect_use_spell_free_cast(name = "Is effect use-spell free-cast context") =
  ($parent?.type? ?? "") == "use_spell";

calc integer monster_context_spell_attack_bonus(name = "Monster context spell attack bonus") =
  when {
    defined(stat = "$parent.$parent.spell_attack_bonus") -> $parent.$parent.spell_attack_bonus,
    defined(stat = "$parent.$parent.$parent.spell_attack_bonus") -> $parent.$parent.$parent.spell_attack_bonus,
    else -> spell_attack_bonus,
  };

calc integer monster_context_spell_dc(name = "Monster context spell DC") =
  when {
    defined(stat = "$parent.$parent.spell_dc") -> $parent.$parent.spell_dc,
    defined(stat = "$parent.$parent.$parent.spell_dc") -> $parent.$parent.$parent.spell_dc,
    else -> spell_save_dc,
  };

calc string monster_context_spellcasting_mode(name = "Monster context spellcasting mode") =
  when {
    defined(stat = "$parent.$parent.spellcasting_type") -> $parent.$parent.spellcasting_type,
    defined(stat = "$parent.$parent.$parent.spellcasting_type") -> $parent.$parent.$parent.spellcasting_type,
    else -> spellcasting_mode,
  };

calc integer monster_context_entry_level(name = "Monster context entry level") =
  if ($parent?.cast_level_override? ?? 0) > 0
    then $parent?.cast_level_override? ?? 0
    else $parent?.level? ?? num_level;

calc integer monster_context_daily_cast_max(name = "Monster context daily cast max") =
  if defined(stat = "$parent.daily_cast_max")
    then $parent.daily_cast_max
    else 0;

calc integer monster_context_daily_casts_remaining(name = "Monster context daily casts remaining") =
  if defined(stat = "$parent.casts_remaining_today")
    then $parent.casts_remaining_today
    else if monster_context_daily_cast_max > 0
      then monster_context_daily_cast_max
      else -1;

calc bool monster_context_has_daily_cast_limit(name = "Monster context has daily cast limit") =
  monster_context_daily_cast_max > 0;

calc bool monster_context_has_remaining_casts(name = "Monster context has remaining casts") =
  !monster_context_has_daily_cast_limit || monster_context_daily_casts_remaining > 0;

calc string monster_context_casts_remaining_text(name = "Monster context casts remaining text") =
  concat(
    [
      "Casts remaining today: ",
      monster_context_daily_casts_remaining,
      " / ",
      monster_context_daily_cast_max,
    ],
  );

calc resource<class_progression>[] character_spellcasting_classes(name = "Character spellcasting classes") =
  if defined(stat = "$character")
    then filter(
        $character.classes,
        filter = ($filterValue) => $filterValue.show_spellcasting_details,
      )
    else [];

calc resource<class_progression>[] spell_matching_class_sources(name = "Spell matching class sources") =
  filter(
    character_spellcasting_classes,
    filter = ($filterValue) => (
        notNull(
          findFirst(
            filter(
              $filterValue.class.all_spells,
              filter = ($filterValue2) => ($filterValue2.level <= ($character?.level? ?? 1)),
            ),
            filter = ($findFirstValue) => ($findFirstValue.spell.id == id),
          ),
        )
          || ($filterValue.class.actual_spellcasting_mode == "prepared"
            && !isEmpty($filterValue.class.actual_spellcasting_tradition)
            && contains(
              haystack = traditions,
              needle = $filterValue.class.actual_spellcasting_tradition,
            ))
      ),
  );

calc resource<levelled_spell>[] character_ancestry_levelled_spells(name = "Character ancestry levelled spells") =
  if defined(stat = "$character")
    then flatAppend(
        [
          ($character.ancestry?.spells ?? []),
          ($character.ancestry?.selected_heritage?.spells ?? []),
        ],
      )
    else [];

calc bool spell_has_specific_ancestry_source(name = "Spell has specific ancestry source") =
  !isEmpty(character_ancestry_levelled_spells)
    && isEmpty(spell_matching_class_sources)
    && notNull(
      findFirst(
        filter(
          character_ancestry_levelled_spells,
          filter = ($filterValue) => ($filterValue.level <= ($character?.level ?? 1)),
        ),
        filter = ($findFirstValue) => ($findFirstValue.spell.id == id),
      ),
    );

calc bool spell_has_specific_class_source(name = "Spell has specific class source") =
  !spell_has_specific_ancestry_source
    && length(spell_matching_class_sources) == 1
    && isEmpty($character?.spellcasting_archetypes ?? []);

calc resource<class_progression>[] selectable_spellcasting_class_sources(name = "Selectable spellcasting class sources") =
  if !isEmpty(spell_matching_class_sources)
    then spell_matching_class_sources
    else character_spellcasting_classes;

calc string[] selectable_spellcasting_class_source_ids(name = "Selectable spellcasting class source ids") =
  map(selectable_spellcasting_class_sources, mapper = ($mapValue) => $mapValue.id);

calc string[] selectable_spellcasting_archetype_source_ids(name = "Selectable spellcasting archetype source ids") =
  map($character?.spellcasting_archetypes ?? [], mapper = ($mapValue) => $mapValue.id);

calc string raw_view_or_saved_source_id(name = "Raw view or saved source id") =
  if !isEmpty(selected_spellcasting_source_id)
    then selected_spellcasting_source_id
    else selected_spellcasting_class_id;

calc string resolved_spellcasting_source_kind(name = "Resolved spellcasting source kind") =
  when {
    selected_spellcasting_source_kind == "class" || selected_spellcasting_source_kind == "archetype" -> selected_spellcasting_source_kind,
    contains(haystack = selectable_spellcasting_archetype_source_ids, needle = raw_view_or_saved_source_id) -> "archetype",
    contains(haystack = selectable_spellcasting_class_source_ids, needle = raw_view_or_saved_source_id) -> "class",
    isEmpty(selectable_spellcasting_class_source_ids) && !isEmpty(selectable_spellcasting_archetype_source_ids) -> "archetype",
    else -> "class",
  };

calc string[] selectable_spellcasting_source_kind_allowed_options(name = "Selectable spellcasting source kind allowed options") =
  flatAppend(
    [
      (if !isEmpty(selectable_spellcasting_class_source_ids) then ["class"] else []),
      (if !isEmpty(selectable_spellcasting_archetype_source_ids) then ["archetype"] else []),
    ],
  );

// Resolved view-or-saved source id (supports both old selected_spellcasting_class_id and new selected_spellcasting_source_id)
calc string view_or_saved_source_id(name = "View or saved source id") =
  when {
    resolved_spellcasting_source_kind == "archetype" && contains(haystack = selectable_spellcasting_archetype_source_ids, needle = raw_view_or_saved_source_id)
      -> raw_view_or_saved_source_id,
    resolved_spellcasting_source_kind == "archetype"
      -> (findFirst(
            selectable_spellcasting_archetype_source_ids,
            filter = ($findFirstValue) => true,
          ) ?? ""),
    resolved_spellcasting_source_kind == "class" && contains(haystack = selectable_spellcasting_class_source_ids, needle = raw_view_or_saved_source_id)
      -> raw_view_or_saved_source_id,
    resolved_spellcasting_source_kind == "class"
      -> (findFirst(
            selectable_spellcasting_class_source_ids,
            filter = ($findFirstValue) => true,
          ) ?? ""),
    else
      -> (findFirst(
            flatAppend(
              [
                selectable_spellcasting_class_source_ids,
                selectable_spellcasting_archetype_source_ids,
              ],
            ),
            filter = ($findFirstValue) => true,
          ) ?? ""),
  };

calc string resolved_spellcasting_class_source_id(name = "Resolved spellcasting class source id") =
  if spell_has_specific_class_source
    then findFirst(
        map(spell_matching_class_sources, mapper = ($mapValue) => $mapValue.id),
        filter = ($findFirstValue) => true,
      )
    else if contains(
      haystack = selectable_spellcasting_class_source_ids,
      needle = view_or_saved_source_id,
    )
    then view_or_saved_source_id
    else (findFirst(
          selectable_spellcasting_class_source_ids,
          filter = ($findFirstValue) => true,
        ) ?? "");

calc resource<class_progression> selected_spellcasting_class_source(name = "Selected spellcasting class source") =
  findFirst(
    selectable_spellcasting_class_sources,
    filter = ($findFirstValue) => ($findFirstValue.id == resolved_spellcasting_class_source_id),
  );

calc resource<archetype> selected_spellcasting_archetype_source(name = "Selected spellcasting archetype source") =
  findFirst(
    $character?.spellcasting_archetypes ?? [],
    filter = ($a) => $a.id == view_or_saved_source_id,
  );

calc bool is_archetype_spell(name = "Is archetype spell") =
  notNull(selected_spellcasting_archetype_source);

calc bool is_class_spell(name = "Is class spell") = !is_archetype_spell;

calc integer total_spellcasting_sources(name = "Total spellcasting sources") =
  length(selectable_spellcasting_class_sources) + length($character?.spellcasting_archetypes ?? []);

calc string ancestry_spellcasting_ability(name = "Ancestry spellcasting ability") =
  $character?.ancestry?.actual_spellcasting_ability ?? "intelligence";

calc string selected_spellcasting_source_name(name = "Selected spellcasting source name") =
  when {
    spell_has_specific_ancestry_source -> concat(
      [
        "Ancestry (",
        enumeratedAbbreviation(
          enumerated_type = "ability",
          id = ancestry_spellcasting_ability,
        ),
        ")",
      ],
    ),
    is_archetype_spell -> selected_spellcasting_archetype_source.spellcasting_entry_name,
    notNull(selected_spellcasting_class_source) -> selected_spellcasting_class_source.class_name_with_spellcasting_ability,
    else -> "",
  };

calc bool should_show_spellcasting_source_select(name = "Should show spellcasting source select") =
  is_character_spell_context
    && !spell_has_specific_ancestry_source
    && !spell_has_specific_class_source
    && total_spellcasting_sources > 1;

calc bool should_show_spellcasting_source_text(name = "Should show spellcasting source text") =
  is_character_spell_context
    && !isEmpty(selected_spellcasting_source_name)
    && !should_show_spellcasting_source_select;

calc string selected_spellcasting_mode(name = "Selected spellcasting mode") =
  when {
    is_monster_spell_context -> monster_context_spellcasting_mode,
    spell_has_specific_ancestry_source -> "spontaneous",
    is_archetype_spell -> selected_spellcasting_archetype_source.actual_spellcasting_mode,
    notNull(selected_spellcasting_class_source) -> selected_spellcasting_class_source.class.actual_spellcasting_mode,
    else -> spellcasting_mode,
  };

calc string selected_spellcasting_mode_name(name = "Selected spellcasting mode name") =
  enumeratedName(
    enumerated_type = "spellcasting_modes",
    id = selected_spellcasting_mode,
  );

calc integer selected_class_spellcasting_proficiency_bonus(name = "Selected class spellcasting proficiency bonus") =
  when {
    is_archetype_spell -> selected_spellcasting_archetype_source.spellcasting_proficiency_bonus,
    notNull(selected_spellcasting_class_source) -> selected_spellcasting_class_source.spellcasting_proficiency_bonus,
    else -> 0,
  };

calc string selected_spellcasting_tradition_for_proficiency(name = "Selected spellcasting tradition for proficiency") =
  when {
    spell_has_specific_ancestry_source -> findFirst(traditions, filter = ($findFirstValue) => true)
      ?? "none",
    is_archetype_spell -> selected_spellcasting_archetype_source.actual_spellcasting_tradition,
    notNull(selected_spellcasting_class_source) -> selected_spellcasting_class_source.class.actual_spellcasting_tradition,
    length(traditions) == 1 -> (findFirst(traditions, filter = ($findFirstValue) => true) ?? "none"),
    else -> "none",
  };

calc integer global_spellcasting_granted_proficiency_rank(name = "Global spellcasting granted proficiency rank") =
  when {
    !defined(stat = "$character.spellcasting_proficiency") -> 0,
    $character.spellcasting_proficiency == "trained" -> 1,
    $character.spellcasting_proficiency == "expert" -> 2,
    $character.spellcasting_proficiency == "master" -> 3,
    $character.spellcasting_proficiency == "legendary" -> 4,
    else -> 0,
  };

calc integer tradition_spellcasting_granted_proficiency_rank(name = "Tradition spellcasting granted proficiency rank") =
  when {
    !defined(stat = "$character") -> 0,
    selected_spellcasting_tradition_for_proficiency == "arcane" && defined(stat = "$character.arcane_spellcasting_proficiency")
      && $character.arcane_spellcasting_proficiency == "trained" -> 1,
    selected_spellcasting_tradition_for_proficiency == "arcane" && defined(stat = "$character.arcane_spellcasting_proficiency")
      && $character.arcane_spellcasting_proficiency == "expert" -> 2,
    selected_spellcasting_tradition_for_proficiency == "arcane" && defined(stat = "$character.arcane_spellcasting_proficiency")
      && $character.arcane_spellcasting_proficiency == "master" -> 3,
    selected_spellcasting_tradition_for_proficiency == "arcane" && defined(stat = "$character.arcane_spellcasting_proficiency")
      && $character.arcane_spellcasting_proficiency == "legendary" -> 4,
    selected_spellcasting_tradition_for_proficiency == "divine" && defined(stat = "$character.divine_spellcasting_proficiency")
      && $character.divine_spellcasting_proficiency == "trained" -> 1,
    selected_spellcasting_tradition_for_proficiency == "divine" && defined(stat = "$character.divine_spellcasting_proficiency")
      && $character.divine_spellcasting_proficiency == "expert" -> 2,
    selected_spellcasting_tradition_for_proficiency == "divine" && defined(stat = "$character.divine_spellcasting_proficiency")
      && $character.divine_spellcasting_proficiency == "master" -> 3,
    selected_spellcasting_tradition_for_proficiency == "divine" && defined(stat = "$character.divine_spellcasting_proficiency")
      && $character.divine_spellcasting_proficiency == "legendary" -> 4,
    selected_spellcasting_tradition_for_proficiency == "occult" && defined(stat = "$character.occult_spellcasting_proficiency")
      && $character.occult_spellcasting_proficiency == "trained" -> 1,
    selected_spellcasting_tradition_for_proficiency == "occult" && defined(stat = "$character.occult_spellcasting_proficiency")
      && $character.occult_spellcasting_proficiency == "expert" -> 2,
    selected_spellcasting_tradition_for_proficiency == "occult" && defined(stat = "$character.occult_spellcasting_proficiency")
      && $character.occult_spellcasting_proficiency == "master" -> 3,
    selected_spellcasting_tradition_for_proficiency == "occult" && defined(stat = "$character.occult_spellcasting_proficiency")
      && $character.occult_spellcasting_proficiency == "legendary" -> 4,
    selected_spellcasting_tradition_for_proficiency == "primal" && defined(stat = "$character.primal_spellcasting_proficiency")
      && $character.primal_spellcasting_proficiency == "trained" -> 1,
    selected_spellcasting_tradition_for_proficiency == "primal" && defined(stat = "$character.primal_spellcasting_proficiency")
      && $character.primal_spellcasting_proficiency == "expert" -> 2,
    selected_spellcasting_tradition_for_proficiency == "primal" && defined(stat = "$character.primal_spellcasting_proficiency")
      && $character.primal_spellcasting_proficiency == "master" -> 3,
    selected_spellcasting_tradition_for_proficiency == "primal" && defined(stat = "$character.primal_spellcasting_proficiency")
      && $character.primal_spellcasting_proficiency == "legendary" -> 4,
    else -> 0,
  };

calc integer selected_spellcasting_granted_proficiency_rank(name = "Selected spellcasting granted proficiency rank") =
  max(
    [
      global_spellcasting_granted_proficiency_rank,
      tradition_spellcasting_granted_proficiency_rank,
    ],
  );

calc integer selected_spellcasting_granted_proficiency_bonus(name = "Selected spellcasting granted proficiency bonus") =
  if !defined(stat = "$character.level_bonus")
    then 0
    else when {
        selected_spellcasting_granted_proficiency_rank == 1 -> $character.level_bonus + 2,
        selected_spellcasting_granted_proficiency_rank == 2 -> $character.level_bonus + 4,
        selected_spellcasting_granted_proficiency_rank == 3 -> $character.level_bonus + 6,
        selected_spellcasting_granted_proficiency_rank == 4 -> $character.level_bonus + 8,
        else -> 0,
      };

calc integer selected_spellcasting_proficiency_bonus(name = "Selected spellcasting proficiency bonus") =
  max(
    [
      selected_class_spellcasting_proficiency_bonus,
      selected_spellcasting_granted_proficiency_bonus,
    ],
  );

calc bool character_spell_slots_defined(name = "Character and spell slots defined") =
  defined(stat = "$character")
    && defined(stat = "$character.spell_slots_1")
    && defined(stat = "$character.spell_slots_2")
    && defined(stat = "$character.spell_slots_3")
    && defined(stat = "$character.spell_slots_4")
    && defined(stat = "$character.spell_slots_5")
    && defined(stat = "$character.spell_slots_6")
    && defined(stat = "$character.spell_slots_7")
    && defined(stat = "$character.spell_slots_8")
    && defined(stat = "$character.spell_slots_9")
    && defined(stat = "$character.spell_slots_10");

calc resource<prepared_spell_choice>[] selected_source_prepared_choices_rank_0(name = "Selected source prepared cantrips") =
  when {
    is_archetype_spell -> selected_spellcasting_archetype_source?.prepared_spell_choices_rank_0 ?? [],
    notNull(selected_spellcasting_class_source) -> selected_spellcasting_class_source?.prepared_spell_choices_rank_0 ?? [],
    else -> [],
  };

calc resource<prepared_spell_choice>[] selected_source_prepared_choices_rank_1(name = "Selected source prepared rank 1") =
  when {
    is_archetype_spell -> selected_spellcasting_archetype_source?.prepared_spell_choices_rank_1 ?? [],
    notNull(selected_spellcasting_class_source) -> selected_spellcasting_class_source?.prepared_spell_choices_rank_1 ?? [],
    else -> [],
  };

calc resource<prepared_spell_choice>[] selected_source_prepared_choices_rank_2(name = "Selected source prepared rank 2") =
  when {
    is_archetype_spell -> selected_spellcasting_archetype_source?.prepared_spell_choices_rank_2 ?? [],
    notNull(selected_spellcasting_class_source) -> selected_spellcasting_class_source?.prepared_spell_choices_rank_2 ?? [],
    else -> [],
  };

calc resource<prepared_spell_choice>[] selected_source_prepared_choices_rank_3(name = "Selected source prepared rank 3") =
  when {
    is_archetype_spell -> selected_spellcasting_archetype_source?.prepared_spell_choices_rank_3 ?? [],
    notNull(selected_spellcasting_class_source) -> selected_spellcasting_class_source?.prepared_spell_choices_rank_3 ?? [],
    else -> [],
  };

calc resource<prepared_spell_choice>[] selected_source_prepared_choices_rank_4(name = "Selected source prepared rank 4") =
  when {
    is_archetype_spell -> selected_spellcasting_archetype_source?.prepared_spell_choices_rank_4 ?? [],
    notNull(selected_spellcasting_class_source) -> selected_spellcasting_class_source?.prepared_spell_choices_rank_4 ?? [],
    else -> [],
  };

calc resource<prepared_spell_choice>[] selected_source_prepared_choices_rank_5(name = "Selected source prepared rank 5") =
  when {
    is_archetype_spell -> selected_spellcasting_archetype_source?.prepared_spell_choices_rank_5 ?? [],
    notNull(selected_spellcasting_class_source) -> selected_spellcasting_class_source?.prepared_spell_choices_rank_5 ?? [],
    else -> [],
  };

calc resource<prepared_spell_choice>[] selected_source_prepared_choices_rank_6(name = "Selected source prepared rank 6") =
  when {
    is_archetype_spell -> selected_spellcasting_archetype_source?.prepared_spell_choices_rank_6 ?? [],
    notNull(selected_spellcasting_class_source) -> selected_spellcasting_class_source?.prepared_spell_choices_rank_6 ?? [],
    else -> [],
  };

