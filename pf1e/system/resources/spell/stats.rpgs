calc integer selected_spell_prepared_total_rank_0(name = "Selected spell prepared total cantrip rank") =
  add(
    map(
      filter(selected_source_prepared_choices_rank_0, filter = ($choice) => ($choice.spell_id == id)),
      mapper = ($choice) => $choice.slot_quantity,
    ),
  );

calc integer selected_spell_prepared_used_rank_0(name = "Selected spell prepared used cantrip rank") =
  add(
    map(
      filter(selected_source_prepared_choices_rank_0, filter = ($choice) => ($choice.spell_id == id)),
      mapper = ($choice) => $choice.used_quantity,
    ),
  );

calc integer selected_spell_prepared_remaining_rank_0(name = "Selected spell prepared remaining cantrip rank") =
  max([0, selected_spell_prepared_total_rank_0 - selected_spell_prepared_used_rank_0]);

calc integer selected_spell_prepared_total_rank_1(name = "Selected spell prepared total rank 1") =
  add(map(filter(selected_source_prepared_choices_rank_1, filter = ($choice) => ($choice.spell_id == id)), mapper = ($choice) => $choice.slot_quantity));

